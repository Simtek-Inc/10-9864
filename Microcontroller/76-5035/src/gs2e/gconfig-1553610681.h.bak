#ifndef __GCONFIG_H__
#define __GCONFIG_H__

// INCLUDE FILE DECLARATIONS //
#include "types.h"

// NAMING CONSTANT DECLARATIONS //
#define GCONFIG_DEFAULT_DATA_PORT		      51020                                     // Default data port for both server and client modes
#define GCONFIG_DEFAULT_Host_PORT		      51021                                     // Default data port for both server and client modes
#define GCONFIG_DEFAULT_BCAST_PORT	            25122                                     // UDP broadcast listening ports
#define GCONFIG_DEFAULT_UCAST_PORT	 	      25124                                     // UDP unicast listening ports
// Following UDP broadcast, multicast and unicast listening ports are used for communication
// with Device Server Manager program and are not configurable





#define GCONFIG_CFG_DATA_FLASH_ADDR		      0x4000                                    //
#define GCONFIG_CFG_PKT_LEN			      72                                        //

#define GCONFIG_OPCODE_OFFSET			      8                                         //
#define GCONFIG_OPCODE_SEARCH_REQ		      0x00                                      //
#define GCONFIG_OPCODE_SEARCH_ACK		      0x01                                      //

#define GCONFIG_OPCODE_SET_REQ		      0x02                                      //
#define GCONFIG_OPCODE_SET_ACK		      0x03                                      //
#define GCONFIG_OPCODE_SET_DENY		      0x04                                      //

#define GCONFIG_OPCODE_UPGRADE_REQ		      0x05                                      //
#define GCONFIG_OPCODE_UPGRADE_ACK		      0x06                                      //
#define GCONFIG_OPCODE_UPGRADE_DENY		      0x07                                      //

#define GCONFIG_OPCODE_RESET_REQ		      0x08                                      //
#define GCONFIG_OPCODE_RESET_ACK		      0x09                                      //
#define GCONFIG_OPCODE_RESET_DENY		      0x0A                                      //

#define GCONFIG_OPCODE_REBOOT_REQ		      0x0B                                      //
#define GCONFIG_OPCODE_REBOOT_ACK		      0x0C                                      //
#define GCONFIG_OPCODE_REBOOT_DENY		      0x0D                                      //

#define GCONFIG_OPCODE_MONITOR_REQ		      0x10                                      //
#define GCONFIG_OPCODE_MONITOR_ACK		      0x11                                      //

#define GCONFIG_OPCODE_CONN_CLOSE		      0x12                                      //
#define GCONFIG_OPCODE_NONE			      0xFF                                      //

#define GCONFIG_OPTION_ENABLE_REBOOT		0x01                                      //
//#define GCONFIG_OPTION_ENABLE_UDP_AUTO_CONNECT	0x02                                      //
#define GCONFIG_OPTION_ENABLE_SIMTEK_DEBUG    	0x04                                      //

#define GCONFIG_NETWORK_SERVER		      0x0000                                    //
#define GCONFIG_NETWORK_CLIENT		      0x8000                                    //

#define GCONFIG_NETWORK_DHCP_ENABLE		      0x4000                                    //
#define GCONFIG_NETWORK_DHCP_DISABLE	      0x0000                                    //

#define GCONFIG_NETWORK_PROTO_UDP		      0x0800                                    //
#define GCONFIG_NETWORK_PROTO_TCP		      0x0400                                    //
#define GCONFIG_NETWORK_PROTO_UDP_BCAST	      0x0100                                    //
//#define GCONFIG_NETWORK_ACC_IP_ENABLE	      0x1000                                    //
//#define GCONFIG_NETWORK_ACC_IP_DISABLE	      0x0000                                    //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//                bit masks                                                               //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
#define DebugModeMask                           0x0004                                    //
#define TransmitModeMask                        0x0008                                    //
#define DeadManCntMask                          0x0010                                    //
#define ReportMethodMask                        0x0020                                    //

#define GCONFIG_NETWORK_TIMEOUT_0_MIN	      0x0000                                    //
#define GCONFIG_NETWORK_TIMEOUT_10_MIN	      0x000A                                    //

#define GCONFIG_SPORT_BRATE_921600		      0x0000                                    //
#define GCONFIG_SPORT_BRATE_115200		      0x0800                                    //
#define GCONFIG_SPORT_BRATE_38400		      0x1000                                    //
#define GCONFIG_SPORT_BRATE_19200		      0x1800                                    //
#define GCONFIG_SPORT_BRATE_9600		      0x2000                                    //
#define GCONFIG_SPORT_BRATE_4800		      0x2800                                    //
#define GCONFIG_SPORT_BRATE_2400		      0x3000                                    //
#define GCONFIG_SPORT_BRATE_1200		      0x3800                                    //
#define GCONFIG_SPORT_DATABIT_5		      0x0000                                    //
#define GCONFIG_SPORT_DATABIT_6		      0x0100                                    //
#define GCONFIG_SPORT_DATABIT_7		      0x0200                                    //
#define GCONFIG_SPORT_DATABIT_8		      0x0300                                    //
#define GCONFIG_SPORT_PARITY_ODD		      0x0000                                    //
#define GCONFIG_SPORT_PARITY_EVEN		      0x0020                                    //
#define GCONFIG_SPORT_PARITY_NONE		      0x0040                                    //
#define GCONFIG_SPORT_FLOWC_XON_XOFF	      0x0000                                    //
#define GCONFIG_SPORT_FLOWC_HARDWARE	      0x0004                                    //
#define GCONFIG_SPORT_FLOWC_NONE		      0x0008                                    //
#define GCONFIG_SPORT_STOPBIT_1		      0x0000                                    //
#define GCONFIG_SPORT_STOPBIT_1P5		      0x0001                                    //
#define GCONFIG_SPORT_STOPBIT_2		      0x0002                                    //

#define GCONFIG_ACCESSIBLE_IP_NUM		      4                                         //
#define GCONFIG_VERSION_STR_LEN		      12                                        //
#define GCONFIG_VERSION_STRING		      "3.1.200"                                 //

// TYPE DECLARATIONS //
typedef struct _GCONFIG_GID                                                               //
{
      U8_T                    id[8];                                                      //
} GCONFIG_GID;                                                                            //

typedef struct _GCONFIG_DEV_NAME                                                          //
{
      U8_T				DevName[16];                                                //
} GCONFIG_DEV_NAME;                                                                       //

typedef struct _GCONFIG_MAC_ADDR                                                          //
{
      U8_T				MacAddr[6];                                                 //
} GCONFIG_MAC_ADDR;                                                                       //

typedef struct _GCONFIG_SMTP_CONFIG                                                       //
{
      U8_T                    DomainName[36];                                             //
      U8_T                    FromAddr[36];                                               //
      U8_T                    ToAddr1[36];                                                //
      U8_T                    ToAddr2[36];                                                //
      U8_T                    ToAddr3[36];                                                //
      U16_T                   EventEnableBits;                                             //
} GCONFIG_SMTP_CONFIG;                                                                    //

typedef struct                                                                            //
{
      U8_T                    Username[16];                                               //
      U8_T                    Passwd[16];                                                 //
      U8_T                    Level;                                                      //
      U8_T                    Rsvd;                                                       //
} GCONFIG_ADMIN;                                                                          //

typedef struct _GCONFIG_CFG_PKT                                                           //
{
      GCONFIG_GID             Gid;                                                        // length  8 NumOfBytes =  8
      U8_T                    Opcode;                                                     // length  1 NumOfBytes =  9
      U8_T                    Option;                                                     // length  1 NumOfBytes =  10
      GCONFIG_DEV_NAME        DevName;                                                    // length 16 NumOfBytes =  26
      GCONFIG_MAC_ADDR        MacAddr;                                                    // length  6 NumOfBytes =  32
      U16_T                    Network;                                                    // length  2 NumOfBytes =  34
      U32_T                   ServerDynamicIP;                                            // length  4 NumOfBytes =  38
      U32_T                   ServerStaticIP;                                             // length  4 NumOfBytes =  42
      U16_T                    ServerDataPktListenPort;                                    // length  2 NumOfBytes =  44
      U8_T                    MasterAddress;                                              // length  1 NumOfBytes =  46
      U8_T                    t5;                                                         // length  1 NumOfBytes =  47
      U16_T                    ServerBroadcastListenPort;                                  // length  2 NumOfBytes =  48
      U32_T                   ClientDestIP;                                               // length  4 NumOfBytes =  52
      U16_T                    ClientDestPort;                                             // length  2 NumOfBytes =  54
      U32_T                   Netmask;                                                    // length  4 NumOfBytes =  58
      U32_T                   t1;
      U32_T                   t2;
      U16_T                    t3;
      U8_T                    t4;
      U8_T                    DeviceStatus;                                               // length  1 NumOfBytes =  70
      U16_T                    EthernetTxTimer;                                            // length  2 NumOfBytes =  72
} GCONFIG_CFG_PKT;

typedef struct _GCONFIG_CFG_DATA
{
      U16_T                    CheckSum;                                                   // length  2 NumOfBytes =  2
      U16_T                    CfgLength;                                                  // length  2 NumOfBytes =  4
      /* the following 5 items will be used for boot loader */
      GCONFIG_DEV_NAME        DevName;                                                    // length 16 NumOfBytes =  20
      GCONFIG_MAC_ADDR        mac;                                                        // length  6 NumOfBytes =  26

      U32_T                   DevServerIpAddr;                                            // length  4 NumOfBytes =  30
      U32_T                   DevClientIPAddr;                                            // length  4 NumOfBytes =  34
      U32_T                   HostServerIPAddr;                                           // length  4 NumOfBytes =  38
      U32_T                   HostClientIPAddr;                                           // length  4 NumOfBytes =  42
      U32_T                   SubNetmask;                                                 // length  4 NumOfBytes =  46
      U32_T                   ex1Ip;                                                      // length  4 NumOfBytes =  50
      U32_T                   ex2Ip;                                                      // length  4 NumOfBytes =  54

      U16_T                    DevServerPort;                                              // length  2 NumOfBytes =  56
      U16_T                    DevUnicastPort;                                             // length  2 NumOfBytes =  58
      U16_T                    DevBroadcastPort;                                           // length  2 NumOfBytes =  60
      U16_T                    DevClientPort;                                              // length  2 NumOfBytes =  62
      U16_T                    HostServerPort;                                             // length  2 NumOfBytes =  64
      U16_T                    HostClientPort;                                             // length  2 NumOfBytes =  66
      U16_T                    ex1Port;                                                    // length  2 NumOfBytes =  68

      U8_T                    BinaryFlags;                                                // length  1 NumOfBytes =  70
      U16_T                    Network;                                                    // length  2 NumOfBytes =  71
      U8_T                    Option;                                                     // length  1 NumOfBytes =  73
      U16_T                    EthernetTxTimer;                                            // length  2 NumOfBytes =  74
} GCONFIG_CFG_DATA;

typedef struct _GCONFIG_CFG_DATA_old2
{
      U16_T                    CheckSum;                                                   // length  2 NumOfBytes =  2
      U16_T                    CfgLength;                                                  // length  2 NumOfBytes =  4

      GCONFIG_DEV_NAME        DevName;                                                    // length 16 NumOfBytes =  20
      GCONFIG_MAC_ADDR        mac;                                                        // length  6 NumOfBytes =  26

      U32_T                   ServerStaticIP;                                             // length  4 NumOfBytes =  30
      U32_T                   ClientDestIP;                                               // length  4 NumOfBytes =  34
      U32_T                   Netmask;                                                    // length  4 NumOfBytes =  38
      U32_T                   ex1Ip;                                                      // length  4 NumOfBytes =  42
      U32_T                   ex4Ip;                                                      // length  4 NumOfBytes =  46
      U32_T                   ex3Ip;                                                      // length  4 NumOfBytes =  50
      U32_T                   ex2Ip;                                                      // length  4 NumOfBytes =  54

      U16_T                    ServerDataPktListenPort;                                    // length  2 NumOfBytes =  56
      U16_T                    ServerBroadcastListenPort;                                  // length  2 NumOfBytes =  58
      U16_T                    ClientDestPort;                                             // length  2 NumOfBytes =  60
      U16_T                    ex1Port;                                                    // length  2 NumOfBytes =  62
      U16_T                    ex2Port;                                                    // length  2 NumOfBytes =  64
      U16_T                    t2;                                                         // length  2 NumOfBytes =  66
      U16_T                    t3;                                                         // length  2 NumOfBytes =  68

      U8_T                    t4;                                                         // length  1 NumOfBytes =  70
      U16_T                    Network;                                                    // length  2 NumOfBytes =  71
      U8_T                    Option;                                                     // length  1 NumOfBytes =  73
      U16_T                    EthernetTxTimer;                                            // length  2 NumOfBytes =  74
} GCONFIG_CFG_DATA_old2;

typedef struct _GCONFIG_CFG_DATA_old
{
      U16_T 				CheckSum;                                                   // length  2 NumOfBytes =  2 
	U16_T 				CfgLength;                                                  // length  2 NumOfBytes =  4 
	/* the following 5 items will be used for boot loader */ 
	U32_T				DeviceIp;                                                   // length  4 NumOfBytes =  8  
	U32_T				DeviceNetmask;                                              // length  4 NumOfBytes =  12 
	U32_T				DeviceGateway;                                              // length  4 NumOfBytes =  16 
	U32_T				UdpAutoConnectClientIp;                                     // length  4 NumOfBytes =  20 
	U16_T 				UdpAutoConnectClientPort;                                   // length  2 NumOfBytes =  22 

	GCONFIG_DEV_NAME		DevName;                                                    // length 16 NumOfBytes =  38 ->byte devname[16]
	U16_T 				Network;                                                    // length  2 NumOfBytes =  40 
	U32_T				ServerStaticIP;                                             // length  4 NumOfBytes =  44
	U16_T 				ServerDataPktListenPort;                                    // length  2 NumOfBytes =  46
	U16_T 				ServerMulticastListenPort;                                  // length  2 NumOfBytes =  48
	U16_T 				ServerBroadcastListenPort;                                  // length  2 NumOfBytes =  50
	U32_T				ClientDestIP;                                               // length  4 NumOfBytes =  54
	U16_T 				ClientDestPort;                                             // length  2 NumOfBytes =  56
	U32_T				Netmask;                                                    // length  4 NumOfBytes =  60
	U32_T				Gateway;                                                    // length  4 NumOfBytes =  64
	U32_T				Dns;                                                        // length  4 NumOfBytes =  68
	U16_T 				SerialPort;                                                 // length  2 NumOfBytes =  70
	U8_T				Rs485Mode;                                                  // length  1 NumOfBytes =  71
	U8_T				Option;                                                     // length  1 NumOfBytes =  72
	U16_T 				EthernetTxTimer;                                            // length  2 NumOfBytes =  74
} GCONFIG_CFG_DATA_old;

typedef struct _GCONFIG_MONITOR_PKT
{
	GCONFIG_GID 		Gid;
	U8_T				Opcode;
	U8_T				ModemStatus;
	U8_T				VerStr[GCONFIG_VERSION_STR_LEN];
	U32_T				TxBytes;
	U32_T				RxBytes;
} GCONFIG_MONITOR_PKT;

typedef struct _GCONFIG_CONN_CLOSE_PKT
{
	GCONFIG_GID 		Gid;
	U8_T				Opcode;
	U8_T				Option;
	U32_T				RemoteIp;
	U16_T				Port;
} GCONFIG_CONN_CLOSE_PKT;

// GLOBAL VARIABLES //
extern GCONFIG_GID XDATA GCONFIG_Gid;

// EXPORTED SUBPROGRAM SPECIFICATIONS //
void GCONFIG_Task(void);
void GCONFIG_Init(void);
void GCONFIG_SetConfigPacket(GCONFIG_CFG_PKT*);
void GCONFIG_GetConfigPacket(GCONFIG_CFG_PKT*);
void GCONFIG_ReadConfigData(void);
void GCONFIG_WriteConfigData(void);
void GCONFIG_ReadDefaultConfigData(void);
//void gconfig_DisplayConfigData(GCONFIG_CFG_DATA *pConfig);
void gconfig_ExDisplayConfigData(void);
U16_T exChecksum(U16_T *pBuf, U32_T length);

U32_T GCONFIG_IpAddr2Ulong(byte*, byte);

U8_T GCONFIG_EnableUdpAutoConnectAfterReboot(void);
void GCONFIG_EnableFirmwareUpgrade(void);
U8_T Simtek_Modes_Enable(U8_T);

void GCONFIG_SetDeviceName(GCONFIG_DEV_NAME*);
void GCONFIG_SetNetwork(U16_T);
void GCONFIG_SetServerStaticIP(U32_T);
void GCONFIG_SetHostMasterAddress(U8_T adrs);
void GCONFIG_SetServerDataPktListenPort(U16_T);
void GCONFIG_SetServerBroadcastListenPort(U16_T);
void GCONFIG_SetClientDestIP(U32_T);
void GCONFIG_SetClientDestPort(U16_T);
void GCONFIG_SetNetmask(U32_T);

bool                          UTIL_PortNumToStr(char *hdr, U16_T *num);
bool                          UTIL_ByteAryToStr(char *hdr, U8_T *num, U8_T len);
bool                          UTIL_MacToStr(char *hdr, U8_T *num, U8_T len);

GCONFIG_CFG_DATA* GCONFIG_GetDeviceDCB(void);
GCONFIG_DEV_NAME* GCONFIG_GetDeviceName(void);
GCONFIG_MAC_ADDR  GCONFIG_GetMacAddress(void);
U16_T  GCONFIG_GetNetwork(void);
U32_T GCONFIG_GetServerStaticIP(void);
U8_T  GCONFIG_GetHostMasterAddress(void);
U16_T  GCONFIG_GetServerDataPktListenPort(void);
U16_T  GCONFIG_GetServerBroadcastListenPort(void);
U32_T GCONFIG_GetClientDestIP(void);
U16_T  GCONFIG_GetClientDestPort(void);
U32_T GCONFIG_GetNetmask(void);
U16_T  GCONFIG_GetEthernetTxTimer(void);

#endif // End of __GCONFIG_H__ //

// End of gconfig.h //
