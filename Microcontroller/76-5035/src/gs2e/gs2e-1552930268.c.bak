// INCLUDE FILE DECLARATIONS //
#include "adapter.h"
#include "gs2e.h"
#include "gudpdat.h"
#include "gudpbc.h"
#include "gudpuc.h"
#include "gconfig.h"
#include "printd.h"
#include "mac.h"
#include "eeprom.h"
#include "ping.h"
#include "ax11000.h"
// NAMING CONSTANT DECLARATIONS //

// MACRO DECLARATIONS //

// GLOBAL VARIABLES DECLARATIONS //

// LOCAL VARIABLES DECLARATIONS //
static byte XDATA gs2e_State;
static byte XDATA gs2e_ConnType;

word  DEADMANcnt;
// LOCAL SUBPROGRAM DECLARATIONS //
void   gs2e_EEPROM_Init(void);

//----------------------------------------------------------------------------------------
// name    : GS2E_Task
// purpose : 
// params  :
// returns :
// note    :
//----------------------------------------------------------------------------------------
void GS2E_Task(void)
{
	GCONFIG_Task();
	if (gs2e_ConnType == GS2E_CONN_UDP)
	  GUDPDAT_Task();
    if (DEADMANcnt > 0)
      {
      if (gs2e_State == GS2E_STATE_UDP_DATA_PROCESS)
        DEADMANcnt = 0;
      else
        {
        DEADMANcnt--;
        printd("DEADMANcnt = %du %bx\r",DEADMANcnt, gs2e_State);
        }
      }
    if (DEADMANcnt == 1) {  AX11000_SoftReboot();  DEADMANcnt = 0;  }
} // End of GS2E_Task() //


//----------------------------------------------------------------------------------------
// name    : gs2e_EEPROM_Init()
// purpose : initialization the I2C sytem
// params  : none
// returns : none
// note    :
//----------------------------------------------------------------------------------------
void   gs2e_EEPROM_Init(void)
{
	EEPROM_Init();
}

//----------------------------------------------------------------------------------------
// name    : GS2E_Init()
// purpose : Initialization
// params  :
// returns :
// note    :
//----------------------------------------------------------------------------------------
void GS2E_Init(void)
{	
//	printd("GS2E_Init()\n\r");
	gs2e_State = GS2E_STATE_IDLE; 

	if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_PROTO_UDP_BCAST) == GCONFIG_NETWORK_PROTO_UDP_BCAST)
	  {
	  GUDPBC_Init(GCONFIG_DEFAULT_BCAST_PORT);
	  }
	GUDPUC_Init(GCONFIG_DEFAULT_UCAST_PORT);

	if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_PROTO_UDP) == GCONFIG_NETWORK_PROTO_UDP)
	  {
	  gs2e_ConnType = GS2E_CONN_UDP;
	  GUDPDAT_Init(GCONFIG_GetServerDataPktListenPort());
	  }
	gs2e_EEPROM_Init();
      DEADMANcnt = 2000;
} // End of GS2E_Init() //

//----------------------------------------------------------------------------------------
// name    : GS2E_GetTaskState
// purpose : 
// params  :
// returns :
// note    :
//----------------------------------------------------------------------------------------
byte GS2E_GetTaskState(void)
{
	return gs2e_State;
} // End of GS2E_GetTaskState() //

//----------------------------------------------------------------------------------------
// name    : GS2E_SetTaskState
// purpose : 
// params  :
// returns :
// note    :
//----------------------------------------------------------------------------------------
void GS2E_SetTaskState(byte state)
{
	gs2e_State = state;
} // End of GS2E_SetTaskState() //

//----------------------------------------------------------------------------------------
// name    : GS2E_GetConnType
// purpose : 
// params  :
// returns :
// note    :
//----------------------------------------------------------------------------------------
byte GS2E_GetConnType(void)
{
	return gs2e_ConnType;
} // End of GS2E_GetConnType() //

// End of gs2e.c //
