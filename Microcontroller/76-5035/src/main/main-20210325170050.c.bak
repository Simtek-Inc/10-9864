    sbit          S10_TL = U07_0^0;       // S10.8 seg-24 connector-J1.24 driver-U07_8 name-FAST.TL
static byte bdata U09_0 _at_ 0x23;                                                        //
    sbit          S06_BL = U09_0^7;       // S06.5 seg-25 connector-J1.25 driver-U09_1 name-STOW.BL
    sbit          S06_TR = U09_0^6;       // S06.9 seg-26 connector-J1.26 driver-U09_2 name-STOW.TR
    sbit          S08_BL = U09_0^5;       // S08.5 seg-27 connector-J1.27 driver-U09_3 name-UP.BL
