static uint idata      wordreg _at_ 0x20;                                                 //
static byte bdata btmpH _at_ 0x20;                                                        //
    sbit          btmpH0 = btmpH^0;                                                       //
    sbit          btmpH1 = btmpH^1;                                                       //
    sbit          btmpH2 = btmpH^2;                                                       //
    sbit          btmpH3 = btmpH^3;                                                       //
    sbit          btmpH4 = btmpH^4;                                                       //
    sbit          btmpH5 = btmpH^5;                                                       //
    sbit          btmpH6 = btmpH^6;                                                       //
    sbit          btmpH7 = btmpH^7;                                                       //
static byte bdata btmpL _at_ 0x21;                                                        //
    sbit          btmpL0 = btmpL^0;                                                       //
    sbit          btmpL1 = btmpL^1;                                                       //
    sbit          btmpL2 = btmpL^2;                                                       //
    sbit          btmpL3 = btmpL^3;                                                       //
    sbit          btmpL4 = btmpL^4;                                                       //
    sbit          btmpL5 = btmpL^5;                                                       //
    sbit          btmpL6 = btmpL^6;                                                       //
    sbit          btmpL7 = btmpL^7;                                                       //
//te bufIndicatorData[ix01];                                                                 //
    sbit          POWERON   = btmpL^0;                                                    //
    sbit          SLAVEGRN  = btmpL^1;                                                    //
    sbit          SLAVEAMB  = btmpL^2;                                                    //
    sbit          LOADGRN   = btmpL^3;                                                    //
    sbit          LOADAMB   = btmpL^4;                                                    //
    sbit          MANUALGRN = btmpL^5;                                                    //
    sbit          MANUALAMB = btmpL^6;                                                    //
//te bufIndicatorData[ix02];                                                                 //
    sbit          STOWGRN   = btmpL^0;                                                    //
    sbit          STOWAMB   = btmpL^1;                                                    //
    sbit          FAST      = btmpL^2;                                                    //
//te bufIndicatorData[ix03];                                                                 //
    sbit          UP        = btmpL^4;                                                    //
    sbit          LEFT      = btmpL^5;                                                    //
    sbit          RIGHT     = btmpL^6;                                                    //
    sbit          DOWN      = btmpL^7;                                                    //
//te bufIndicatorData[ix04];                                                                 //
    sbit          APDS      = btmpL^0;                                                    //
    sbit          HEI       = btmpL^1;                                                    //
    sbit          API       = btmpL^2;                                                    //
    sbit          TP        = btmpL^3;                                                    //
                                          // block sch    connector.pin
static byte bdata U03_0 _at_ 0x22;        // name  sch    connector       sch U#_seg   name/
    sbit          S02_BR = U03_0^7;       // S02.6 seg-01 connector-J1.01 driver-U03_1 name-POWER.BR
    sbit          S02_TL = U03_0^6;       // S02.8 seg-02 connector-J1.02 driver-U03_2 name-POWER.TL
    sbit          S03_BR = U03_0^5;       // S03.6 seg-03 connector-J1.03 driver-U03_3 name-SLAVE.BR
