    sbit          S05_TR = U05_0^0;       // S05.9 seg-16 connector-J1.16 driver-U05_8 name-MANUAL.TR
static byte bdata U07_0 _at_ 0x22;                                                        //
    sbit          S06_BR = U07_0^7;       // S06.6 seg-17 connector-J1.17 driver-U07_1 name-STOW.BR
