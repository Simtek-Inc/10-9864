//========================================================================================//
//      fpga register addresses                                                           //
//========================================================================================//
#define defaultaddress        0x00                                                        // default address to use after reset

#define adrsfirmware1         0x20                                                        // firmware number and revision data
#define adrsfirmware2         0x21                                                        // firmware number and revision data
#define adrsfirmware3         0x22                                                        // firmware number and revision data
#define adrsfirmware4         0x23                                                        // firmware number and revision data

#define adrsA2DChannel0       0x50                                                        // address of a2d channel 0 reader
#define adrsA2DChannel1       0x51                                                        // address of a2d channel 1 reader

#define adrsswitchbank1       0x60                                                        // address of switch bank 1 reader
#define adrsswitchbank2       0x61                                                        // address of switch bank 2 reader
#define adrsswitchbank3       0x62                                                        // address of switch bank 3 reader
#define adrsswitchbank4       0x63                                                        // address of switch bank 4 reader

#define adrsexternalenables   0x80                                                        // address of control register for external hardware enable/disable

#define closeCOMports         0x63
#define A2DEngineEnable       0x01  // turn the a2d sample in engine on
#define onSwCmnLo             0x02
#define onSwCmnHi             0x04
#define onRs422port           0x18
#define onRs422portRe         0x10
#define onRs233port           0x20
#define onHeartBeat           0x40  // turn the heartbeat on
#define onHeartBeatPWM        0x80  // turn the heart beat dimming with pwm on
#define defaultexternal       onRs233port | onSwCmnLo | offHeartBeat | A2DEngineEnable | onRs422port
#define adrsbitcontrol1       0x90                                                        // address of discrete bit control bank 1
#define defaultpwmctrl01      0x00                                                        // default off state of device enable bank = 0xFF
#define adrsbitcontrol2       0x91                                                        // address of discrete bit control bank 2
#define adrsbitcontrol3       0x92                                                        // address of discrete bit control bank 3
#define adrspwmon01           0xA0                                                        // address of the device enable latch bank 1
#define adrspwmon02           0xA1                                                        // address of the device enable latch bank 2
#define adrspwmon03           0xA2                                                        // address of the device enable latch bank 3
#define adrspwmon02           0xA1                                                        // address of the device enable latch bank 2
#define defaultpwmctrl02      0x00                                                        // default off state of device enable bank = 0x3F
#define adrsbitcontrol3       0x92                                                        // address of discrete bit control bank 3
#define defaultbitonbit3      0x3F        // 1 = ON                                       // define the default state
#define adrspwmon03           0xA2                                                        // address of the device enable latch bank 3
#define defaultpwmctrl03      0x3F                                                        // default off state of device enable bank = 0x3F

#define defaultdutycycle      0x0C00                                                      // default PWM duty cycle
#define adrsDutyCycle01       0xC0                                                        // address_xC0 address of pwm duty cycle control register for discrete 1
#define adrsDutyCycle02       0xC1                                                        // address_xC1 address of pwm duty cycle control register for discrete 2
#define adrsDutyCycle03       0xC2                                                        // address_xC2 address of pwm duty cycle control register for discrete 3
#define adrsDutyCycle04       0xC3                                                        // address_xC2 address of pwm duty cycle control register for discrete 3
