    sbit          S16_BL = U06_0^5;       // S16.5 seg-59 connector-J2.27 driver-U06_3 name-AP1.BL
    sbit          S16_TR = U06_0^4;       // S16.9 seg-60 connector-J2.28 driver-U06_4 name-AP1.TR
    sbit          S17_BL = U06_0^3;       // S17.5 seg-61 connector-J2.29 driver-U06_5 name-TP.BL
    sbit          S17_TR = U06_0^2;       // S17.9 seg-62 connector-J2.30 driver-U06_6 name-TP.TR
    sbit          S18_BL = U06_0^1;       // N02.0 seg-63 connector-J2.31 driver-U06_7 name-NU.BL
    sbit          S18_TR = U06_0^0;       // N02.0 seg-64 connector-J2.32 driver-U06_8 name-NU.TR
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
