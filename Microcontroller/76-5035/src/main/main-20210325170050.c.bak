//----------------------------------------------------------------------------------------
// Name          : iRamCheck                                                              //
// Purpose       : test a cell of the internal RAM to make sure it functions properly     //
// Params        : pointer to the memory cell to check                                    //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
byte iRamCheck(byte IDATA* ptr)                                                           // check the external RAM for malfunctioning bits
{
      byte state = 0;
      *ptr = 0x00;                                                                        // write all bits off to the location
      if (*ptr != 0x00) {state = 0x40;}                                                   // make sure that the current location is 0x00 if not set the error flag
      *ptr = 0xFF;                                                                        // write all bits on to the location
      if (*ptr != 0xFF) {state = 0x40;}                                                   // make sure that the current location is 0xff if not set the error flag
      *ptr = 0x00;                                                                        // write all bits off to the location
      return state;                                                                       // return to status of the ram test
}

//----------------------------------------------------------------------------------------
// Name          : xRamCheck                                                              //
// Purpose       : test a cell of the external RAM to make sure it functions properly     //
// Params        : pointer to the memory cell to check                                    //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
byte xRamCheck(byte XDATA* ptr)                                                           // check the external RAM for malfunctioning bits
{
      byte state = 0;
      *ptr = 0x00;                                                                        // write all bits off to the location
      if (*ptr != 0x00) {state = 0x40;}                                                   // make sure that the current location is 0x00 if not set the error flag
      *ptr = 0xFF;                                                                        // write all bits on to the location
      if (*ptr != 0xFF) {state = 0x40;}                                                   // make sure that the current location is 0xff if not set the error flag
      *ptr = 0x00;                                                                        // write all bits off to the location
       return state;                                                                      // return to status of the ram test
}

//----------------------------------------------------------------------------------------
// Name          : fpgaWriteAddress                                                       //
// Purpose       : write the address of the register to access within the FPGA            //
// Params        : the address of the register                                            //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void fpgaWriteAddress(byte adrs)                                                          //
{
      byte i;

      fpgaserialale     = 1;                                                              // make sure the fpga ale is deactived before starting
      fpgaserialale     = 1;                                                              // make sure the fpga ale is deactived before starting
      fpgaserialclock   = 1;                                                              // make sure the fpga serial register clock is deactived before starting
      fpgaserialclock   = 1;                                                              // make sure the fpga serial register clock is deactived before starting
      btmpH             = adrs;                                                           // zero out the read byte to start
      fpgaserialale     = 0;                                                              // activate the ale to move the address into the address latch from the sipo function
      for (i = 0; i < 8; i++)                                                             // loop until all bits are read
        {
        fpgadatain      = btmpH0;                                                         // write the bit of the data to the fpga data input pin
        fpgadatain      = btmpH0;                                                         // burn a ccyle
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // burn a ccyle
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // burn a ccyle
        btmpH           = btmpH >> 1;                                                     // shift the next bit into position for the next bit write
        fpgaserialclock = 1;                                                              // set the clock to activate
        fpgaserialclock = 1;                                                              // set the clock to activate
        fpgaserialclock = 1;                                                              // set the clock to activate
        fpgaserialclock = 1;                                                              // set the clock to activate
        }
      fpgaserialclock   = 1;                                                              // set the clock to high to burn a cycle
      fpgaserialale     = 1;                                                              // now that the address is latched deactivate the ale
      fpgaserialale     = 1;                                                              // now that the address is latched deactivate the ale
      fpgadatain        = 1;                                                              // write the bit of the data to the fpga data input pin
      fpgadatain        = 1;                                                              // write the bit of the data to the fpga data input pin
}

//----------------------------------------------------------------------------------------
// Name          : fpgaWriteData                                                          //
// Purpose       : write the address of the register to access within the FPGA            //
// Params        : the address of the register, and the bits of resolution                //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void fpgaWriteData(byte adrs, uint dat, byte numofbits)                                   //
{
      byte i;

      fpgaWriteAddress(adrs);                                                             // output the fpga register address
      fpgaserialload    = 1;                                                              // make sure the fpga load is deactived before starting
      fpgaserialclock   = 1;                                                              // make sure the fpga serial register clock is deactived before starting
      wordreg           = dat;                                                            // load the data uint to write to the register 
      fpgaserialload    = 0;                                                              // activate the load ale to move the address into the address latch from the sipo function
      for (i = 0; i < numofbits; i++)                                                     // loop until all bits are read
        {
        fpgadatain      = btmpL0;                                                         // write the bit of the data to the fpga data input pin
        fpgadatain      = btmpL0;                                                         // burn a ccyle
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // burn a ccyle
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // burn a ccyle
        wordreg         = wordreg >> 1;                                                   // shift the next bit into position for the next bit write
        fpgaserialclock = 1;                                                              // activate the fpga serial register clock
        fpgaserialclock = 1;                                                              // activate the fpga serial register clock
        }
      fpgaserialclock   = 1;                                                              // set the clock to high again to burn a cycle
      fpgaserialload    = 1;                                                              // now that the data is clocked in activate the load
      fpgadatain        = 1;                                                              // write the bit of the data to the fpga data input pin
}

//----------------------------------------------------------------------------------------
// Name          : fpgaWriteData                                                          //
// Purpose       : write the address of the register to access within the FPGA            //
// Params        : the address of the register, and the bits of resolution                //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void fpgaWriteDataL(byte adrs, byte *pdat, byte numofbits)                                   //
{
      byte i, dat;
      
      dat = *pdat;

      fpgaWriteAddress(adrs);                                                             // output the fpga register address
      fpgaserialload    = 1;                                                              // make sure the fpga load is deactived before starting
      fpgaserialclock   = 1;                                                              // make sure the fpga serial register clock is deactived before starting
      wordreg           = dat;                                                            // load the data uint to write to the register 
      fpgaserialload    = 0;                                                              // activate the load ale to move the address into the address latch from the sipo function
      for (i = 0; i < numofbits; i++)                                                     // loop until all bits are read
        {
        if((i % 8) == 0)                                                                  //
          {
          btmpL           = *pdat;                                                        //
          pdat++;                                                                         //
 //  printd("%02bx\n\r",btmpL);
          }
        fpgadatain      = btmpL0;                                                         // write the bit of the data to the fpga data input pin
//   if(btmpL0 == 0) printd("0"); else  printd("1");
        fpgadatain      = btmpL0;                                                         // burn a ccyle
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // burn a ccyle
        fpgaserialclock = 0;                                                              // deactivate the fpga serial register clock
        fpgaserialclock = 0;                                                              // burn a ccyle
        btmpL           = btmpL >> 1;                                                     // shift the next bit into position for the next bit write
        fpgaserialclock = 1;                                                              // activate the fpga serial register clock
        fpgaserialclock = 1;                                                              // activate the fpga serial register clock
        }
      fpgaserialclock   = 1;                                                              // set the clock to high again to burn a cycle
      fpgaserialload    = 1;                                                              // now that the data is clocked in activate the load
//   printd("\n\r");
      fpgadatain        = 1;                                                              // write the bit of the data to the fpga data input pin
}

//----------------------------------------------------------------------------------------
// Name          : fpgaReadData                                                           //
// Purpose       : read the data from the register address given                          //
// Params        : the address of the register, and the bits of resolution                //
// Returns       : void                                                                   //
// Note          : this routine is setup for a max of 16 bits                             //
//----------------------------------------------------------------------------------------
uint fpgaReadData(byte adrs, numofbits)                                                   //
{
      byte i;

      fpgaWriteAddress(adrs);                                                             // output the fpga register address
      fpgaserialclock   = 1;                                                              // set the clock and, the load line to make sure
      fpgaserialload    = 1;                                                              //  the index starts at zero , and the data is latched
      fpgadataout       = 1;                                                              // setup pin for reading
      fpgaserialload    = 0;                                                              // activate the load to move the parallel data into the serial hold register
      wordreg           = 0;                                                              // clear the data uint before starting read 
      for (i = 0; i < numofbits; i++)                                                     // loop until all bits are read
        {
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        fpgaserialclock = 1;                                                              // the data is written on the rising edge
        wordreg         = wordreg >> 1;                                                   // shift the next bit into position for the next bit write
        btmpH7          = fpgadataout;                                                    // write the bit of the data to the fpga data input pin
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        fpgaserialclock = 0;                                                              // toggle the fpga serial clock,
        }
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialclock   = 1;                                                              // burn a cycle to make sure that the data pin has settled
      fpgaserialload    = 1;                                                              // make sure the fpga ale is deactived before starting
      i = 16 - numofbits;                                                                 // find number of bits to adjust data passed back
      if(i != 0)  {                                                                       // if the data is a full 16 no adjustment is necessary
        while(i != 0)                                                                     // keep shifting until data placement is right for numofbits
          {  wordreg    = wordreg >> 1; i--;  }}                                          // shift the data over one bit, adjust count for one shift done
      return wordreg;                                                                     // return the data
}

//----------------------------------------------------------------------------------------
// Name          : printdHex2Bin(byte num)
// Purpose       : 
// Params        : 
// Returns       : 
// Note          : 
//----------------------------------------------------------------------------------------
void printdHex2Bin(byte num)
{
  if((num & 0x80) == 0) printd("0");  else printd("1");
  if((num & 0x40) == 0) printd("0");  else printd("1");
  if((num & 0x20) == 0) printd("0");  else printd("1");
  if((num & 0x10) == 0) printd("0");  else printd("1");
  if((num & 0x08) == 0) printd("0");  else printd("1");
  if((num & 0x04) == 0) printd("0");  else printd("1");
  if((num & 0x02) == 0) printd("0");  else printd("1");
  if((num & 0x01) == 0) printd("0 "); else printd("1 ");
}

//----------------------------------------------------------------------------------------
// Name          : 
// Purpose       : reformat host data to match device hardware
// Params        : 
// Returns       : void
// Note          : using serial sink drivers MIC-5841
//----------------------------------------------------------------------------------------
void createbitmap5124(byte *ptrs,byte *ptrb)
{
      btmpL  = *ptrs;    // BYTE 2                                                        // load a byte of host indicator data
      ptrs++;                                                                             // move the pointer to the previous byte of host data
   U03_0 = 0;
   U05_0 = 0;                                                        //
      S02_BR = POWERON;       // S02.6 seg-01 connector-J1.01 driver-U03_1 name-POWER.BR
      S02_TL = POWERON;       // S02.8 seg-02 connector-J1.02 driver-U03_2 name-POWER.TL
      S03_BR = SLAVEAMB;      // S03.6 seg-03 connector-J1.03 driver-U03_3 name-SLAVE.BR
      S03_TL = SLAVEAMB;      // S03.8 seg-04 connector-J1.04 driver-U03_4 name-SLAVE.TL
      S04_BR = LOADAMB;       // S04.6 seg-05 connector-J1.05 driver-U03_5 name-LOAD.BR
      S04_TL = LOADAMB;       // S04.8 seg-06 connector-J1.06 driver-U03_6 name-LOAD.TL
      S05_BR = MANUALAMB;     // S05.6 seg-07 connector-J1.07 driver-U03_7 name-MANUAL.BR
      S05_TL = MANUALAMB;     // S05.8 seg-08 connector-J1.08 driver-U03_8 name-MANUAL.TL
      S02_BL = POWERON;       // S02.5 seg-09 connector-J1.09 driver-U05_1 name-POWER.BL
      S02_TR = POWERON;       // S02.9 seg-10 connector-J1.10 driver-U05_2 name-POWER.TR
      S03_BL = SLAVEGRN;      // S03.5 seg-11 connector-J1.11 driver-U05_3 name-SLAVE.BL
      S03_TR = SLAVEGRN;      // S03.9 seg-12 connector-J1.12 driver-U05_4 name-SLAVE.TR
      S04_BL = LOADGRN;       // S04.5 seg-13 connector-J1.13 driver-U05_5 name-LOAD.BL
      S04_TR = LOADGRN;       // S04.9 seg-14 connector-J1.14 driver-U05_6 name-LOAD.TR
      S05_BL = MANUALGRN;     // S05.5 seg-15 connector-J1.15 driver-U05_7 name-MANUAL.BL
      S05_TR = MANUALGRN;     // S05.9 seg-16 connector-J1.16 driver-U05_8 name-MANUAL.TR
      *ptrb  = U03_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell
      *ptrb  = U05_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell

      btmpL  = *ptrs;    // BYTE 3                                                        // load a byte of host indicator data
      ptrs++;                                                                             // move the pointer to the previous byte of host data
   U07_0 = 0;                                                        //
   U09_0 = 0;                                                        //
      S06_BR = STOWAMB;       // S06.6 seg-17 connector-J1.17 driver-U07_1 name-STOW.BR
      S06_TL = STOWAMB;       // S06.8 seg-18 connector-J1.18 driver-U07_2 name-STOW.TL
      S10_BR = FAST;          // S10.6 seg-23 connector-J1.23 driver-U07_7 name-FAST.BR
      S10_TL = FAST;          // S10.8 seg-24 connector-J1.24 driver-U07_8 name-FAST.TL
      S06_BL = STOWGRN;       // S06.5 seg-25 connector-J1.25 driver-U09_1 name-STOW.BL
      S06_TR = STOWGRN;       // S06.9 seg-26 connector-J1.26 driver-U09_2 name-STOW.TR
      S10_BL = FAST;          // S10.5 seg-31 connector-J1.31 driver-U09_7 name-FAST.BL
      S10_TR = FAST;          // S10.9 seg-32 connector-J1.32 driver-U09_8 name-FAST.TR

      btmpL  = *ptrs;    // BYTE 4                                                        // load a byte of host indicator data
      ptrs++;                                                                             // move the pointer to the previous byte of host data
      S08_BR = UP;            // S08.6 seg-19 connector-J1.19 driver-U07_3 name-UP.BR
      S08_TL = UP;            // S08.8 seg-20 connector-J1.20 driver-U07_4 name-UP.TL
      S09_BR = LEFT;          // S09.6 seg-21 connector-J1.21 driver-U07_5 name-LEFT.BR
      S09_TL = LEFT;          // S09.8 seg-22 connector-J1.22 driver-U07_6 name-LEFT.TL
      S08_BL = UP;            // S08.5 seg-27 connector-J1.27 driver-U09_3 name-UP.BL
      S08_TR = UP;            // S08.9 seg-28 connector-J1.28 driver-U09_4 name-UP.TR
      S09_BL = LEFT;          // S09.5 seg-29 connector-J1.29 driver-U09_5 name-LEFT.BL
      S09_TR = LEFT;          // S09.9 seg-30 connector-J1.30 driver-U09_6 name-LEFT.TR
      *ptrb  = U07_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell
      *ptrb  = U09_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell

   U11_0 = 0;                                                        //
   U13_0 = 0;        
      S11_BR = RIGHT;         // S11.6 seg-33 connector-J2.01 driver-U11_1 name-RIGHT.BR
      S11_TL = RIGHT;         // S11.8 seg-34 connector-J2.02 driver-U11_2 name-RIGHT.TL
      S12_BR = DOWN;          // S12.6 seg-35 connector-J2.03 driver-U11_3 name-DOWN.BR
      S12_TL = DOWN;          // S12.8 seg-36 connector-J2.04 driver-U11_4 name-DOWN.TL
      S11_BL = RIGHT;         // S11.5 seg-41 connector-J2.09 driver-U13_1 name-RIGHT.BL
      S11_TR = RIGHT;         // S11.9 seg-42 connector-J2.10 driver-U13_2 name-RIGHT.TR
      S12_BL = DOWN;          // S12.5 seg-43 connector-J2.11 driver-U13_3 name-DOWN.BL
      S12_TR = DOWN;          // S12.9 seg-44 connector-J2.12 driver-U13_4 name-DOWN.TR

      btmpL  = *ptrs;    // BYTE 5                                                        // load a byte of host indicator data
      S14_BR = APDS;          // S14.6 seg-39 connector-J2.07 driver-U11_7 name-APDS.BR
      S14_TL = APDS;          // S14.8 seg-40 connector-J2.08 driver-U11_8 name-APDS.TL
      S14_BL = APDS;          // S14.5 seg-47 connector-J2.15 driver-U13_7 name-APDS.BL
      S14_TR = APDS;          // S14.9 seg-48 connector-J2.16 driver-U13_8 name-APDS.TR
      *ptrb  = U11_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell
      *ptrb  = U13_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell
   U04_0 = 0;                                                        //
   U06_0 = 0;                                                        //
      S15_BR = HEI;           // S15.6 seg-49 connector-J2.17 driver-U04_1 name-HEI.BR
      S15_TL = HEI;           // S15.8 seg-50 connector-J2.18 driver-U04_2 name-HEI.TL
      S16_BR = API;           // S16.6 seg-51 connector-J2.19 driver-U04_3 name-API.BR
      S16_TL = API;           // S16.8 seg-52 connector-J2.20 driver-U04_4 name-API.TL
      S17_BR = TP;            // S17.6 seg-53 connector-J2.21 driver-U04_5 name-TP.BR
      S17_TL = TP;            // S17.8 seg-54 connector-J2.22 driver-U04_6 name-TP.TL
      S15_BL = HEI;           // S15.5 seg-57 connector-J2.25 driver-U06_1 name-HEI.BL
      S15_TR = HEI;           // S15.9 seg-58 connector-J2.26 driver-U06_2 name-HEI.TR
      S16_BL = API;           // S16.5 seg-59 connector-J2.27 driver-U06_3 name-API.BL
      S16_TR = API;           // S16.9 seg-60 connector-J2.28 driver-U06_4 name-API.TR
      S17_BL = TP;            // S17.5 seg-61 connector-J2.29 driver-U06_5 name-TP.BL
      S17_TR = TP;            // S17.9 seg-62 connector-J2.30 driver-U06_6 name-TP.TR
      *ptrb  = U04_0;                                                                     // save the IC bit control data for ouput
      ptrb--;                                                                             // move the pointer to bitmapped data to the next cell
      *ptrb  = U06_0;                                                                     // save the IC bit control data for ouput
}

//----------------------------------------------------------------------------------------
// Name          : loaddriverMIC5841                                                      //
// Purpose       : Load data into MIC5841 serial sink drivers                             //
// Params        : Fpga Address for 5841 control pins                                     //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void loaddriverMIC5841(byte *ptrb, byte num)                                              // Serial sink driver load
{
      byte loop, cnt;


      Load5841 = 0;                                                                       //
      Clk5841  = 0;                                                                       // make sure the driver clock is deactivated
      Din5841  = 0;                                                                       //
      NOP(1);                                                                             // give the display time to see the data
      for(cnt  = 0; cnt < num; cnt++)                                                     // loop so all the bytes are output to the high current sink drivers
        {
        btmpL = *ptrb;                                                                    // get a byte of the bitmapped data
        ptrb++;                                                                             // move the pointer to bitmapped data to the next cell
        for (loop = 0; loop < 8; loop++)                                                  // loop until one drivers worth of bits is loaded
          {
          Din5841 = btmpL0;                                                               // write the bit of the data to the fpga data input pin
          Din5841 = btmpL0;                                                               // burn a cycle
          Clk5841 = 0;                                                                    // deactivate the fpga serial register clock
          Clk5841 = 0;                                                                    // burn a cycle
          Clk5841 = 0;                                                                    // deactivate the fpga serial register clock
          Clk5841 = 0;                                                                    // burn a cycle
          btmpL   = btmpL >> 1;                                                           // shift the next bit into position for the next bit write
          Clk5841 = 1;                                                                    // activate the fpga serial register clock
          Clk5841 = 1;                                                                    // activate the fpga serial register clock
          }
        }
      Load5841 = 1;                                                                       // activate display driver load
      Load5841 = 1;                                                                       // activate display driver load
      Load5841 = 1;                                                                       // activate display driver load
      Load5841 = 1;                                                                       // activate display driver load
      Load5841 = 0;                                                                       // deactivate display driver load      
      Clk5841  = 0;                                                                       // make sure the driver clock is deactivated
      Din5841  = 0;                                                                       //
}

//----------------------------------------------------------------------------------------
// name    : printFirmwareInformation                                                     //
// purpose : display the  firmware information in the debug window                        //
// params  : void                                                                         //
// returns : void                                                                         //
// note    :                                                                              //
//----------------------------------------------------------------------------------------
void  printFirmwareInformation()                                                          //
{
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
    printd("uC Firmware PN          : ");                                                 // output the firmware data for the master processor
    printd("%02bx-",   bufFirmwareData[ix02]);                                             //
    printd("%02bx",    bufFirmwareData[ix03]);                                             //
    printd("%02bx",    bufFirmwareData[ix04]);                                             //
    printd(" : %c\n\r",bufFirmwareData[ix05]);                                             //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
    printd("FPGA Firmware PN        : ");                                                 // output the firmware data for the slave 0 processor
    printd("%02bx-",   bufFirmwareData[ix06]);                                             //
    printd("%02bx",    bufFirmwareData[ix07]);                                             //
    printd("%02bx",    bufFirmwareData[ix08]);                                             //
    printd(" : %c\n\r",bufFirmwareData[ix09]);                                             //
}

//----------------------------------------------------------------------------------------
// name    : printDeviceConfigurationInformation                                          //
// purpose : show the user the device information in the debug window                     //
// params  : void                                                                         //
// returns : void                                                                         //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
void  printDeviceConfigurationInformation()                                               //
{
    printd("Debug Routines          : ");                                                 //
    if(fDebugMode == OFF)                                                                 // get the state of the debug bit
      printd("disabled\n\r");                                                             // alert the user to port status
    else                                                                                  //
      printd("enabled\n\r");                                                              // alert the user to port status
    printd("Transmit Mode           : ");                                                 // alert the user to port status
    if(fDebugMode == OFF)                                                                 // get the state of the debug bit
      {
      if(fTransmitMode == Server)                                                         // get the state of the client port bit
        printd("Server\n\r");                                                             // alert the user to port status
      else                                                                                //
        printd("Client\n\r");                                                             // alert the user to port status
      }
    else                                                                                  //
      printd("Server\n\r");                                                               // alert the user to port status
    gconfig_ExDisplayConfigData();                                                        //
    printd("*****************************************************\n\r");                  //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          display the firmware information for all programs in the debug window         //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
    printFirmwareInformation();                                                           //
    printd("*****************************************************\n\r");                  //
}

//----------------------------------------------------------------------------------------
// name    : processResetRsp                                                              //
// purpose : execute all steps required for a response                                    //
// params  : void                                                                         //
// returns : void                                                                         //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
void  processResetRsp(void)                                                               //
{
      int   i     = 0;
      byte  tmp   = 0;
      char  ch    = ' ';
//      GCONFIG_MAC_ADDR mac;
//      char  sPortNum[8];
//      char  sVersion[8];
      uint  port;
//      uint  version;

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initailize the message buffers                                                //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      port = GCONFIG_GetServerDataPktListenPort();                                        // get the port number used by the device
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initailize the message buffers device host communications                     //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      strncpy(&bufStatusData[ix01],statusdefault,sizeof(statusdefault));                  //
      strncpy(&bufIndicatorData[ix01],indicatordefault,sizeof(indicatordefault));         //
      strncpy(&bufDimmingData[ix01],dimmingdefault,sizeof(dimmingdefault));               //
      strncpy(&bufFirmwareData[ix01],firmwaredefault,sizeof(firmwaredefault));            //
      wordreg = fpgaReadData(adrsfirmware1,8);                                            // get the fpga firmware data MSB
//  printd("adrsfirmware1 = 0x%04dx \n\r",wordreg);
      bufFirmwareData[ix06] = btmpL;
      wordreg = fpgaReadData(adrsfirmware2,8);                                            // get the fpga firmware data 2nd MSB
//  printd("adrsfirmware2 = 0x%04dx \n\r",wordreg);
      bufFirmwareData[ix07] = btmpL;
      wordreg = fpgaReadData(adrsfirmware3,8);                                            // get the fpga firmware data 3rd MSB
//  printd("adrsfirmware3 = 0x%04dx \n\r",wordreg);
      bufFirmwareData[ix08] = btmpL;
      wordreg = fpgaReadData(adrsfirmware4,8);                                            // get the fpga firmware data LSB
//  printd("adrsfirmware4 = 0x%04dx \n\r",wordreg);
      bufFirmwareData[ix09] = btmpL;
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
//          reset the external hardware functions                                         //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
      LogicRst = 1;                                                                       // activate FPGA reset
      DELAY_Ms(5);                                                                        // wait for the FPGA to see the reset signal
      LogicRst = 0;                                                                       // activate FPGA reset
      DELAY_Ms(10);                                                                       // wait for the FPGA to see the reset signal
//      fpgaWriteData(adrsexternalenables,defaultexternal,5);                               // enable the pullup for the input banks
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initialize the action counters to zero                                        //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      acResetRequest         = 0;                                                         // clear the display change request flag
      HrtBeatCnt             = 0;                                                         // turn the heartbeat LED on
      acStatusRequest        = 0;                                                         // clear the status response action count
      acIndicatorRequest     = 1;                                                         // clear the status response action count
      acDimmingRequest       = 1;                                                         // clear the status response action count
      acFirmwareRequest      = 0;                                                         // clear the firmware response action count
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initialize the menu for debug port operations                                 //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      UTIL_MenuInit();                                                                    // process any messages entered in the debug window
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//                                                                                        //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      printd("Hardware init           : pass\n\r");                                       //
      HardwareSettings = 0;                                                               //
}

//----------------------------------------------------------------------------------------
// name    : processEthernetTraffic                                                       //
// purpose : check for new Ethernet traffic and process new data                          //
// params  : last software timer count, display link speed flag                           //
// returns : current timer count                                                          //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
ulong processEthernetTraffic(ulong ptc, dls)                                              //
{
    ulong tc;                                                                            // current time count
    byte  linkSpeed = 0;                                                                  //
    
    tc              = (uint)SWTIMER_Tick();                                               // get the current timer count
    if ((tc - ptc) >= TIME_OUT_COUNTER)                                                   // see if the difference in the curent & last time differs more then the timeout
      {
      ptc           = tc;                                                                 // set the last time to the current time
      TCPIP_PeriodicCheck();                                                              // check the for any TCPIP traffic
      }
    STOE_ProcessInterrupt();                                                              // process all TOE buffers input/output
    if (MAC_GetInterruptFlag())                                                           // get the data for this device
      { linkSpeed   = MAC_ProcessInterruptExt(); }                                        // find the linkage speed, and process device traffic
    if(dls == ON) printd("Ethernet Link Speed = bps\n\r", linkSpeed);                     // display the linkage speed
    return ptc;                                                                           // return the current timer count
}

//----------------------------------------------------------------------------------------
// name    : setupEthernet                                                                //
// purpose : initailize and start all of the Ethernet processes                           //
// params  : enabled                                                                      //
// returns : the last updated timer count                                                 //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
ulong setupEthernet(byte enabled)
{
    ulong ip;                                                                             //
    ulong mask;                                                                           //
    byte  cmdDhcpFlag      = 0;                                                           //
    ulong dhcpTimeStart    = 0;                                                           //
    ulong swtc;                                                                           //

    if(enabled == TRUE)                                                                   //
      {
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initialize network adapter                                                    //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      ETH_Init();                                                                         //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initailize the device configurationnitialization                              //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      GCONFIG_Init();                                                                     //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          iniailize the software timer                                                  //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      SWTIMER_Init();                                                                     //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          enable transmit socket for runtime mode                                       //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//      dport = GCONFIG_GetClientDestPort();                                                // get the host server port number
//      gudpdat_ClientOpen(TrxSocket, dport);                                               //
//      if ((fDebugMode == OFF) && fTransmitMode == Client)                                 //
        {   gudpdat_ClientOpen(TrxSocket);  }                                             //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          Start the Ethernet Engine and Software Timer for DMA                          //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      ETH_Start();                                                                        // start the ethernet process
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          Start the Ethernet Engine and Software Timer for DMA                          //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      SWTIMER_Start();                                                                    // start the software timer
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initailize the hardware DCB                                                   //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      mask    = GCONFIG_GetNetmask();                                                     //
      ip      = GCONFIG_GetServerStaticIP();                                              //
      TCPIP_SetIPAddr(ip);                                                                //
      STOE_SetIPAddr(ip);                                                                 //
      TCPIP_SetSubnetMask(mask);                                                          //
      STOE_SetSubnetMask(mask);                                                           //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          update device IP and port settings                                            //
      if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_DHCP_ENABLE) == GCONFIG_NETWORK_DHCP_ENABLE)
        {
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initialize network adapter                                                    //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
        printd("DHCP     init           : ");                                             //
        if (DHCP_Init())                                                                  //
          printd("pass\n\r");                                                             //
        else
          printd("**ERROR**\n\r");                                                        //
        printd("DHCP Assigned IP    : ");                                                 // tell user that the DHCP process has started
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//    start the DHCP engine                                                               //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
        DHCP_Start();                                                                     // start the DHCP process
        cmdDhcpFlag   = 1;                                                                // set the DHCP initailization flag to start
        dhcpTimeStart = SWTIMER_Tick();                                                   // record the DHCP process start time
        }
      else                                                                                //
        {
        ip            = 0;                                                                // update the IP settings to the static IP and port
        cmdDhcpFlag   = 0;                                                                // set the DHCP initailization flag to bypass
        }
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          start DHCP process loop                                                       //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      DELAY_Ms(1000);                                                                     // wait 1S to give the internal hardware time to start up
      while(cmdDhcpFlag == 1)                                                             // check the DHCP flag to see if the DHCP process has completed
        {
        printd("DHCP response -- ");                                                      //
        if (DHCP_GetState() > DHCP_IDLE_STATE)                                            // see if the DHCP process is in the beginning idle state
          { DHCP_Send(); }                                                                // send a DHCP request to the DHCP host
        else                                                                              // the DHCP process is not in IDLE, execute the next step
          { 
          ulong ip = STOE_GetIPAddr();                                                    // reteieve the DHCP host proposed IP
          if (ip == 0)                                                                    // make sure the proposed IP was not invalid
            printd(" fail!\n\r");                                                         // let the host know that the DHCP process failed
          cmdDhcpFlag = 0;                                                                // set the DHCP process flag to complete
          }//if (DHCP_GetState() > DHCP_IDLE_STATE)
        swtc = processEthernetTraffic(0, ON);                                             // check for new Ethernet traffic and process new data
        }//while(cmdDhcpFlag == 1)do
      UpdateIpSettings(ip);                                                               // update IP address, subnet mask, gateway IP address and DNS IP address
      printd("*****************************************************\n\r");                // 
      }
      return swtc;                                                                        // return the software timer count
}

//----------------------------------------------------------------------------------------
// Name          : main                                                                   //
// Purpose       : execute the main loop of the program as long as powered                //
// Params        : void                                                                   //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void main(void)
{
//      uint  tmp;                                                                          //
      uint  temp16 = 1;                                                                   //

      byte  sysInitFlag = 1;                                                              //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      byte  linkFlag = 0;                                                                 //
      byte  cmdDhcpFlag = 0;                                                              //
      ulong dhcpTimeStart = 0;                                                            //
//      ulong dhcpTimeStop = 0;                                                             //
//      byte  dhcpArpRequest = 0;                                                           //
//      byte  dhcpDeclineCount = 0;                                                         //
      ulong timeCount;                                                                    //
      ulong preTimeCount;                                                                 //
      byte  realtimeswblock;                                                              // create a variable for the realtime report blocking
//      byte  realtimeptblock;                                                              // create a variable for the realtime report blocking

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          Start Main Code                                                               //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      ExecuteRuntimeFlag     = 1;                                                         //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          system initiation                                                             //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      AX11000_Init();                                                                     // initailize the AX110xx setup registers
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          uart interface initiation                                                     //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      uart_Init(0,Baud___9600, FALSE);                                                    // setup port 0 for 8,1,1n, and baudrate
      uart_Init(1,Baud___9600, FALSE);                                                    // setup port 1 for 8,1,1n, and 9600bps
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          uart interface initiation                                                     //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      printd("Instrument Part Number  : %s\n\r",SIMTEK_Inst_Number);                      //
      printd("Firmware Last Revised   : %s %s\n\r",__DATE__,__TIME__);                    // c:\tftpd64
      printd("Ethernet Library Ver.   : %s\n\r", GCONFIG_VERSION_STRING);                 //
      printd("*********************************************************\n\r");            //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          uart interface initiation                                                     //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      printd("UART-0   init           : pass   ");                                        //
      printd("baud : %02bx \n\r",Baud___9600);                                            // show the user the baudrate
      printd("UART-1   init           : pass\n\r");                                       //
      printd("*****************************************************\n\r");                // print this in the debug widow to ease readability for user
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initailize the device configuration                                           //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      preTimeCount = setupEthernet(TRUE);                                                 // initailize and start all of the Ethernet processes
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          initialize harware                                                            //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      LogicRst                = 1;                                                        // activate FPGA reset
      DELAY_Ms(5);                                                                        // wait for the FPGA to see the reset signal
      LogicRst                = 0;                                                        // activate FPGA reset
      acResetRequest          = 1;                                                        //
      processResetRsp();                                                                  // reset all functions to the powerup state
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          display device configuration information                                      //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
      printDeviceConfigurationInformation();                                              // print the device configuration information in the debug window
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          start main loop                                                               //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//      

      while (1)                                                                           // loop until power is removed
        {
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          begin action request processing for debug commands                            //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
        UTIL_MenuExecute();                                                               // get and process any data the user entered in the debug window
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          check for the processing count and process any dimming data changes           //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
        if(fDebugMode == OFF)                                                             // check for the test/debug state
          {
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          look for changes in the switch data, and process realtime messages            //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
          processSwitchBank2(realtimeswblock);                                          // read and process switch bank 1
          processSwitchBank3(realtimeswblock);                                          // read and process switch bank 2
          processSwitchBank4(realtimeswblock);                                          // read and process switch bank 2
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          transfer all received into the processing buffer                              //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//

          ADCount--;                                                                      //
          if (ADCount == 0)                                                               // process every
            {
            ScopePin = 1;                                                                 // toggle the pin for oscilloscope triggering
            ScopePin = 0;                                                                 // toggle the pin for oscilloscope triggering
            ADCount = a2ddelay;                                                           //
            }
          }

        timeCount = (uint)SWTIMER_Tick();                                                 //
        if ((timeCount- preTimeCount)>= TIME_OUT_COUNTER)                                 //
          {
          preTimeCount = timeCount;                                                       //
          TCPIP_PeriodicCheck();                                                          //
          }
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          polling mode                                                                  //
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
        STOE_ProcessInterrupt();                                                          //
        if (MAC_GetInterruptFlag())                                                       //
          {
          linkFlag = MAC_ProcessInterruptExt();                                           //
          }
        GS2E_Task();                                                                      //
        }
} // End of main() //