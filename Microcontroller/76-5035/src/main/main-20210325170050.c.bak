//----------------------------------------------------------------------------------------//
// Name          : NOP                                                                    //
// Purpose       : create a small runtime delay                                           //
// Params        : the number of times to loop                                            //
// Returns       : void                                                                   //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------//
void NOP(uint loop)                                                                       //
{
      uint i;                                                                             //

      for (i = 0; i < loop; i++)                                                          //
       {    _nop_();    }                                                                 //
}

// Name          : wrChrEthTxBuffer(byte ch, uint Count)                                  //
// Purpose       : write data to the ring buffer to transmit over Ethernet                //
// Params        : Data byte to write, Count of bytes currently in buffer                 //
// Returns       : updated count of bytes in buffer                                       //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
uint wrChrEthTxBuffer(byte ch, uint Count)                                                // write data to the ethernet transmit buffer
{
      EthTxBuffer[EthTxBufIndx] = ch;                                                     // add the data to the ethernet buffer
      EthTxBufIndx++;                                                                     // update the ethernet buffer index
      Count++;                                                                            // update the count showing the number of bytes in the buffer
      if (EthTxBufIndx == EthMaxTxSize)                                                   // check to see if the index is at the maximum
        EthTxBufIndx = 0;                                                                 // reset the index to the first byte of the buffer
      return Count;                                                                       // pass the buffer count back to the calling routine
}

//----------------------------------------------------------------------------------------
// Name          : wrStrEthTxBuffer(byte* pData, uint cnt)                                //
// Purpose       : write data to the ring buffer to transmit over Ethernet                //
// Params        : pointer to the data bytes to write, number of bytes to write           //
// Returns       : number of bytes sucessfully written into the buffer                    //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
uint wrStrEthTxBuffer(byte* pData, uint cnt)                                              // write data to the ethernet transmit buffer
{
      uint TmpCnt;                                                                        //
      uint offset;                                                                        //

      if((EthTxBufIndx + cnt) > EthMaxTxSize)                                             // make sure that the number of bytes to write added to the number
      {                                                                                   //  of bytes in the buffer already is not greater then the buffer
        offset = EthMaxTxSize - EthTxBufIndx;                                             // find the number of bytes that will fit in the buffer before overflow
        memmove(&EthTxBuffer[EthTxBufIndx], pData, offset);                               // fill the remainder of the buffer with the given data
        memmove(&EthTxBuffer[ix01], pData+offset, cnt - offset);                          // add the remainder of the given data to the begining of the buffer
        }
      else                                                                                // else all of the given data will still fit in the buffer
        {
        memmove(&EthTxBuffer[EthTxBufIndx], pData, cnt);                                  // place all of the given data into the buffer
        }
      EthTxBufIndx += cnt;                                                                // make sure that the index points at the first empty byte
      EthTxBufIndx &= EthMaxTxMask;                                                       // mask the index to wrap the buffer around into a ring
      TmpCnt = readEthTxBufCount() + cnt;                                                 // adjust the current buffer count
      return TmpCnt;                                                                      // return the number of bytes in the buffer
}

//----------------------------------------------------------------------------------------
// Name          : WriteEthTxCount(uint TempCount)                                        //
// Purpose       : update the count checked by Ethernet process                           //
// Params        : updated count                                                          //
// Returns       : void                                                                   //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------
void writeEthTxCount(uint TempCount)                                                      // update the global ethernet transmit buffer count
{
      EthTxCount = TempCount;                                                             // write the new count to the global buffer
}

//----------------------------------------------------------------------------------------
// name          : main_readEthChar(byte* pDat)                                            //
// Purpose       : retrieve data from buffer to place in ethernet transmit buffer         //
// Params        : pointer to variable to return                                          //
// Returns       : count of data left in buffer                                           //
// note    : this routine replaced GetEthChar defined in main.c.                          //
//----------------------------------------------------------------------------------------
uint main_readEthChar(byte* pDat)                                                         // read a data byte from the ethernet buffer
{
      uint temp;                                                                         //
      
      temp = readEthTxBufCount();                                                          // get the current ethernet buffer count
      if (temp > 0)                                                                       // see if there are any bytes in the buffer
        {
        *pDat = EthTxBuffer[EthTxBufTail];                                                   // write the data to the location pointed to by the pointer
        EthTxBufTail++;                                                                      // update the ethernet ring buffer index
        if (EthTxBufTail == EthMaxTxSize)                                                    // check the index to make sure that the index remains within the buffer space 
          {  EthTxBufTail = 0;  }                                                            // reset the index to the first byte of the buffer
        EthTxCount--;                                                                     // update the count of the bytes in the buffer
        return EthTxCount;                                                                // pass the altered count back to the calling routine
        }
      return 0;                                                                           // write the default value for the count
}

//----------------------------------------------------------------------------------------
// Name          : readEthTxBufCount(void)                                                //
// Purpose       : read the current number of bytes in the Ethernet ring buffer           //
// Params        : void                                                                   //
// Returns       : current number of bytes in the Ethernet ring buffer                    //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
uint readEthTxBufCount(void)                                                               // retrieve the current number of bytes in the ethernet transmit buffer
{
      return EthTxCount;                                                                  // pass the ethernet transmit buffer to the calling routine
}

//----------------------------------------------------------------------------------------
// Name          : processSwitchBank2                                                     //
// Purpose       : read the switch bank and look for changes, record any actions found    //
// Params        : byte reportblock                                                       //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void processSwitchBank2(byte reportblock)                                                 //
{
      byte tmp, swadr, dat;                                                               // create variables for local use
// s06 - stow      input_bank01<6>  : inout std_logic; -- 76 -- J3.14             -- GIO18    -- GENERAL PURPOSE I/O
// s05 - manual    input_bank01<5>  : inout std_logic; -- 72 -- J3.12             -- GIO22    -- GENERAL PURPOSE I/O
// s04 - load      input_bank01<4>  : inout std_logic; -- 70 -- J3.10             -- GIO24    -- GENERAL PURPOSE I/O
// s03 - slave     input_bank01<3>  : inout std_logic; -- 65 -- J3.8              -- GIO26    -- GENERAL PURPOSE I/O
// s02 - power     input_bank01<2>  : inout std_logic; -- 64 -- J3.6              -- GIO27    -- GENERAL PURPOSE I/O
// s01 - error     input_bank01<1>  : inout std_logic; -- 63 -- J3.4              -- GIO28    -- GENERAL PURPOSE I/O
// s01 - rx        input_bank01<0>  : inout std_logic; -- 62 -- J3.2              -- GIO29    -- GENERAL PURPOSE I/O
      wordreg   = fpgaReadData(adrsswitchbank1,7);                                        // get the fpga swich bank one register data
      dat       = (btmpL) & 0x7F;                                                         // read the switch data and mask off unused bits

      if (bufStatusData[ix02] != dat)                                                 // if current state does not match old state there are changes to process
        {
        if(SwBank02Cnt == 0)                                                              // se if the debounce change time out has expired
          {
          if(reportblock == OFF)                                                          // see if this change should be logged
            {
            tmp = bufStatusData[ix02] ^ dat;                                          // find any differences between the last reading and the current reading
            if((tmp & 0x7F) != 0)                                                         // check for any changes in the switch bank,
              {
              if((tmp & 0x03) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x03))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x01 : swadr = acodeS1_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x02 : swadr = acodeS1_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x04) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x04))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x04 : swadr = acodeS2_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS2_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x08) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x08))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x08 : swadr = acodeS3_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS3_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x10) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x10))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x10 : swadr = acodeS4_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS4_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x20) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x20))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x20 : swadr = acodeS5_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS5_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x40) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x40))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x40 : swadr = acodeS6_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS6_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              }
            }
          bufStatusData[ix02] = dat;                                                  // save the current switch state for the next switch check
          SwBank02Cnt = SwBank02Delay;                                                    // reset the debounce delay counter
          }
        else
          {  SwBank02Cnt--;  }                                                               // decrement debounce delay counter
        }
      else
        {  SwBank02Cnt = SwBank02Delay;  }                                                 // reset the debounce delay counter
}

//----------------------------------------------------------------------------------------
// Name          : processSwitchBank3                                                     //
// Purpose       : read the switch bank and look for changes, record any actions found    //
// Params        : byte reportblock                                                       //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void processSwitchBank3(byte reportblock)                                                 //
{
      byte tmp, swadr, dat;                                                               // create variables for local use
// s12 - down      input_bank02<6>  : inout std_logic; -- 11 -- J15.7  & U9.7(o)  -- GIO14    -- GENERAL PURPOSE I/O & U9.7(o) CAN BUS ~TX0RTS
// s11 - right     input_bank02<5>  : inout std_logic; -- 08 -- J15.9  & U9.25(o) -- GIO16    -- GENERAL PURPOSE I/O & U9.9(o) CAN BUS ~TX2RTS
// s10 - fast      input_bank02<4>  : inout std_logic; -- 77 -- J3.15             -- GIO19    -- GENERAL PURPOSE I/O
// s09 - left      input_bank02<3>  : inout std_logic; -- 73 -- J3.13             -- GIO21    -- GENERAL PURPOSE I/O
// sxx - 0         input_bank02<2>  : inout std_logic; -- 71 -- J3.11  & Q14.2    -- GIO23 X  -- GENERAL PURPOSE I/O & CONTROL A2D CH0 SOURCE VOLTAGE
// s07 - safe      input_bank02<1>  : inout std_logic; -- 69 -- J3.9   & Q15.2    -- GIO25 X  -- GENERAL PURPOSE I/O & CONTROL A2D CH1 SOURCE VOLTAGE
// s07 - arm       input_bank02<0>  : inout std_logic; -- 78 -- J3.16             -- GIO20    -- GENERAL PURPOSE I/O
      wordreg   =  fpgaReadData(adrsswitchbank2,7);                                       // get the fpga swich bank one register data
      btmpH     =  btmpL;                                                                 //
      btmpL0    = ~btmpH0;                                                                // 
      btmpL1    =  btmpH0;                                                                // 
      tmp       =  btmpL;
      wordreg   =  fpgaReadData(adrsswitchbank3,7);                                       // get the fpga swich bank one register data
      btmpH     =  btmpL;                                                                 //
      btmpL     =  tmp;
      btmpL2    =  btmpH5;                                                                // 
      dat       =  (btmpL) & 0x7F;                                                        // read the switch data and mask off unused bits

      if (bufStatusData[ix03] != dat)                                                 // if current state does not match old state there are changes to process
        {
        if(SwBank03Cnt == 0)                                                              // se if the debounce change time out has expired
          {
//      printd("sw3=%02bx,%02bx\n\r",btmpL, dat);
          if(reportblock == OFF)                                                          // see if this change should be logged
            {
            tmp = bufStatusData[ix03] ^ dat;                                          // find any differences between the last reading and the current reading
            if((tmp & 0x7F) != 0)                                                         // check for any changes in the switch bank,
              {
              if((tmp & 0x03) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x01))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x01 : swadr = acodeS7_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS7_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x04) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x04))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x04 : swadr = acodeS8_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS8_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x08) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x08))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x08 : swadr = acodeS9_Position1; break;                           // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS9_Position2; break;                           // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x10) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x10))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x10 : swadr = acodeS10_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS10_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x20) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x20))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x20 : swadr = acodeS11_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS11_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x40) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x40))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x40 : swadr = acodeS12_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS12_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              }
            }
          bufStatusData[ix03] = dat;                                                  // save the current switch state for the next switch check
          SwBank03Cnt = SwBank03Delay;                                                    // reset the debounce delay counter
          }
        else
          {  SwBank03Cnt--;  }                                                               // decrement debounce delay counter
        }
      else
        {  SwBank03Cnt = SwBank03Delay;  }                                                   // reset the debounce delay counter
}

//----------------------------------------------------------------------------------------
// Name          : processSwitchBank4                                                     //
// Purpose       : read the switch bank and look for changes, record any actions found    //
// Params        : byte reportblock                                                       //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void processSwitchBank4(byte reportblock)                                                 //
{
      byte tmp, swadr, dat;                                                               // create variables for local use
// sxx - 0         input_bank03<6>  : inout std_logic; -- 05 -- J13.8  & U9.21(i) -- GIO03    -- GENERAL PURPOSE I/O & U9.21(o) Osc1
// s08 - up arrow  input_bank03<5>  : inout std_logic; -- 16 -- J15.4             -- GIO11    -- GENERAL PURPOSE I/O
// s17 - tp        input_bank03<4>  : inout std_logic; -- 13 -- J15.6  & U9.6(o)  -- GIO13    -- GENERAL PURPOSE I/O & U9.6(o) CAN BUS ~RESET
// s16 - ap1       input_bank03<3>  : inout std_logic; -- 10 -- J15.8  & U9.9(o)  -- GIO15    -- GENERAL PURPOSE I/O & U9.8(o) CAN BUS ~TX1RTS
// s15 - hei       input_bank03<2>  :   out std_logic; -- 07 -- J15.10 & U9.15(i) -- GIO17    -- GENERAL PURPOSE I/O & U9.15(o) CAN BUS STBY 1 = off
// s14 - apds      input_bank03<1>  : inout std_logic; -- 19 -- J15.3             -- GIO10    -- GENERAL PURPOSE I/O
// s13 - lamp test input_bank03<0>  : inout std_logic; -- 15 -- J15.5             -- GIO12    -- GENERAL PURPOSE I/O
      wordreg   = fpgaReadData(adrsswitchbank3,7);                                        // get the fpga swich bank one register data
      dat       = (btmpL) & 0x7F;                                                         // read the switch data and mask off unused bits

      if (bufStatusData[ix04] != dat)                                                 // if current state does not match old state there are changes to process
        {
        if(SwBank04Cnt == 0)                                                              // se if the debounce change time out has expired
          {
//      printd("sw4=%02bx,%02bx\n\r",btmpL, dat);
          if(reportblock == OFF)                                                          // see if this change should be logged
            {
            tmp = bufStatusData[ix04] ^ dat;                                          // find any differences between the last reading and the current reading
            if((tmp & 0x7F) != 0)                                                         // check for any changes in the switch bank,
              {
              if((tmp & 0x01) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x01))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x01 : swadr = acodeS13_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS13_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x02) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x02))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x02 : swadr = acodeS14_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS14_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x04) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x04))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x04 : swadr = acodeS15_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS15_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x08) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x08))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x08 : swadr = acodeS16_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS16_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              if((tmp & 0x10) != 0)                                                       // check for any changes in switch S1
                {
                switch((dat & 0x10))                                                      // mask off the other switches data and find the switch position
                  {
                  case 0x10 : swadr = acodeS17_Position1; break;                          // load the switch action code buffer with the switch position action code
                  case 0x00 : swadr = acodeS17_Position2; break;                          // load the switch action code buffer with the switch position action code
                  default   : swadr = acodeSS_NullPosition; break;                        // default to the 1st position
                  }
                //wrRealtimeSwitchReport(swadr);                                            // place a realtime switch report in the transmit buffer
                }
              }
            }
          bufStatusData[ix04] = dat;                                                  // save the current switch state for the next switch check
          SwBank04Cnt = SwBank04Delay;                                                    // reset the debounce delay counter
          }
        else
          {  SwBank04Cnt--;  }                                                               // decrement debounce delay counter
        }
      else
        {  SwBank04Cnt = SwBank04Delay;  }                                                   // reset the debounce delay counter
}

//----------------------------------------------------------------------------------------
// Name          : UpdateIpSettings                                                       //
// Purpose       : Update IP address, subnet mak, gateway IP address and DNS IP address   //
// Params        : IP to use for update                                                   //
// Returns       : void                                                                   //
// Note          :                                                                        //
//----------------------------------------------------------------------------------------
void UpdateIpSettings(ulong ip)                                                           // Update IP address, subnet mask, gateway IP address and DNS IP address
{
      if (ip > 0)                                                                         // check the IP to see if it is valid
        {
        printd("IP  : %bu.%bu.%bu.%bu\n\r", (byte) ((ip >> 24) & 0x000000FF),             // write the IP address to the user debug port
                                            (byte) ((ip >> 16) & 0x000000FF),             //
                                            (byte) ((ip >> 8)  & 0x000000FF),             //
                                            (byte) ( ip        & 0x000000FF));            //
        }
      else                                                                                // the IP was valid
        if (ip == 0)                                                                      // check the IP to see if it is valid
          {
          ulong mask = GCONFIG_GetNetmask();                                              // retrieve the default net mask
//          ulong gateway = GCONFIG_GetGateway();                                         // retrieve the default gateway address
          ip = GCONFIG_GetServerStaticIP();                                               // retrieve the static IP
          TCPIP_SetIPAddr(ip);                                                            // write the default IP addess into the DCB
          STOE_SetIPAddr(ip);                                                             // write the default IP addess into the DCB
          TCPIP_SetSubnetMask(mask);                                                      // write the default net mask into the DCB
          STOE_SetSubnetMask(mask);                                                       // write the default net mask into the DCB
//          TCPIP_SetGateway(gateway);                                                      // write the gateway address to the DCB
//          STOE_SetGateway(gateway);                                                       //
          }
//      GCONFIG_SetServerDynamicIP(ip);                                                     // write the server IP address to the DCB
      GS2E_Init();                                                                        //
} // End of UpdateIpSettings //

