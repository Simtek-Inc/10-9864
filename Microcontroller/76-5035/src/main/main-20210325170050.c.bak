    sbit          S05_TL = U03_0^0;       // S05.8 seg-08 connector-J1.08 driver-U03_8 name-MANUAL.TL
static byte bdata U05_0 _at_ 0x23;                                                        //
    sbit          S02_BL = U05_0^7;       // S02.5 seg-09 connector-J1.09 driver-U05_1 name-POWER.BL
    sbit          S02_TR = U05_0^6;       // S02.9 seg-10 connector-J1.10 driver-U05_2 name-POWER.TR
    sbit          S03_BL = U05_0^5;       // S03.5 seg-11 connector-J1.11 driver-U05_3 name-SLAVE.BL
