static byte bdata U08 _at_ 0x22;                                                          //
    sbit          J3_01 = U04^7;                                                          // seg-65 connector-J3.01 driver-U08_1
    sbit          J3_02 = U04^6;                                                          // seg-66 connector-J3.02 driver-U08_2
    sbit          J3_03 = U04^5;                                                          // seg-67 connector-J3.03 driver-U08_3
    sbit          J3_04 = U04^4;                                                          // seg-68 connector-J3.04 driver-U08_4
    sbit          J3_05 = U04^3;                                                          // seg-69 connector-J3.05 driver-U08_5
    sbit          J3_06 = U04^2;                                                          // seg-70 connector-J3.06 driver-U08_6
    sbit          J3_07 = U04^1;                                                          // seg-71 connector-J3.07 driver-U08_7
    sbit          J3_08 = U04^0;                                                          // seg-72 connector-J3.08 driver-U08_8
static byte bdata U10 _at_ 0x23;                                                          //
    sbit          J3_09 = U06^7;                                                          // seg-73 connector-J3.09 driver-U10_1
    sbit          J3_10 = U06^6;                                                          // seg-74 connector-J3.10 driver-U10_2
    sbit          J3_11 = U06^5;                                                          // seg-75 connector-J3.11 driver-U10_3
    sbit          J3_12 = U06^4;                                                          // seg-76 connector-J3.12 driver-U10_4
    sbit          J3_13 = U06^3;                                                          // seg-77 connector-J3.13 driver-U10_5
    sbit          J3_14 = U06^2;                                                          // seg-78 connector-J3.14 driver-U10_6
    sbit          J3_15 = U06^1;                                                          // seg-79 connector-J3.15 driver-U10_7
    sbit          J3_16 = U06^0;                                                          // seg-80 connector-J3.16 driver-U10_8
static byte bdata U12 _at_ 0x22;                                                          //
    sbit          J3_17 = U04^7;                                                          // seg-81 connector-J3.17 driver-U12_1
    sbit          J3_18 = U04^6;                                                          // seg-82 connector-J3.18 driver-U12_2
    sbit          J3_19 = U04^5;                                                          // seg-83 connector-J3.19 driver-U12_3
    sbit          J3_20 = U04^4;                                                          // seg-84 connector-J3.20 driver-U12_4
    sbit          J3_21 = U04^3;                                                          // seg-85 connector-J3.21 driver-U12_5
    sbit          J3_22 = U04^2;                                                          // seg-86 connector-J3.22 driver-U12_6
    sbit          J3_23 = U04^1;                                                          // seg-87 connector-J3.23 driver-U12_7
    sbit          J3_24 = U04^0;                                                          // seg-88 connector-J3.24 driver-U12_8
static byte bdata U14 _at_ 0x23;                                                          //
    sbit          J3_25 = U06^7;                                                          // seg-89 connector-J3.25 driver-U14_1
    sbit          J3_26 = U06^6;                                                          // seg-90 connector-J3.26 driver-U14_2
    sbit          J3_27 = U06^5;                                                          // seg-91 connector-J3.27 driver-U14_3
    sbit          J3_28 = U06^4;                                                          // seg-92 connector-J3.28 driver-U14_4
    sbit          J3_29 = U06^3;                                                          // seg-93 connector-J3.29 driver-U14_5
    sbit          J3_30 = U06^2;                                                          // seg-94 connector-J3.30 driver-U14_6
    sbit          J3_31 = U06^1;                                                          // seg-95 connector-J3.31 driver-U14_7
    sbit          J3_32 = U06^0;                                                          // seg-96 connector-J3.32 driver-U14_8
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
//          action counters                                                               //
//========================================================================================//
