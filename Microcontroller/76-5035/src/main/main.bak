//== ---------------------------------------------------------------------------------- ==//
//== -                       local subprogram definitions                             - ==//
//== ---------------------------------------------------------------------------------- ==//
// name    : NOP                                                                          //
// purpose : create a small runtime delay                                                 //
// params  : the number of times to loop                                                  //
// returns : void                                                                         //
// notes   :                                                                              //
//----------------------------------------------------------------------------------------//
void NOP(uint loop)                                                                       //
{
      uint i;                                                                             //

      for (i = 0; i < loop; i++)                                                          //
       {    _nop_();    }                                                                 //
}

