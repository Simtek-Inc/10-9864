 118          // ---------------------------------------------------------------------------------------
 119          // Function Name : nibbleswap      
 120          // Purpose       : swap the high and low nibbles of the given byte
 121          // Params        : byte to swapped
 122          // Returns       : swapped byte     
 123          // Note          : 
 124          // ---------------------------------------------------------------------------------------
 125          byte nibbleswap(byte dat)
 126          {
 127   1            AssyVarPass1 = dat;
 128   1      #pragma asm
 129   1            push  Acc
 130   1            mov   Acc,tmpvar1
 131   1            swap  a
 132   1            mov   tmpvar1,Acc
 133   1            pop   Acc
 134   1      #pragma endasm
 135   1            return AssyVarPass1;
 136   1      }
