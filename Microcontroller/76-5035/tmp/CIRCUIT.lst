  54          // ----------------------------------------------------------------------------
  55          // name    : x001uSDelay(void)
  56          // Purpose       : create a 1uS delay
  57          // Params        : void
  58          // Returns       : void
  59          // notes   : 
  60          // ----------------------------------------------------------------------------
  61          void x001uSDelay(void)
  62          {
  63   1            x100nSDelay();                                                                      // 100nS 100nS
  64   1            x100nSDelay();                                                                      // 100nS 200nS
  65   1            x100nSDelay();                                                                      // 100nS 300nS
  66   1            x100nSDelay();                                                                      // 100nS 400nS
  67   1            x100nSDelay();                                                                      // 100nS 500nS
  68   1            x100nSDelay();                                                                      // 100nS 600nS
  69   1            x100nSDelay();                                                                      // 100nS 700nS
  70   1            x100nSDelay();                                                                      // 100nS 800nS
  71   1            x100nSDelay();                                                                      // 100nS 900nS
  72   1            _nop_();                                                                            //  20nS 920nS
  73   1      }
  74          
