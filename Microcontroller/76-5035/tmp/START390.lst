                        104     ;------------------------------------------------------------------------------
                        105     ;  START390.A51:  This code is executed after processor reset.
                        106     ;  You may add this file to a uVision2 project.
                        107     ;
                        108     ;  To translate this file use A51 with the following invocation:
                        109     ;
                        110     ;     AX51 START390.A51 MOD_CONT
                        111     ;
                        112     ;  To link the modified STARTUP.OBJ file to your application use the following
                        113     ;  LX51 invocation:
                        114     ;
                        115     ;     LX51 <your object file list>, START390.OBJ <controls>
                        116     ;
                        117     ;------------------------------------------------------------------------------
                        118     ;
                        119     ;------------------------------------------------------------------------------
                        120     ;
AX51 MACRO ASSEMBLER  START390                                                              03/10/26 15:30:55 PAGE     3

                        121     ;  Code Block Size
                        122     ;
                        123     ;  This Block Size must be set before system initialization.
                        124     ;  Hardware will check this value for memory shadow function first.
                        125     ;  It could be obtained after compilied whole source code.
                        126     ;  
 008C                   127     CODEBLOCK       EQU     8CH     ; the block size of code space.
                        128     ;
                        129     ;  Notes:  Each Block has 32KBytes memory space, and must not be set to '00H'.
                        130     ;          It must be placed at address 0x3FFF of code space.
                        131     ;------------------------------------------------------------------------------
                        132     ;
                        133     ;  User-defined Power-On Initialization of Memory
                        134     ;
                        135     ;  With the following EQU statements the initialization of memory
                        136     ;  at processor reset can be defined:
                        137     ;
                        138     ;               ; the absolute start-address of IDATA memory is always 0
 0080                   139     IDATALEN        EQU     80H     ; the length of IDATA memory in bytes.
                        140     ;
 0000                   141     XDATASTART      EQU     0H      ; the absolute start-address of XDATA memory
 8000                   142     XDATALEN        EQU     8000H   ; the length of XDATA memory in bytes.
                        143     ;
 0000                   144     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
 0000                   145     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                        146     ;
                        147     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                        148     ;          8051 CPU. At minimum the memory space occupied from the C51 
                        149     ;          run-time routines must be set to zero.
                        150     ;------------------------------------------------------------------------------
                        151     ;
                        152     ;  Reentrant Stack Initilization
                        153     ;
                        154     ;  The following EQU statements define the stack pointer for reentrant
                        155     ;  functions and initialized it:
                        156     ;
                        157     ;  Stack Space for reentrant functions in the SMALL model.
 0000                   158     IBPSTACK        EQU     0       ; set to 1 if small reentrant is used.
 00F1                   159     IBPSTACKTOP     EQU     0F0H+1  ; set top of stack to highest location+1.
                        160     ;
                        161     ;  Stack Space for reentrant functions in the LARGE model.      
 0001                   162     XBPSTACK        EQU     1       ; set to 1 if large reentrant is used.
                        163     
 66D8                   164     XBPSTACKTOP     EQU     (32727-(256*(8+16+1)))+1
                        165                                     ; set top of stack to highest location+1 below STOE buff
                               er.
                                
                                
                                
                        169     ;
                        170     ;  Stack Space for reentrant functions in the COMPACT model.    
 0000                   171     PBPSTACK        EQU     0       ; set to 1 if compact reentrant is used.
 F500                   172     PBPSTACKTOP     EQU     0F4FFH+1; set top of stack to highest location+1.
                        173     ;
                        174     ;------------------------------------------------------------------------------
                        175     ;
                        176     ;  Page Definition for Using the Compact Model with 64 KByte xdata RAM
                        177     ;
                        178     ;  The following EQU statements define the xdata page used for pdata
                        179     ;  variables. The EQU PPAGE must conform with the PPAGE control used
                        180     ;  in the linker invocation.
                        181     ;
 0000                   182     PPAGEENABLE     EQU     0       ; set to 1 if pdata object are used.
 00F4                   183     PPAGE           EQU     0F4H    ; define PPAGE number. 
                        184     ;
                        185     ;------------------------------------------------------------------------------
