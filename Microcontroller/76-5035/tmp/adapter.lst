  91      =1  }tag;
  92      =1  
  93      =1  // PPP handshake //
  94      =1  typedef struct _ppp_handshake_session {
  95      =1          uint    protocol;
  96      =1          byte    ppp_code;
  97      =1          byte    ppp_id;
C51 COMPILER V8.06   ADAPTER                                                               03/10/2026 15:31:00 PAGE 32  

  98      =1          uint    length;
  99      =1          byte    option[PPPOE_MAX_DATA-10];
