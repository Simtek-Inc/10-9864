  99          // Note:
 100          // ----------------------------------------------------------------------------
 101           //
 102          void eth_RcvHandle(byte XDATA* pbuf, uint length, byte protocol)
 103          {
 104   1              // copy packet into uIP buffer //
 105   1              DMA_GrantXdata(TCPIP_GetRcvBuffer(), pbuf, length);
 106   1      
 107   1              TCPIP_SetRcvLength(length);
 108   1      
 109   1              switch (protocol)
 110   1              {
 111   2              default:
 112   2                      break;
 113   2              case 1:
 114   2              case 2:
 115   2              case 6:
 116   2              case 17:
 117   2                      if (ETH_DoDhcp == 0)
 118   2                              uip_arp_ipin();
 119   2                      TCPIP_Receive();
 120   2                      if(TCPIP_GetXmitLength() > 0)
 121   2                      {
 122   3                              //if (!ETH_IsPppoe)
 123   3                                      uip_arp_out();
 124   3                              ETH_Send(0);
 125   3                      }
 126   2                      break;
 127   2              case 0xff:
 128   2                              if(pbuf[12] == 0x08 && pbuf[13] == 0x06)
 129   2                              {
 130   3                                      uip_arp_arpin();
 131   3                                      if ((pbuf[21] == 0x02) && ((*(ulong *)&pbuf[28]) == STOE_GetIPAddr()))
 132   3                                      {
 133   4                                              if (ETH_CheckDhcpArpReply() == FALSE)
 134   4                                                      ETH_SetDhcpArpReplyFlag(TRUE);
 135   4                                      }
 136   3                                      else
 137   3                                      {
 138   4                                  if(TCPIP_GetXmitLength() > 0)
C51 COMPILER V8.06   ADAPTER                                                               03/10/2026 15:31:00 PAGE 42  

 139   4                                                      ETH_Send(0);
 140   4      
 141   4                                              if (TCPIP_GetGwMacAddrFlag())
 142   4                                                      eth_ArpSendIntervalTime = ETH_ARP_SEND_INTERVAL_TIME;
 143   4                                      }
 144   3                              }
 145   2      
 146   2                      break;
 147   2              }  // End of switch //
 148   1      
 149   1      } // End of eth_RcvHandle //
