 162   1              uint    length = TCPIP_GetXmitLength();
 163   1      
 164   1              eth_PayLoadOffset = payloadOffset;
 165   1              ETH_SendPkt(TCPIP_GetXmitBuffer(), length);
 166   1      } // End of ETH_Send() //
