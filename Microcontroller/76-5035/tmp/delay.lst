  38          static byte delay_SysClk  = 25;
  39          static byte delay_ProgWst =  1;
  40          
  41          // ----------------------------------------------------------------------------
  42          // Function Name : DELAY_Init
  43          // Purpose       : Get system clock and program wait state to decide delay loop count.
  44          // Params        :
  45          // Returns       :
  46          // Note          :
  47          // -------------------------------------------------------------------------------
  48          void DELAY_Init(void)
  49          {
  50   1              // get system clock //
  51   1              switch (AX11000_GetSysClk())
  52   1              {
  53   2                case SCS_100M : delay_SysClk = CLK_100M;  break;
  54   2                case SCS_50M  : delay_SysClk = CLK_50M;   break;
  55   2                case SCS_25M  : delay_SysClk = CLK_25M;   break;
  56   2                default:                                  break;
  57   2              }
  58   1              // get program wait state //
  59   1              delay_ProgWst = AX11000_GetProgWst() + 1;
  60   1              // calculate driver loop count for per ms //
  61   1              delay_MsLoop = ((ulong)delay_SysClk * 1000) / ((ulong)delay_ProgWst * 44);
  62   1      } // End of DELAY_Init //
  63          
  64          // ----------------------------------------------------------------------------
  65          // Function Name : DELAY_Us
  66          // Purpose       : Delay XXX us.
  67          // Params        :
  68          // Returns       :
  69          // Note          :
  70          // -------------------------------------------------------------------------------
  71          void DELAY_Us(uint loop)
  72          {       
  73   1              ulong   count;
  74   1      
  75   1              count = ((ulong)delay_SysClk * loop) / ((ulong)delay_ProgWst * 20);
  76   1              if (count > 7)
  77   1                      count -= 7;
  78   1              else
  79   1                      return;
  80   1              while (count--);
  81   1      } // End of DELAY_Us //
  82          
  83          // -------------------------------------------------------------------------------
  84          // Function Name : DELAY_Ms
  85          // Purpose : Delay XXX ms
  86          // Params  :
  87          // Returns :
  88          // Note    :
  89          // -------------------------------------------------------------------------------
  90          void DELAY_Ms(uint loop)
  91          {
  92   1              uint    x, y;
  93   1      
  94   1              for (y = 0; y < loop; y++)
  95   1              {
