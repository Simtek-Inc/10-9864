           =1 #define WAKEUP_FRAME_FILTER0_UNI_ENABLE BIT1
           =1 #define WAKEUP_FRAME_FILTER1_ENABLE             BIT2
           =1 #define WAKEUP_FRAME_FILTER1_UNI_ENABLE BIT3
           =1 #define WAKEUP_FRAME_CASCADE_ENABLE             BIT4
