           =1 void MAC_Init(byte);
           =1 void MAC_Start(void);
           =1 void mac_StopOperate(void);
           =1 void mac_InterruptDisable(void);
           =1 byte* MAC_GetMacAddr(void);
           =1 void MAC_SetMacAddr(byte*);
           =1 void MAC_SetRxFilter(byte);
           =1 void  MAC_SetInterruptFlag(void);
           =1 byte  MAC_GetInterruptFlag(void);
           =1 void  MAC_ProcessInterrupt(void);
           =1 byte  MAC_ProcessInterruptExt(void);
           =1 void  MAC_MultiFilter(byte*, byte);
           =1 
           =1 #endif // __MAC_H__ //
