           =1 #define WAKEUP_BY_MICROSOFT_FRAME               BIT6
           =1 
           =1 // Bit definitions: MAC_LINK_CHANGE_INT_ENABLE_REG //
           =1 #define PRIMARY_LINK_CHANGE_ENABLE              BIT0
           =1 #define SECOND_LINK_CHANGE_ENABLE               BIT2
