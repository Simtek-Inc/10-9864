           =1 #define MAC_RCV_PROMISCUOUS                             1
           =1 #define MAC_RCV_ALL_MULTICAST                   2
           =1 #define MAC_RCV_BROADCAST                               4
           =1 #define MAC_RCV_MULTICAST                               8
           =1 
           =1 #define MAC_PRIMARY_PHY_LINK_WAKEUP             1                
           =1 #define MAC_MAGIC_PACKET_WAKEUP                 2
           =1 #define MAC_EXTERNAL_PIN_WAKEUP                 4
           =1 #define MAC_MS_FRAME_WAKEUP                             8
           =1 
           =1 // MAC register definitions //
           =1 #define MAC_SRAM_CMD_REG                                0x00
           =1 #define MAC_SRAM_DATA_REG                               0x02
           =1 #define MAC_RX_CTL_REG                                  0x0A
           =1 #define MAC_IPG_CTL_REG                                 0x0C
           =1 #define MAC_ADDR_REG                                    0x10
           =1 #define MAC_MULTICASE_REG                               0x16
           =1 #define MAC_TEST_REG                                    0x1E
           =1 #define MAC_MEDIUM_STATUS_MODE_REG              0x20
           =1 #define MAC_PHY_CTL_REG                                 0x22
           =1 #define MAC_WAKEUP_INT_ENABLE_REG               0x24
           =1 #define MAC_LINK_CHANGE_INT_ENABLE_REG  0x26
           =1 #define MAC_WAKEUP_LINK_INT_STATUS_REG  0x28
           =1 #define MAC_WAKEUP_FRAME_COMMAND                0x30
           =1 #define MAC_WAKEUP_FRAME_MASK0                  0x32
           =1 #define MAC_WAKEUP_FRAME_CRC0                   0x36
           =1 #define MAC_WAKEUP_FRAME_OFFSET0                0x38
           =1 #define MAC_WAKEUP_FRAME_LAST_BYTE0             0x3a
           =1 #define MAC_WAKEUP_FRAME_MASK1                  0x40
           =1 #define MAC_WAKEUP_FRAME_CRC1                   0x44
           =1 #define MAC_WAKEUP_FRAME_OFFSET1                0x46
           =1 #define MAC_WAKEUP_FRAME_LAST_BYTE1             0x48
           =1 #define MAC_CMD_ABORT                                   0xFF
           =1 
           =1 // Bit definitions: MAC_RX_CTL_REG //
           =1 #define PACKET_TYPE_PROMISCOUS                  BIT0
           =1 #define PACKET_TYPE_ALL_MULTI                   BIT1
           =1 #define PACKET_TYPE_RCV_CRC_ERROR               BIT2
           =1 #define PACKET_TYPE_BROADCAST                   BIT3
           =1 #define PACKET_TYPE_MULTICAST                   BIT4
           =1 #define PACKET_TYPE_UNICAST_MATCH               BIT5
           =1 #define START_OPERATION                                 BIT7
           =1 
           =1 // Bit definitions: MAC_MEDIUM_STATUS_MODE_REG //
           =1 #define MEDIUM_SUPER_MAC                                BIT0
           =1 #define MEDIUM_STOP_BACKPRESSURE                BIT1
           =1 #define MEDIUM_ENABLE_RECEIVE                   BIT2
           =1 #define MEDIUM_CHECK_ONLY_TYPE_PAUSE    BIT3
           =1 #define MEDIUM_ENABLE_TX_FLOWCTRL               BIT4
           =1 #define MEDIUM_FULL_DUPLEX_MODE                 BIT5
C51 COMPILER V8.06   DHCPC                                                                 03/10/2026 15:31:00 PAGE 34  

           =1 #define MEDIUM_MII_100M_MODE                    BIT6
           =1 #define MEDIUM_ENABLE_RX_FLOWCTRL               BIT7
           =1 
           =1 // Bit definitions: MAC_PHY_CTL_REG //
           =1 #define PHY_SELECT_EXTERNAL_PHY                 0
           =1 #define PHY_SELECT_EMBEDDED                             BIT0
           =1 #define PHY_AUTO_SELECT                                 BIT1
           =1 #define PHY_INTERNAL_PHY_OPERA_STATE    BIT2
