           =1 // wakeup frame Mode //
           =1 #define WUF_ONLY_USE_FILTER0                    0
           =1 #define WUF_ONLY_USE_FILTER1                    1
           =1 #define WUF_ONLY_FILTER0_MACADDR                2
           =1 #define WUF_ONLY_FILTER1_MACADDR                3
           =1 #define WUF_BOTH_FILTERS                                4
           =1 #define WUF_BOTH_FILTERS_MACADDR                6
           =1 #define WUF_CASCADE                                             8
           =1 #define WUF_CASCADE_MACADDR                             10
           =1 
           =1 // TYPE DECLARATIONS //
           =1 //----------------------------------------------------------------------------------------
           =1 typedef struct _MAC_INFORMATION
           =1 {
           =1 // definition for NetworkType member. //
           =1 #define MAC_AUTO_NEGOTIATION                    0
           =1 #define MAC_LINK_100M_SPEED                             100
           =1 #define MAC_LINK_10M_SPEED                              10
           =1 #define MAC_LINK_FULL_DUPLEX                    0x80
           =1 #define MAC_FORCE_ENBEDDED_PHY_10_HALF  0x4A
           =1 
           =1         byte    LinkSpeed;
           =1         byte    FullDuplex;
           =1       byte  MediumLinkType;   // map to mac register MAC_MEDIUM_STATUS_MODE_REG //
           =1         byte    NetworkType;
           =1         byte    InterruptMask;
C51 COMPILER V8.06   DHCPC                                                                 03/10/2026 15:31:00 PAGE 35  

           =1 
           =1 } MAC_INFO;
           =1 
           =1 //----------------------------------------------------------------------------------------
           =1 typedef struct _MAC_WAKEUP_FRAME
           =1 {
           =1       byte  Mode;       // see above wakeup frame Mode //
           =1       byte  Offset0;    // filter0 offset //
           =1       byte  Offset1;    // filter1 offset //
           =1       ulong Mask0;      // filter0 mask //
           =1       ulong Mask1;      // filter1 mask //
           =1       byte* Pframe;     // point to the first byte of wakeup frame (destination address) //
           =1         byte    Length;
           =1 
           =1 } MAC_WUF;
