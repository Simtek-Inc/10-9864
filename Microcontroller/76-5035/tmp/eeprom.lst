  46          // Returns         :
C51 COMPILER V8.06   EEPROM                                                                03/10/2026 15:31:01 PAGE 29  

  47          // Note                  :
  48          // ----------------------------------------------------------------------------
  49          void EEPROM_Init(void)
  50          {
  51   1            // Disable I2C interrupt.
  52   1      
  53   1              switch (CSREPR & (BIT6|BIT7))
  54   1              {
  55   2              case SYS_CLK_100M:
  56   2                      // I2C master mode, interrupt enable, fast mode in slave, 7-bits address, 400KHz at 100M
  57   2                      I2C_Setup(I2C_ENB|I2C_FAST|I2C_7BIT|I2C_MASTER_MODE, I2C_FAST_100M, 0x005A);
  58   2                      break;
  59   2              case SYS_CLK_50M:
  60   2                      // I2C master mode, interrupt enable, fast mode in slave, 7-bits address, 400KHz at 50M
  61   2                      I2C_Setup(I2C_ENB|I2C_FAST|I2C_7BIT|I2C_MASTER_MODE, I2C_FAST_50M, 0x005A);
  62   2                      break;
  63   2              case SYS_CLK_25M:
  64   2                      // I2C master mode, interrupt enable, fast mode in slave, 7-bits address, 400KHz at 25M
  65   2                      I2C_Setup(I2C_ENB|I2C_FAST|I2C_7BIT|I2C_MASTER_MODE, I2C_FAST_25M, 0x005A);
  66   2                      break;
  67   2              }
  68   1      
  69   1      } // End of EEPROM_Init() //
  70          
  71          // ----------------------------------------------------------------------------
  72          // Function Name : teI2C_STATUS EEPROM_Read(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
  73          // Purpose       :
  74          // Params          :
  75          // Returns         :
  76          // Note                  :
  77          // ----------------------------------------------------------------------------
  78          teI2C_STATUS EEPROM_Read(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
  79          {
  80   1              return I2C_Read(DevAddr, RegAddr, pBuf, Len);
  81   1      }
  82          
  83          // ----------------------------------------------------------------------------
  84          // Function Name : teI2C_STATUS EEPROM_Write(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
  85          // Purpose       :
  86          // Params          :
  87          // Returns         :
  88          // Note                  :
  89          // ----------------------------------------------------------------------------
  90          teI2C_STATUS EEPROM_Write(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
  91          {
  92   1            byte LenTemp, ErrFlag = 0;
  93   1              
  94   1              while (Len)
  95   1              {
  96   2                      LenTemp = 0x08 - (RegAddr & 0x07);
  97   2                      if (LenTemp > Len)
  98   2                              LenTemp = Len;
  99   2                              
 100   2                      ErrFlag = I2C_Write(DevAddr, RegAddr, pBuf, LenTemp);
 101   2                      
 102   2                      Len -= LenTemp;
 103   2                      RegAddr += LenTemp;
 104   2                      pBuf += LenTemp;
 105   2                      
 106   2                      DELAY_Ms(10);
 107   2              }
 108   1              return ErrFlag;
C51 COMPILER V8.06   EEPROM                                                                03/10/2026 15:31:01 PAGE 30  

 109   1      }
