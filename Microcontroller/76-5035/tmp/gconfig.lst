 262          //----------------------------------------------------------------------------------------
 263          // Name    : GCONFIG_IpAddr2Ulong()
 264          // Purpose :
 265          // Params  :
 266          // Returns :
 267          // Note    :
 268          //----------------------------------------------------------------------------------------
 269          ulong GCONFIG_IpAddr2Ulong(byte* pBuf, byte len)
 270          {
 271   1          ulong ip     = 0;
 272   1          byte* point  = (byte*)&ip;
 273   1          byte  count  = 0;
 274   1          byte  count2 = 0;
 275   1      
 276   1          while (1)
 277   1            {
 278   2            count2 = 0;
 279   2            while ((*pBuf != '.') && len)
 280   2              {
 281   3              count2++;
 282   3              if (count2 > 3) return 0xffffffff;
 283   3      
 284   3              *point *= 10;
 285   3        
 286   3              if ((*pBuf < 0x3a) && (*pBuf > 0x2f))
 287   3                *point += (*pBuf - 0x30);
 288   3              else
 289   3                return 0xffffffff;
 290   3      
 291   3              pBuf++;
 292   3              len--;
 293   3              }
 294   2        
 295   2            if (len == 0) break;
 296   2      
 297   2            pBuf++;
 298   2            len--;
 299   2            count++;
 300   2            point++;
 301   2      
 302   2            if (count > 3) return 0xffffffff;
 303   2            }
 304   1      
 305   1          if (count != 3) return 0xffffffff;
 306   1      
 307   1          return ip;
 308   1      } //End of GCONFIG_IpAddr2Ulong() //
