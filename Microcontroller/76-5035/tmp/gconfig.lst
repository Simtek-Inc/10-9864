 248          // Name    : Simtek_Modes_Enable
 249          // Purpose : use data stored with EDCT tool to enable different functions
 250          // Params  : mask of bit to check for enable/disable of desired function
 251          // Returns : ON if enabled, OFF if not
 252          // Note    :
 253          // ---------------------------------------------------------------------------------------
 254          //
 255          byte Simtek_Modes_Enable(byte mask)
 256          {
 257   1          if ((gconfig_ConfigData.Option & mask) == 0)                                        // mask off all ot
             -her bits and check remaing bit/s for state
 258   1            return OFF;                                                                       // debug if enable
             -d turn mode off
 259   1          return ON;                                                                          // debug if disabl
             -ed turn mode on
 260   1      } //End of Simtek_Modes_Enable(byte mask) //
