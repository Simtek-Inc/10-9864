 677          static uint  gconfig_Checksum(uint  *pBuf, ulong length)
 678          {
 679   1              ulong   cksum = 0;
 680   1              ulong   i, count;
 681   1              byte*   inChar = &pBuf;
 682   1              uint *  point;
 683   1      
 684   1              count = length/2;
 685   1      
 686   1          for (i = 0; i < count; i++)
 687   1            {
 688   2            point = pBuf;
 689   2            cksum += *pBuf++;
 690   2            if (point > pBuf)
 691   2              (*inChar) = *inChar + 1;
 692   2      
 693   2            if (!(i % 0x8000))
 694   2              {
C51 COMPILER V8.06   GCONFIG                                                               03/10/2026 15:30:59 PAGE 75  

 695   3              cksum = (cksum >> 16) + (cksum & 0xffff);
 696   3              cksum += (cksum >> 16);
 697   3              cksum &= 0xffff;
 698   3              }
 699   2            }
 700   1                  
 701   1          if (length % 2)
 702   1            cksum += (*pBuf & 0xff00);
 703   1      
 704   1          cksum  = (cksum >> 16) + (cksum & 0xffff);
