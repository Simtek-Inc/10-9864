  49          // name    : GS2E_PortLeaseTimeoutUpdate
  50          // purpose : 
  51          // params  :
  52          // returns :
  53          // notes   : Rev B removed 2 extra buffer writes that were corrputing the device status data
  54          //----------------------------------------------------------------------------------------
  55          void  GS2E_PortLeaseTimeoutUpdate(void)
  56          {
  57   1          if (DEADMANcnt == 0)                                                                  // check to make
             - sure the connection has been made
  58   1            {
  59   2            if(PortLeaseTimeoutVal != 0)                                                        // check to see 
             -the port is being used
  60   2              {
  61   3              if(PortLeaseTimeoutVal == 1)                                                      // see if the ti
             -meout on the port has been reached
  62   3                {
  63   4                PortLeaseTimeoutVal = 0;                                                        // turn the port
             - lease timeout off
  64   4      //          if(acDimmingRequest < 0xffff)                                                   // make sure t
             -he maximum number of action requests is not pending
  65   4      //            { 
  66   4      //            bufDimmingData[ix02] = 0;                                                      // 
  67   4      //            acDimmingRequest++;                                                           // trigger a r
             -eset action
  68   4      //            }
  69   4                printd("\rConnection inactive\n\r");                                                //
  70   4                }
  71   3              else                                                                              // the port leas
             -e timeout has not been reached
  72   3                {
  73   4                PortLeaseTimeoutVal--;                                                          // update the po
             -rt lease timeout
  74   4                }
  75   3              }
  76   2            }
  77   1      }
