 124          void GS2E_Init(void)
 125          {       
 126   1              gs2e_State = GS2E_STATE_IDLE; 
 127   1      
 128   1              if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_PROTO_UDP_BCAST) == GCONFIG_NETWORK_PROTO_UDP_BCAST)
 129   1                {
 130   2                GUDPBC_Init(GCONFIG_UDP_BCAST_SERVER_PORT);
 131   2                }
 132   1              GUDPUC_Init(GCONFIG_UDP_UCAST_SERVER_PORT);
 133   1      
 134   1              if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_PROTO_UDP) == GCONFIG_NETWORK_PROTO_UDP)
 135   1                {
 136   2                gs2e_ConnType = GS2E_CONN_UDP;
 137   2                GUDPDAT_Init(GCONFIG_GetServerDataPktListenPort());
 138   2                }
 139   1          DEADMANcnt          = 3000;                                                           // 
 140   1          PortLeaseTimeoutVal = PortLeaseTimeout;                                               // set the port 
             -lease timeout for an approximately 5 second delay
 141   1              gs2e_EEPROM_Init();
 142   1      } // End of GS2E_Init() //
