           =3 
           =3 typedef unsigned short int          bool;                                                 // boolean
           =3 typedef unsigned char               byte;                                                 //  8-bit unsign
             -ed
           =3 typedef unsigned short int          uint;                                                 // 16-bit unsign
             -ed
           =3 typedef short int                   sint;                                                 // 16-bit signed
           =3 typedef unsigned long               ulong;                                                // 32-bit unsign
             -ed
           =3 typedef unsigned short int          word;                                                 // 16-bit unsign
             -ed
           =3 
           =3 #ifndef NULL
           =3   #define NULL ((void *) 0L)
           =3 #endif
           =3 
