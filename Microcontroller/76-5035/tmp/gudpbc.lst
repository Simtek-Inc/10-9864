 410      =2  /** @} */
 411      =2  
 412      =2  /*------------------------------------------------------------------------------*/
 413      =2  
 414      =2  /**
 415      =2   * \defgroup uipoptgeneral General configuration options
 416      =2   * @{
 417      =2   */
 418      =2  
 419      =2  /**
 420      =2   * The size of the uIP packet buffer.
 421      =2   *
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 27  

 422      =2   * The uIP packet buffer should not be smaller than 60 bytes, and does
 423      =2   * not need to be larger than 1500 bytes. Lower size results in lower
 424      =2   * TCP throughput, larger size results in higher TCP throughput.
 425      =2   *
 426      =2   * \hideinitializer
 427      =2   */
 428      =2  #define UIP_BUFSIZE     1514
 429      =2  
 430      =2  
 431      =2  /**
 432      =2   * Determines if statistics support should be compiled in.
 433      =2   *
 434      =2   * The statistics is useful for debugging and to show the user.
 435      =2   *
 436      =2   * \hideinitializer
 437      =2   */
 438      =2  #define UIP_STATISTICS  0
 439      =2  
 440      =2  /**
 441      =2   * Determines if logging of certain events should be compiled in.
 442      =2   *
 443      =2   * This is useful mostly for debugging. The function uip_log()
 444      =2   * must be implemented to suit the architecture of the project, if
 445      =2   * logging is turned on.
 446      =2   *
 447      =2   * \hideinitializer
 448      =2   */
 449      =2  #define UIP_LOGGING     0
 450      =2  
 451      =2  /**
