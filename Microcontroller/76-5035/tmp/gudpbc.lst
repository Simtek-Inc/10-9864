           =2 #define BIT26           0x04000000
           =2 #define BIT27           0x08000000
           =2 #define BIT28           0x10000000
           =2 #define BIT29           0x20000000
           =2 #define BIT30           0x40000000
           =2 #define BIT31           0x80000000
           =2 
           =2 #define LOW_BYTE(dat)   (byte) (dat & 0x00FF)
           =2 #define HIGH_BYTE(dat)  (byte)((dat & 0xFF00) >> 8)
           =2 
           =2 #define U32BYTE0(dat)   (byte) (dat  & 0x000000FF)
           =2 #define U32BYTE1(dat)   (byte)((dat  & 0x0000FF00) >> 8)
           =2 #define U32BYTE2(dat)   (byte)((dat  & 0x00FF0000) >> 16)
           =2 #define U32BYTE3(dat)   (byte)((dat  & 0xFF000000) >> 24)
           =2  
