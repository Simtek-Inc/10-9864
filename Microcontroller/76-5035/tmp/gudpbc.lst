 504      =2  /**
 505      =2   * \defgroup uipoptapp Appication specific configurations
 506      =2   * @{
 507      =2   *
 508      =2   * An uIP application is implemented using a single application
 509      =2   * function that is called by uIP whenever a TCP/IP event occurs. The
 510      =2   * name of this function must be registered with uIP at compile time
 511      =2   * using the UIP_APPCALL definition.
 512      =2   *
 513      =2   * uIP applications can store the application state within the
 514      =2   * uip_conn structure by specifying the size of the application
 515      =2   * structure with the UIP_APPSTATE_SIZE macro.
 516      =2   *
 517      =2   * The file containing the definitions must be included in the
 518      =2   * uipopt.h file.
 519      =2   *
 520      =2   * The following example illustrates how this can look.
 521      =2   \code
 522      =2  
 523      =2  void httpd_appcall(void);
 524      =2  #define UIP_APPCALL     httpd_appcall
 525      =2  
 526      =2  struct httpd_state {
 527      =2    uint state; 
 528      =2    uint count;
 529      =2    char *dataptr;
 530      =2    char *script;
 531      =2  };
 532      =2  #define UIP_APPSTATE_SIZE (sizeof(struct httpd_state))
 533      =2   \endcode
 534      =2   */
 535      =2  
 536      =2  /**
 537      =2   * \var #define UIP_APPCALL
 538      =2   *
 539      =2   * The name of the application function that uIP should call in
 540      =2   * response to TCP/IP events.
 541      =2   *
 542      =2   */
 543      =2  
 544      =2  /**
 545      =2   * \var #define UIP_APPSTATE_SIZE
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 29  

 546      =2   *
 547      =2   * The size of the application state that is to be stored in the
 548      =2   * uip_conn structure.
 549      =2   */
 550      =2  /** @} */
 551      =2  
 552      =2  /* Include the header file for the application program that should be
 553      =2     used. If you don't use the example web server, you should change
 554      =2     this. */
 555      =2  
 556      =2  
 557      =2  #endif /* __UIPOPT_H__ */
  59      =1  
  60      =1  //-----------------------------------------------------------------------------------//
  61      =1  // First, the functions that should be called from the
  62      =1  // system. Initialization, the periodic timer and incoming packets are
  63      =1  // handled by the following three functions.
  64      =1  //
  65      =1  
  66      =1  //
  67      =1  // \defgroup uipconffunc uIP configuration functions
  68      =1  // @{
  69      =1  //
  70      =1  // The uIP configuration functions are used for setting run-time
  71      =1  // parameters in uIP such as IP addresses. 
  72      =1  //
  73      =1  
  74      =1  //
  75      =1  // Set the IP address of this host.
  76      =1  //
  77      =1  // The IP address is represented as a 4-byte array where the first
  78      =1  // octet of the IP address is put in the first member of the 4-byte
  79      =1  // array.
  80      =1  //
  81      =1  // \param addr A pointer to a 4-byte representation of the IP address.
  82      =1  //
  83      =1  // \hideinitializer
  84      =1  //
  85      =1  #define uip_sethostaddr(addr) do { uip_hostaddr[0] = addr[0]; \
  86      =1                                uip_hostaddr[1] = addr[1]; } while(0)
  87      =1  
  88      =1  //
  89      =1  // Get the IP address of this host.
  90      =1  //
  91      =1  // The IP address is represented as a 4-byte array where the first
  92      =1  // octet of the IP address is put in the first member of the 4-byte
  93      =1  // array.
  94      =1  //
  95      =1  // \param addr A pointer to a 4-byte array that will be filled in with
  96      =1  // the currently configured IP address.
  97      =1  //
  98      =1  // \hideinitializer
  99      =1  //
 100      =1  #define uip_gethostaddr(addr) do { addr[0] = uip_hostaddr[0]; \
 101      =1                                addr[1] = uip_hostaddr[1]; } while(0)
 102      =1  
 103      =1  //
 104      =1  // \defgroup uipinit uIP initialization functions
 105      =1  // @{
 106      =1  //
 107      =1  // The uIP initialization functions are used for booting uIP.
 108      =1  //
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 30  

 109      =1  
 110      =1  //
 111      =1  // uIP initialization function.
 112      =1  //
 113      =1  // This function should be called at boot up to initilize the uIP
 114      =1  // TCP/IP stack.
 115      =1  //
 116      =1  void uip_init(void);
 117      =1  
 118      =1  // @} //
 119      =1  
 120      =1  // \defgroup uipdevfunc uIP device driver functions
 121      =1  // @{
 122      =1  //
 123      =1  // These functions are used by a network device driver for interacting
 124      =1  // with uIP.
 125      =1  //
 126      =1  // Process an incoming packet.
 127      =1  //
 128      =1  // This function should be called when the device driver has received
 129      =1  // a packet from the network. The packet from the device driver must
 130      =1  // be present in the uip_buf buffer, and the length of the packet
 131      =1  // should be placed in the uip_len variable.
 132      =1  //
 133      =1  // When the function returns, there may be an outbound packet placed
 134      =1  // in the uip_buf packet buffer. If so, the uip_len variable is set to
 135      =1  // the length of the packet. If no packet is to be sent out, the
 136      =1  // uip_len variable is set to 0.
 137      =1  //
 138      =1  // The usual way of calling the function is presented by the source
 139      =1  // code below.
 140      =1  // \code
 141      =1  //  uip_len = devicedriver_poll();
 142      =1  //  if(uip_len > 0) {
 143      =1  //    uip_input();
 144      =1  //    if(uip_len > 0) {
 145      =1  //      devicedriver_send();
 146      =1  //    }
 147      =1  //  }
 148      =1  // \endcode
 149      =1  //
 150      =1  // \note If you are writing a uIP device driver that needs ARP
 151      =1  // (Address Resolution Protocol), e.g., when running uIP over
 152      =1  // Ethernet, you will need to call the uIP ARP code before calling
 153      =1  // this function:
 154      =1  // \code
 155      =1  //  #define BUF ((struct uip_eth_hdr *)&uip_buf[0])
 156      =1  //  uip_len = ethernet_devicedrver_poll();
 157      =1  //  if(uip_len > 0) {
 158      =1  //    if(BUF->type == HTONS(UIP_ETHTYPE_IP)) {
 159      =1  //      uip_arp_ipin();
 160      =1  //      uip_input();
 161      =1  //      if(uip_len > 0) {
 162      =1  //        uip_arp_out();
 163      =1  //      ethernet_devicedriver_send();
 164      =1  //      }
 165      =1  //    } else if(BUF->type == HTONS(UIP_ETHTYPE_ARP)) {
 166      =1  //      uip_arp_arpin();
 167      =1  //      if(uip_len > 0) {
 168      =1  //      ethernet_devicedriver_send();
 169      =1  //      }
 170      =1  //    }
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 31  

 171      =1  // \endcode
 172      =1  //
 173      =1  // \hideinitializer
 174      =1  //
 175      =1  //#define uip_input()        uip_process(UIP_DATA)
 176      =1  
 177      =1  //
 178      =1  // Periodic processing for a connection identified by its number.
 179      =1  // 
 180      =1  // This function does the necessary periodic processing (timers,
 181      =1  // polling) for a uIP TCP conneciton, and should be called when the
 182      =1  // periodic uIP timer goes off. It should be called for every
 183      =1  // connection, regardless of whether they are open of closed.
 184      =1  //
 185      =1  // When the function returns, it may have an outbound packet waiting
 186      =1  // for service in the uIP packet buffer, and if so the uip_len
 187      =1  // variable is set to a value larger than zero. The device driver
 188      =1  // should be called to send out the packet.
 189      =1  //
 190      =1  // The ususal way of calling the function is through a for() loop like
 191      =1  // this:
 192      =1  // \code
 193      =1  //  for(i = 0; i < UIP_CONNS; ++i) {
 194      =1  //    uip_periodic(i);
 195      =1  //    if(uip_len > 0) {
 196      =1  //      devicedriver_send();
 197      =1  //    }
 198      =1  //  }
 199      =1  // \endcode
 200      =1  //
 201      =1  // \note If you are writing a uIP device driver that needs ARP
 202      =1  // (Address Resolution Protocol), e.g., when running uIP over
 203      =1  // Ethernet, you will need to call the uip_arp_out() function before
 204      =1  // calling the device driver:
 205      =1  // \code
 206      =1  //  for(i = 0; i < UIP_CONNS; ++i) {
 207      =1  //    uip_periodic(i);
 208      =1  //    if(uip_len > 0) {
 209      =1  //      uip_arp_out();
 210      =1  //      ethernet_devicedriver_send();
 211      =1  //    }
 212      =1  //  }
 213      =1  // \endcode 
 214      =1  //
 215      =1  // \param conn The number of the connection which is to be periodically polled.
 216      =1  //
 217      =1  // \hideinitializer
 218      =1  //
 219      =1  #define uip_periodic(conn) do { uip_conn = &uip_conns[conn]; \
 220      =1                                  uip_process(UIP_TIMER); } while (0)
 221      =1  
 222      =1  //
 223      =1  // Periodic processing for a connection identified by a pointer to its structure.
 224      =1  //
 225      =1  // Same as uip_periodic() but takes a pointer to the actual uip_conn
 226      =1  // struct instead of an integer as its argument. This function can be
 227      =1  // used to force periodic processing of a specific connection.
 228      =1  //
 229      =1  // \param conn A pointer to the uip_conn struct for the connection to
 230      =1  // be processed.
 231      =1  //
 232      =1  // \hideinitializer
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 32  

 233      =1  //
 234      =1  #define uip_periodic_conn(conn) do { uip_conn = conn; \
 235      =1                                       uip_process(UIP_TIMER); } while (0)
 236      =1  
 237      =1  #if UIP_UDP
 238      =1  //
 239      =1  // Periodic processing for a UDP connection identified by its number.
 240      =1  //
 241      =1  // This function is essentially the same as uip_prerioic(), but for
 242      =1  // UDP connections. It is called in a similar fashion as the
 243      =1  // uip_periodic() function:
 244      =1  // \code
 245      =1  //  for(i = 0; i < UIP_UDP_CONNS; i++) {
 246      =1  //    uip_udp_periodic(i);
 247      =1  //    if(uip_len > 0) {
 248      =1  //      devicedriver_send();
 249      =1  //    }
 250      =1  //  }   
 251      =1  // \endcode
 252      =1  //
 253      =1  // \note As for the uip_periodic() function, special care has to be
 254      =1  // taken when using uIP together with ARP and Ethernet:
 255      =1  // \code
 256      =1  //  for(i = 0; i < UIP_UDP_CONNS; i++) {
 257      =1  //    uip_udp_periodic(i);
 258      =1  //    if(uip_len > 0) {
 259      =1  //      uip_arp_out();
 260      =1  //      ethernet_devicedriver_send();
 261      =1  //    }
 262      =1  //  }   
 263      =1  // \endcode
 264      =1  //
 265      =1  // \param conn The number of the UDP connection to be processed.
 266      =1  //
 267      =1  // \hideinitializer
 268      =1  //
 269      =1  #define uip_udp_periodic(conn) do { uip_udp_conn = &uip_udp_conns[conn]; \
 270      =1                                  uip_process(UIP_UDP_TIMER); } while (0)
 271      =1  
 272      =1  //
 273      =1  // Periodic processing for a UDP connection identified by a pointer to
 274      =1  // its structure.
 275      =1  //
 276      =1  // Same as uip_udp_periodic() but takes a pointer to the actual
 277      =1  // uip_conn struct instead of an integer as its argument. This
 278      =1  // function can be used to force periodic processing of a specific
 279      =1  // connection.
 280      =1  //
 281      =1  // \param conn A pointer to the uip_udp_conn struct for the connection
 282      =1  // to be processed.
 283      =1  //
 284      =1  // \hideinitializer
 285      =1  //
 286      =1  #define uip_udp_periodic_conn(conn) do { uip_udp_conn = conn; \
 287      =1                                           uip_process(UIP_UDP_TIMER); } while (0)
 288      =1  
 289      =1  void uip_udp_listen(uint port);
 290      =1  void uip_udp_unlisten(uint port);
 291      =1  
 292      =1  #endif // UIP_UDP //
 293      =1  
 294      =1  // The uIP packet buffer.
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 33  

 295      =1  //
 296      =1  // The uip_buf array is used to hold incoming and outgoing
 297      =1  // packets. The device driver should place incoming data into this
 298      =1  // buffer. When sending data, the device driver should read the link
 299      =1  // level headers and the TCP/IP headers from this buffer. The size of
 300      =1  // the link level headers is configured by the UIP_LLH_LEN define.
 301      =1  //
 302      =1  // \note The application data need not be placed in this buffer, so
 303      =1  // the device driver must read it from the place pointed to by the
 304      =1  // uip_appdata pointer as illustrated by the following example:
 305      =1  // \code
 306      =1  // void
 307      =1  // devicedriver_send(void)
 308      =1  // {
 309      =1  //    hwsend(&uip_buf[0], UIP_LLH_LEN);
 310      =1  //    hwsend(&uip_buf[UIP_LLH_LEN], 40);
 311      =1  //    hwsend(uip_appdata, uip_len - 40 - UIP_LLH_LEN);
 312      =1  // }
 313      =1  // \endcode
 314      =1  //
 315      =1  //extern byte xdata uip_buf[UIP_BUFSIZE+2];
 316      =1  
 317      =1  // @} //
 318      =1  void uip_listen(uint port);
 319      =1  
 320      =1  //-----------------------------------------------------------------------------------//
 321      =1  // Functions that are used by the uIP application program. Opening and
 322      =1  // closing connections, sending and receiving data, etc. is all
 323      =1  // handled by the functions below.
 324      =1  //
 325      =1  //
 326      =1  // \defgroup uipappfunc uIP application functions
 327      =1  // @{
 328      =1  //
 329      =1  // Functions used by an application running of top of uIP.
 330      =1  //
 331      =1  
 332      =1  // Start listening to the specified port.
 333      =1  //
 334      =1  // \note Since this function expects the port number in network byte
 335      =1  // order, a conversion using HTONS() or htons() is necessary.
 336      =1  //
 337      =1  // \code
 338      =1  // uip_listen(HTONS(80)); 
 339      =1  // \endcode
 340      =1  //
 341      =1  // \param port A 16-bit port number in network byte order.
 342      =1  //
 343      =1  void uip_listen(uint port);
 344      =1  
 345      =1  // Stop listening to the specified port.
 346      =1  //
 347      =1  // \note Since this function expects the port number in network byte
 348      =1  // order, a conversion using HTONS() or htons() is necessary.
 349      =1  //
 350      =1  // \code
 351      =1  // uip_unlisten(HTONS(80)); 
 352      =1  // \endcode
 353      =1  //
 354      =1  // \param port A 16-bit port number in network byte order.
 355      =1  //
 356      =1  
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 34  

 357      =1  struct uip_conn *uip_connect(uint *ripaddr, uint port);
 358      =1  
 359      =1  // Connect to a remote host using TCP.
 360      =1  //
 361      =1  // This function is used to start a new connection to the specified
 362      =1  // port on the specied host. It allocates a new connection identifier,
 363      =1  // sets the connection to the SYN_SENT state and sets the
 364      =1  // retransmission timer to 0. This will cause a TCP SYN segment to be
 365      =1  // sent out the next time this connection is periodically processed,
 366      =1  // which usually is done within 0.5 seconds after the call to
 367      =1  // uip_connect().
 368      =1  //
 369      =1  // \note This function is avaliable only if support for active open
 370      =1  // has been configured by defining UIP_ACTIVE_OPEN to 1 in uipopt.h.
 371      =1  //
 372      =1  // \note Since this function requires the port number to be in network
