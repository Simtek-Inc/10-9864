 472      =2  /**
 473      =2   * \defgroup uipoptcpu CPU architecture configuration
 474      =2   * @{
 475      =2   *
 476      =2   * The CPU architecture configuration is where the endianess of the
 477      =2   * CPU on which uIP is to be run is specified. Most CPUs today are
 478      =2   * little endian, and the most notable exception are the Motorolas
 479      =2   * which are big endian. The BYTE_ORDER macro should be changed to
 480      =2   * reflect the CPU architecture on which uIP is to be run.
 481      =2   */
 482      =2  #ifndef LITTLE_ENDIAN
 483      =2  #define LITTLE_ENDIAN  3412
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 28  

 484      =2  #endif /* LITTLE_ENDIAN */
 485      =2  #ifndef BIG_ENDIAN
 486      =2  #define BIG_ENDIAN     1234
 487      =2  #endif /* BIGE_ENDIAN */
 488      =2  
 489      =2  /**
 490      =2   * The byte order of the CPU architecture on which uIP is to be run.
 491      =2   *
 492      =2   * This option can be either BIG_ENDIAN (Motorola byte order) or
 493      =2   * LITTLE_ENDIAN (Intel byte order).
 494      =2   *
 495      =2   * \hideinitializer
 496      =2   */
 497      =2  #ifndef BYTE_ORDER
 498      =2  #define BYTE_ORDER     BIG_ENDIAN     // Keil C
 499      =2  #endif /* BYTE_ORDER */
 500      =2  
 501      =2  /** @} */
 502      =2  /*------------------------------------------------------------------------------*/
