 756      =1  //
 757      =1  // Representation of a uIP TCP connection.
 758      =1  //
 759      =1  // The uip_conn structure is used for identifying a connection. All
 760      =1  // but one field in the structure are to be considered read-only by an
 761      =1  // application. The only exception is the appstate field whos purpose
 762      =1  // is to let the application store application-specific state (e.g.,
 763      =1  // file pointers) for the connection. The size of this field is
 764      =1  // configured in the "uipopt.h" header file.
 765      =1  //
 766      =1  struct uip_conn {
 767      =1          uint ripaddr[2];    //< The IP address of the remote host. //
 768      =1  
 769      =1          uint lport;         //< The local TCP port, in network byte order. //
 770      =1          uint rport;         //< The local remote TCP port, in network byte order. //  
 771      =1  
 772      =1          byte rcv_nxt[4];    //< The sequence number that we expect to receive next. //
 773      =1          byte snd_nxt[4];    //< The sequence number that was last sent by us. //
