C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 39  

 667      =1  // Pack an IP address into a 4-byte array which is used by uIP to
 668      =1  // represent IP addresses.
 669      =1  //
 670      =1  // Example:
 671      =1  // \code
 672      =1  // uint ipaddr[2];
 673      =1  //
 674      =1  // uip_ipaddr(&ipaddr, 192,168,1,2); 
 675      =1  // \endcode
 676      =1  //
 677      =1  // \param addr A pointer to a 4-byte array that will be filled in with
 678      =1  // the IP addres.
 679      =1  // \param addr0 The first octet of the IP address.
 680      =1  // \param addr1 The second octet of the IP address.
 681      =1  // \param addr2 The third octet of the IP address.
 682      =1  // \param addr3 The forth octet of the IP address. 
 683      =1  //
 684      =1  // \hideinitializer
 685      =1  //
 686      =1  #define uip_ipaddr(addr, addr0,addr1,addr2,addr3) do { \
 687      =1                       (addr)[0] = HTONS(((addr0) << 8) | (addr1)); \
 688      =1                       (addr)[1] = HTONS(((addr2) << 8) | (addr3)); \
 689      =1                    } while(0)
 690      =1  
 691      =1  //
 692      =1  // Convert 16-bit quantity from host byte order to network byte order.
 693      =1  //
 694      =1  // This macro is primarily used for converting constants from host
 695      =1  // byte order to network byte order. For converting variables to
 696      =1  // network byte order, use the htons() function instead.
 697      =1  //
 698      =1  // \hideinitializer
 699      =1  //
 700      =1  #ifndef HTONS
 701      =1  #if BYTE_ORDER == BIG_ENDIAN
 702      =1  #define HTONS(n) (n)
 703      =1  #else // BYTE_ORDER == BIG_ENDIAN //
           =1 #define HTONS(n) ((((uint)((n) & 0xff)) << 8) | (((n) & 0xff00) >> 8))
           =1 #endif // BYTE_ORDER == BIG_ENDIAN //
 706      =1  #endif // HTONS //
 707      =1  
 708      =1  //
 709      =1  // Convert 16-bit quantity from host byte order to network byte order.
 710      =1  //
 711      =1  // This function is primarily used for converting variables from host
 712      =1  // byte order to network byte order. For converting constants to
 713      =1  // network byte order, use the HTONS() macro instead.
 714      =1  //
