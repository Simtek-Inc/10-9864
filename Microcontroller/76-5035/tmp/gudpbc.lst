  89      =2  
  90      =2  /**
  91      =2   * \defgroup uipoptstaticconf Static configuration options
  92      =2   * @{
  93      =2   *
  94      =2   * These configuration options can be used for setting the IP address
  95      =2   * settings statically, but only if UIP_FIXEDADDR is set to 1. The
  96      =2   * configuration options for a specific node includes IP address,
  97      =2   * netmask and default router as well as the Ethernet address. The
  98      =2   * netmask, default router and Ethernet address are appliciable only
  99      =2   * if uIP should be run over Ethernet.
 100      =2   *
 101      =2   * All of these should be changed to suit your project.
 102      =2  */
 103      =2  
 104      =2  /**
 105      =2   * Determines if uIP should use a fixed IP address or not.
 106      =2   *
 107      =2   * If uIP should use a fixed IP address, the settings are set in the
 108      =2   * uipopt.h file. If not, the macros uip_sethostaddr(),
 109      =2   * uip_setdraddr() and uip_setnetmask() should be used instead.
 110      =2   *
 111      =2   * \hideinitializer
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 22  

 112      =2   */
 113      =2  
 114      =2  #define UIP_FIXEDADDR    0
 115      =2  
 116      =2  /**
 117      =2   * Ping IP address asignment.
 118      =2   *
 119      =2   * uIP uses a "ping" packets for setting its own IP address if this
 120      =2   * option is set. If so, uIP will start with an empty IP address and
 121      =2   * the destination IP address of the first incoming "ping" (ICMP echo)
 122      =2   * packet will be used for setting the hosts IP address.
 123      =2   *
 124      =2   * \note This works only if UIP_FIXEDADDR is 0.
 125      =2   *
 126      =2   * \hideinitializer
 127      =2   */
 128      =2  #define UIP_PINGADDRCONF 0
 129      =2  
 130      =2  #define UIP_IPADDR0     192 /**< The first octet of the IP address of
 131      =2                                 this uIP node, if UIP_FIXEDADDR is
 132      =2                                 1. \hideinitializer */
 133      =2  #define UIP_IPADDR1     168 /**< The second octet of the IP address of
 134      =2                                 this uIP node, if UIP_FIXEDADDR is
 135      =2                                 1. \hideinitializer */
 136      =2  #define UIP_IPADDR2     0   /**< The third octet of the IP address of
 137      =2                                 this uIP node, if UIP_FIXEDADDR is
 138      =2                                 1. \hideinitializer */
 139      =2  #define UIP_IPADDR3     3   /**< The fourth octet of the IP address of
 140      =2                                 this uIP node, if UIP_FIXEDADDR is
 141      =2                                 1. \hideinitializer */
 142      =2  
 143      =2  #define UIP_NETMASK0    255 /**< The first octet of the netmask of
 144      =2                                 this uIP node, if UIP_FIXEDADDR is
 145      =2                                 1. \hideinitializer */
 146      =2  #define UIP_NETMASK1    255 /**< The second octet of the netmask of
 147      =2                                 this uIP node, if UIP_FIXEDADDR is
 148      =2                                 1. \hideinitializer */
 149      =2  #define UIP_NETMASK2    255 /**< The third octet of the netmask of
 150      =2                                 this uIP node, if UIP_FIXEDADDR is
 151      =2                                 1. \hideinitializer */
 152      =2  #define UIP_NETMASK3    0   /**< The fourth octet of the netmask of
 153      =2                                 this uIP node, if UIP_FIXEDADDR is
 154      =2                                 1. \hideinitializer */
 155      =2  
 156      =2  #define UIP_DRIPADDR0   192 /**< The first octet of the IP address of
 157      =2                                 the default router, if UIP_FIXEDADDR is
 158      =2                                 1. \hideinitializer */
 159      =2  #define UIP_DRIPADDR1   168 /**< The second octet of the IP address of
 160      =2                                 the default router, if UIP_FIXEDADDR is
 161      =2                                 1. \hideinitializer */
 162      =2  #define UIP_DRIPADDR2   0   /**< The third octet of the IP address of
 163      =2                                 the default router, if UIP_FIXEDADDR is
 164      =2                                 1. \hideinitializer */
 165      =2  #define UIP_DRIPADDR3   1   /**< The fourth octet of the IP address of
 166      =2                                 the default router, if UIP_FIXEDADDR is
 167      =2                                 1. \hideinitializer */
 168      =2  
 169      =2  /**
 170      =2   * Specifies if the uIP ARP module should be compiled with a fixed
 171      =2   * Ethernet MAC address or not.
 172      =2   *
 173      =2   * If this configuration option is 0, the macro uip_setethaddr() can
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 23  

 174      =2   * be used to specify the Ethernet address at run-time.
 175      =2   *
 176      =2   * \hideinitializer
 177      =2   */
 178      =2  #define UIP_FIXEDETHADDR 1
 179      =2  
