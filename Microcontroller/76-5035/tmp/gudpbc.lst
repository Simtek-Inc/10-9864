 201      =2  /**
 202      =2   * \defgroup uipoptip IP configuration options
 203      =2   * @{
 204      =2   *
 205      =2   */
 206      =2  /**
 207      =2   * The IP TTL (time to live) of IP packets sent by uIP.
 208      =2   *
 209      =2   * This should normally not be changed.
 210      =2   */
 211      =2  #define UIP_TTL         (TCPIP_TIME_TO_LIVE)
 212      =2  
 213      =2  /**
 214      =2   * Turn on support for IP packet reassembly.
 215      =2   *
 216      =2   * uIP supports reassembly of fragmented IP packets. This features
 217      =2   * requires an additonal amount of RAM to hold the reassembly buffer
 218      =2   * and the reassembly code size is approximately 700 bytes.  The
 219      =2   * reassembly buffer is of the same size as the uip_buf buffer
 220      =2   * (configured by UIP_BUFSIZE).
 221      =2   *
 222      =2   * \note IP packet reassembly is not heavily tested.
 223      =2   *
 224      =2   * \hideinitializer
 225      =2   */
 226      =2  #define UIP_REASSEMBLY 0
 227      =2  
 228      =2  /**
 229      =2   * The maximum time an IP fragment should wait in the reassembly
 230      =2   * buffer before it is dropped.
 231      =2   *
 232      =2   */
 233      =2  #define UIP_REASS_MAXAGE 40
 234      =2  
 235      =2  /** @} */
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 24  

 236      =2  
 237      =2  #define CHECKSUM_OFFLOAD                1       /* hardware process all checksum calculate */
 238      =2  
 239      =2  /*------------------------------------------------------------------------------*/
 240      =2  /**
 241      =2   * \defgroup uipoptudp UDP configuration options
 242      =2   * @{
 243      =2   *
 244      =2   * \note The UDP support in uIP is still not entirely complete; there
 245      =2   * is no support for sending or receiving broadcast or multicast
 246      =2   * packets, but it works well enough to support a number of vital
 247      =2   * applications such as DNS queries, though
 248      =2   */
 249      =2  
 250      =2  /**
 251      =2   * Toggles wether UDP support should be compiled in or not.
 252      =2   *
 253      =2   * \hideinitializer
 254      =2   */
 255      =2  #define UIP_UDP           1
 256      =2  
 257      =2  /**
 258      =2   * Toggles if UDP checksums should be used or not.
 259      =2   *
 260      =2   * \note Support for UDP checksums is currently not included in uIP,
 261      =2   * so this option has no function.
 262      =2   *
 263      =2   * \hideinitializer
 264      =2   */
 265      =2  #define UIP_UDP_CHECKSUMS 0
 266      =2  
 267      =2  /**
 268      =2   * The maximum amount of concurrent UDP connections.
 269      =2   *
 270      =2   * \hideinitializer
 271      =2   */
 272      =2  #define UIP_UDP_CONNS           (TCPIP_MAX_UDP_CONN)
 273      =2  
 274      =2  /**
 275      =2   * The name of the function that should be called when UDP datagrams arrive.
 276      =2   *
 277      =2   * \hideinitializer
 278      =2   */
 279      =2  #define UIP_UDP_APPCALL()  TCPIP_CallUdpApp();
 280      =2  
 281      =2  /** @} */
 282      =2  /*------------------------------------------------------------------------------*/
 283      =2  /**
 284      =2   * \defgroup uipopttcp TCP configuration options
 285      =2   * @{
 286      =2   */
 287      =2  
 288      =2  /**
 289      =2   * Determines if support for opening connections from uIP should be
 290      =2   * compiled in.
 291      =2   *
 292      =2   * If the applications that are running on top of uIP for this project
 293      =2   * do not need to open outgoing TCP connections, this configration
 294      =2   * option can be turned off to reduce the code size of uIP.
 295      =2   *
 296      =2   * \hideinitializer
 297      =2   */
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 25  

 298      =2  #define UIP_ACTIVE_OPEN 1
 299      =2  
 300      =2  /**
 301      =2   * The maximum number of simultaneously open TCP connections.
 302      =2   *
 303      =2   * Since the TCP connections are statically allocated, turning this
 304      =2   * configuration knob down results in less RAM used. Each TCP
 305      =2   * connection requires approximatly 30 bytes of memory.
 306      =2   *
 307      =2   * \hideinitializer
 308      =2   */
 309      =2  #define UIP_CONNS                       (TCPIP_MAX_TCP_CONN)
 310      =2  
 311      =2  /**
 312      =2   * The maximum number of simultaneously listening TCP ports.
 313      =2   *
 314      =2   * Each listening TCP port requires 2 bytes of memory.
 315      =2   *
 316      =2   * \hideinitializer
 317      =2   */
 318      =2  #define UIP_LISTENPORTS         (TCPIP_MAX_TCP_LISTEN)
 319      =2  
 320      =2  #define UIP_UDP_LISTENPORTS     (TCPIP_MAX_UDP_LISTEN)
 321      =2  
 322      =2  /**
 323      =2   * The size of the advertised receiver's window.
 324      =2   *
 325      =2   * Should be set low (i.e., to the size of the uip_buf buffer) is the
 326      =2   * application is slow to process incoming data, or high (32768 bytes)
 327      =2   * if the application processes data quickly.
 328      =2   *
 329      =2   * \hideinitializer
 330      =2   */
 331      =2  #define UIP_RECEIVE_WINDOW   (1460 * 4)
 332      =2  
 333      =2  /**
 334      =2   * Determines if support for TCP urgent data notification should be
 335      =2   * compiled in.
 336      =2   *
 337      =2   * Urgent data (out-of-band data) is a rarely used TCP feature that
 338      =2   * very seldom would be required.
 339      =2   *
 340      =2   * \hideinitializer
 341      =2   */
 342      =2  #define UIP_URGDATA      1
 343      =2  
 344      =2  /**
 345      =2   * The initial retransmission timeout counted in timer pulses.
 346      =2   *
 347      =2   * This should not be changed.
 348      =2   */
 349      =2  #define UIP_RTO         3
 350      =2  
 351      =2  /**
 352      =2   * The maximum number of times a segment should be retransmitted
 353      =2   * before the connection should be aborted.
 354      =2   *
 355      =2   * This should not be changed.
 356      =2   */
 357      =2  #define UIP_MAXRTX      8
 358      =2  
 359      =2  /**
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 26  

 360      =2   * The maximum number of times a SYN segment should be retransmitted
 361      =2   * before a connection request should be deemed to have been
 362      =2   * unsuccessful.
 363      =2   *
 364      =2   * This should not need to be changed.
 365      =2   */
 366      =2  #define UIP_MAXSYNRTX      3
 367      =2  
 368      =2  /**
 369      =2   * The TCP maximum segment size.
 370      =2   *
 371      =2   * This is should not be to set to more than UIP_BUFSIZE - UIP_LLH_LEN - 40.
 372      =2   */
 373      =2  #define UIP_TCP_MSS     (UIP_BUFSIZE - 54)
 374      =2  
 375      =2  
 376      =2  /**
 377      =2   * How long a connection should stay in the TIME_WAIT state.
 378      =2   *
 379      =2   * This configiration option has no real implication, and it should be
 380      =2   * left untouched.
