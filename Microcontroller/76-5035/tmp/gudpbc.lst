 108          byte GUDPBC_NewConn(ulong XDATA* pip, uint remotePort, byte socket)
 109          {
 110   1              byte    i;
 111   1      
 112   1              pip = pip;
 113   1              remotePort = remotePort;
 114   1      
 115   1              for (i = 0; i < GUDPBC_MAX_CONNS; i++)
 116   1                {
 117   2                if (gudpbc_Conns[i].State != GUDPBC_STATE_FREE)
 118   2                  TCPIP_UdpClose(gudpbc_Conns[i].UdpSocket);
 119   2                gudpbc_Conns[i].State = GUDPBC_STATE_CONNECTED;
 120   2                gudpbc_Conns[i].UdpSocket = socket;
 121   2      #if GUDPBC_ENABLE_DEBUG_MSG
                        printd("GUDPBC_NewConn(id=%bu, remotePort=%du, socket=%bu)\n\r",i, remotePort,socket);
              #endif  
 124   2                return i;
 125   2                }
 126   1              return GUDPBC_NO_NEW_CONN;
 127   1      } // End of GUDPBC_NewConn() //
