 871      =1  // used directly by an application or by a device driver.
 872      =1  //
 873      =1  //-----------------------------------------------------------------------------------//
 874      =1  // byte uip_flags:
 875      =1  //
 876      =1  // When the application is called, uip_flags will contain the flags
 877      =1  // that are defined in this file. Please read below for more
 878      =1  // infomation.
 879      =1  //
 880      =1  extern volatile byte idata uip_flags;
 881      =1  
 882      =1  // The following flags may be set in the global variable uip_flags
 883      =1  // before calling the application callback. The UIP_ACKDATA and
 884      =1  // UIP_NEWDATA flags may both be set at the same time, whereas the
 885      =1  // others are mutualy exclusive. Note that these flags should *NOT* be
 886      =1  // accessed directly, but through the uIP functions/macros.
 887      =1  
 888      =1  #define UIP_ACKDATA   1     // Signifies that the outstanding data was
 889      =1  //                             acked and the application should send
 890      =1  //                             out new data instead of retransmitting
 891      =1  //                             the last data.
 892      =1  #define UIP_NEWDATA   2     // Flags the fact that the peer has sent us new data. //
 893      =1  #define UIP_REXMIT    4     // Tells the application to retransmit the data that was last sent. //
 894      =1  #define UIP_CONN_TIMEDOUT       8
 895      =1  //#define UIP_POLL      8     // Used for polling the application, to
 896      =1  //                             check if the application has data that
 897      =1  //                               it wants to send.
 898      =1  #define UIP_CLOSE     16    // The remote host has closed the
 899      =1  //                             connection, thus the connection has
 900      =1  //                             gone away. Or the application signals
 901      =1  //                             that it wants to close the
 902      =1  //                             connection.
 903      =1  #define UIP_ABORT     32    // The remote host has aborted the
 904      =1  //                             connection, thus the connection has
 905      =1  //                             gone away. Or the application signals
 906      =1  //                             that it wants to abort the
 907      =1  //                             connection.
 908      =1  #define UIP_CONNECTED 64    // We have got a connection from a remote
 909      =1  //                             host and have set up a new connection
 910      =1  //                             for it, or an active connection has
 911      =1  //                             been successfully established.
 912      =1  
 913      =1  #define UIP_TIMEDOUT  128   // The connection has been aborted due to too many retransmissions. //
 914      =1  
C51 COMPILER V8.06   GUDPBC                                                                03/10/2026 15:30:59 PAGE 43  

 915      =1  extern byte xdata uip_extraflag;
 916      =1  
 917      =1  #define UIP_SEND_PUSH   1
 918      =1  #define UIP_SEND_NONE   2
 919      =1  #define UIP_SEND_REXMIT 4
 920      =1  #define UIP_RCV_WINDOW  64
 921      =1  #define UIP_RCV_PRE_ACK 128
 922      =1  
 923      =1  // uip_process(flag):
 924      =1  //
 925      =1  // The actual uIP function which does all the work.
 926      =1  //
 927      =1  void uip_process(byte flag);
 928      =1  
 929      =1  // The following flags are passed as an argument to the uip_process()
 930      =1  // function. They are used to distinguish between the two cases where
 931      =1  // uip_process() is called. It can be called either because we have
 932      =1  // incoming data that should be processed, or because the periodic
 933      =1  // timer has fired.
 934      =1  
 935      =1  #define UIP_DATA    1     // Tells uIP that there is incoming data in
 936      =1                            // the uip_buf buffer. The length of the
 937      =1                            // data is stored in the global variable
 938      =1                            // uip_len.
 939      =1  #define UIP_TIMER   2     // Tells uIP that the periodic timer has
 940      =1                            // fired.
 941      =1  #if UIP_UDP
 942      =1  #define UIP_UDP_TIMER 3
 943      =1  #endif // UIP_UDP //
 944      =1  
 945      =1  #if UIP_ACTIVE_OPEN
 946      =1  #define UIP_ACTIVE_SEND 4
 947      =1  #endif // UIP_ACTIVE_OPEN //
 948      =1  
 949      =1  // The TCP states used in the uip_conn->tcpstateflags. //
 950      =1  #define CLOSED      0
 951      =1  #define SYN_RCVD    1
 952      =1  #define SYN_SENT    2
 953      =1  #define ESTABLISHED 3
 954      =1  #define FIN_WAIT_1  4
 955      =1  #define FIN_WAIT_2  5
 956      =1  #define CLOSING     6
 957      =1  #define TIME_WAIT   7
 958      =1  #define LAST_ACK    8
 959      =1  #define TS_MASK     15
 960      =1    
 961      =1  #define UIP_STOPPED      16
 962      =1  
 963      =1  #define UIP_TCPIP_HLEN 40
 964      =1  
