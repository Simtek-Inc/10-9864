 277          // ---------------------------------------------------------------------------------------//
 278          // name    : GUDPDAT_Task                                                                 //
 279          // Purpose :                                                                              //
 280          // Params  :                                                                              //
 281          // Returns :                                                                              //
 282          // Note    :                                                                              //
 283          // ---------------------------------------------------------------------------------------//
 284          void GUDPDAT_Task(void)                                                                   //
 285          {
 286   1            byte id;                                                                            //
 287   1            uint temp;                                                                          //
 288   1      
 289   1            for (id = 0; id < GUDPDAT_MAX_CONNS; id++)                                          //
 290   1              {
 291   2              switch (gudpdat_Conns[id].State)                                                  //
 292   2                {
 293   3                case GUDPDAT_STATE_FREE :                                                       //
 294   3                    if (gudpdat_UdpClient == TRUE)                                              //
 295   3                      {
 296   4                      gudpdat_Client(id);                                                       //
 297   4                      }
 298   3                    break;                                                                      //
 299   3                case GUDPDAT_STATE_CONNECTING :                                                 //
C51 COMPILER V8.06   GUDPDAT                                                               03/10/2026 15:30:59 PAGE 78  

 300   3                    if (gudpdat_UdpClient == TRUE)                                              //
 301   3                      {
 302   4                      gudpdat_Conns[id].State = GUDPDAT_STATE_CONNECTED;                        //
 303   4                      }
 304   3                    break;                                                                      //
 305   3                case GUDPDAT_STATE_CONNECTED :                                                  //
 306   3                    {
 307   4                    temp = gudpdat_GetData(id);                                                 //
 308   4                    gudpdat_SendData(id);                                                       //
 309   4                    gudpdat_MaintainConnection(id);                                             //
 310   4                    }
 311   3                    break;                                                                      //
 312   3                default:                                                                        //
 313   3                    break;                                                                      //
 314   3                }
 315   2              }
 316   1      } // End of GUDPDAT_Task() //
