 183          // ---------------------------------------------------------------------------------------//
 184          // name    : gudpdat_GetData()                                                            //
 185          // Purpose : transfer data from the main loop buffer into the TOE buffer                  //
 186          // Params  : socket id                                                                    //
 187          // Returns : the number of bytes still left in the main loop buffer                       //
 188          // Note    :                                                                              //
 189          // ---------------------------------------------------------------------------------------//
 190          uint gudpdat_GetData(byte id)
 191          {
 192   1            byte dat;
 193   1            uint temp;
 194   1      
 195   1            temp = readEthTxBufCount();                                                         // 
 196   1            while (temp > 0)                                                                    // 
 197   1              {
 198   2              if (gudpdat_TxDatLen >= GUDPDAT_MAX_DATA_LEN)                                     // 
 199   2                break;                                                                          // 
 200   2              temp = main_readEthChar(&dat);                                                    // 
 201   2              gudpdat_TxBuf[gudpdat_TxDatLen++] = dat;                                          // 
 202   2              gudpdat_Conns[id].UrRxBytes++;                                                    // 
 203   2              }
 204   1            return temp;                                                                        // 
 205   1      } // End of gudpdat_GetData() //
 206          
 207          // ---------------------------------------------------------------------------------------//
 208          // name    : gudppdat_MaintainConnection()                                                //
 209          // Purpose : Maintain connection with host                                                //
 210          // Params  : socket id                                                                    //
 211          // Returns : void                                                                         //
 212          // Note    :                                                                              //
 213          // ---------------------------------------------------------------------------------------//
 214          void gudpdat_MaintainConnection(byte id)
 215          {
 216   1            ulong time;
 217   1            time = SWTIMER_Tick();
 218   1            
 219   1      // Maintain the connection: send ARP request each GUDPDAT_MAIN_CONNECT_TIME //
 220   1            if (time >= gudpdat_Conns[id].Timer)
 221   1              elapse = time - gudpdat_Conns[id].Timer;
 222   1            else
 223   1              elapse = (0xFFFFFFFF - gudpdat_Conns[id].Timer) + time;
 224   1            
 225   1            if (elapse >= GUDPDAT_MAIN_CONNECT_TIME)
 226   1              {
 227   2              if ((STOE_GetIPAddr() & STOE_GetSubnetMask()) != (gudpdat_Conns[id].Ip & STOE_GetSubnetMask()))
 228   2                {
 229   3                ETH_SendArpRequest(STOE_GetGateway());
 230   3                }
 231   2              else
 232   2                {
 233   3                ETH_SendArpRequest(gudpdat_Conns[id].Ip);
 234   3                }
 235   2              gudpdat_Conns[id].Timer = time;
 236   2              }
 237   1      } // End of gudpdat_MaintainConnection() //
C51 COMPILER V8.06   GUDPDAT                                                               03/10/2026 15:30:59 PAGE 77  

 238          
 239          // ---------------------------------------------------------------------------------------//
 240          // name    : gudpdat_SendData()                                                           //
 241          // Purpose : send any data to the host                                                    //
 242          // Params  : socket id                                                                    //
 243          // Returns : void                                                                         //
 244          // Note    :                                                                              //
 245          // ---------------------------------------------------------------------------------------//
 246          void gudpdat_SendData(byte id)
 247          {
 248   1            ulong elapse, time;
 249   1      
 250   1            if (gudpdat_TxDatLen >= GUDPDAT_MAX_DATA_LEN)
 251   1              {
 252   2              TCPIP_UdpSend(gudpdat_Conns[id].UdpSocket, 0, 0, gudpdat_TxBuf, GUDPDAT_MAX_DATA_LEN);
 253   2              gudpdat_TxDatLen = 0;                                                             //
 254   2              gudpdat_TxWaitTime = 0;
 255   2              }
 256   1            else if (gudpdat_TxDatLen > 0)
 257   1              {
 258   2              time = SWTIMER_Tick();
 259   2              if (gudpdat_TxWaitTime == 0)
 260   2                { gudpdat_TxWaitTime = time; }
 261   2              else
 262   2                {
 263   3                if (time >= gudpdat_TxWaitTime)
 264   3                  elapse = time - gudpdat_TxWaitTime;
 265   3                else
 266   3                  elapse = (0xFFFFFFFF - gudpdat_TxWaitTime) + time;
 267   3                if ((elapse * SWTIMER_INTERVAL) >= gudpdat_EthernetTxTimer)
 268   3                  {
 269   4                  TCPIP_UdpSend(gudpdat_Conns[id].UdpSocket, 0, 0, gudpdat_TxBuf, gudpdat_TxDatLen);
 270   4                  gudpdat_TxDatLen   = 0;
 271   4                  gudpdat_TxWaitTime = 0;
 272   4                  }
 273   3                }
 274   2              }
 275   1      } // End of gudpdat_SendData() //
