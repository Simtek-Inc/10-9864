 137          // ---------------------------------------------------------------------------------------//
 138          // name    : gudpdat_Client()                                                             //
 139          // Purpose : create a client connection with the host                                     //
 140          // Params  : socket id                                                                    //
 141          // Returns : void                                                                         //
 142          // Note    :                                                                              //
 143          // ---------------------------------------------------------------------------------------//
 144          void gudpdat_Client(byte id)                                                              // 
 145          {
 146   1            ulong dip;
 147   1            byte tmp;
 148   1      
 149   1            if (GS2E_GetTaskState() != GS2E_STATE_UDP_DATA_PROCESS)                             // 
 150   1              {
 151   2              uint   dport = GCONFIG_GetClientDestPort();                                       // get the host 
             -server port number
 152   2              dip = GCONFIG_GetClientDestIP();                                                  // get the host 
             -server ip address
 153   2              // get destination ip //
 154   2              if (dip == 0)                                                                     // 
 155   2                return;
 156   2              if (gudpdat_Conns[id].State == GUDPDAT_STATE_FREE)                                // confirm that 
             -the socket is free
 157   2                {
 158   3                gudpdat_Conns[id].State = GUDPDAT_STATE_CONNECTING;                             // set the task 
             -state to connecting
 159   3                gudpdat_Conns[id].Timer = SWTIMER_Tick();                                       // save the curr
             -ent time count
 160   3                gudpdat_Conns[id].Ip = dip;                                                     // save the IP a
             -ddress
 161   3                gudpdat_Conns[id].Port = dport;                                                 // save the port
             - number
 162   3                gudpdat_Conns[id].UdpSocket = TCPIP_UdpNew(gudpdat_InterAppId,                  //
 163   3                                                           id,                                  // socket id
 164   3                                                           dip,                                 // host ip addre
             -ss
 165   3                                                           GUDPDAT_GetRandomPortNum(),          // random port
 166   3                                                           dport);                              // host server p
             -ort
 167   3                // Send ARP request to build IP/MAC entry in ARP table //
 168   3                if ((STOE_GetIPAddr() & STOE_GetSubnetMask()) != (dip & STOE_GetSubnetMask()))  //
 169   3                  dip = STOE_GetGateway();                                                      // 
 170   3                ETH_SendArpRequest(dip);                                                        // send an ARP m
             -essage to the host
 171   3                GS2E_SetTaskState(GS2E_STATE_UDP_DATA_PROCESS);                                 // set the task 
             -state
 172   3                tmp = printd("UDP host client port    : ");                                     //
 173   3                if(gudpdat_Conns[id].UdpSocket == TCPIP_NO_NEW_CONN)                            // check to make
             - sure the socket was created
 174   3                  printd("**ERROR! UNABLE TO CREATE SOCKET**\n\r");                             // let the user 
             -know the the port is not initailized, there was an error
 175   3                else
 176   3                  {
C51 COMPILER V8.06   GUDPDAT                                                               03/10/2026 15:30:59 PAGE 76  

 177   4                  printd("%du\n\r", (uint) dport);                                              // print the por
             -t number
 178   4                  }          
 179   3                }
 180   2              }
 181   1      }
