  23      =2  #ifndef TYPES_H
           =2 #define TYPES_H
           =2 
           =2 typedef unsigned short int          bool;                                                 // boolean
           =2 typedef unsigned char               byte;                                                 //  8-bit unsign
             -ed
           =2 typedef unsigned short int          uint;                                                 // 16-bit unsign
             -ed
           =2 typedef short int                   sint;                                                 // 16-bit signed
           =2 typedef unsigned long               ulong;                                                // 32-bit unsign
             -ed
           =2 typedef unsigned short int          word;                                                 // 16-bit unsign
             -ed
           =2 
           =2 #ifndef NULL
           =2   #define NULL ((void *) 0L)
           =2 #endif
           =2 
           =2 #define TRUE                  1
           =2 #define FALSE                 0
           =2 #define ON                    1
           =2 #define OFF                   0
           =2 #define Client                1
           =2 #define Server                0
           =2 
           =2 // Bit Definitions for Bitwise Operation //
           =2 #define BIT0            0x01
           =2 #define BIT1            0x02
           =2 #define BIT2            0x04
           =2 #define BIT3            0x08
C51 COMPILER V8.06   GUDPDAT                                                               03/10/2026 15:30:59 PAGE 19  

           =2 #define BIT4            0x10
           =2 #define BIT5            0x20
           =2 #define BIT6            0x40
           =2 #define BIT7            0x80
           =2 #define BIT8            0x0100
           =2 #define BIT9            0x0200
           =2 #define BIT10           0x0400
           =2 #define BIT11           0x0800
           =2 #define BIT12           0x1000
           =2 #define BIT13           0x2000
           =2 #define BIT14           0x4000
           =2 #define BIT15           0x8000
           =2 #define BIT16           0x00010000
           =2 #define BIT17           0x00020000
           =2 #define BIT18           0x00040000
           =2 #define BIT19           0x00080000
           =2 #define BIT20           0x00100000
           =2 #define BIT21           0x00200000
           =2 #define BIT22           0x00400000
           =2 #define BIT23           0x00800000
           =2 #define BIT24           0x01000000
           =2 #define BIT25           0x02000000
           =2 #define BIT26           0x04000000
           =2 #define BIT27           0x08000000
           =2 #define BIT28           0x10000000
           =2 #define BIT29           0x20000000
           =2 #define BIT30           0x40000000
           =2 #define BIT31           0x80000000
           =2 
           =2 #define LOW_BYTE(dat)   (byte) (dat & 0x00FF)
           =2 #define HIGH_BYTE(dat)  (byte)((dat & 0xFF00) >> 8)
           =2 
           =2 #define U32BYTE0(dat)   (byte) (dat  & 0x000000FF)
           =2 #define U32BYTE1(dat)   (byte)((dat  & 0x0000FF00) >> 8)
           =2 #define U32BYTE2(dat)   (byte)((dat  & 0x00FF0000) >> 16)
           =2 #define U32BYTE3(dat)   (byte)((dat  & 0xFF000000) >> 24)
           =2  
           =2 // Keil compiler user define //
           =2 #define     KEIL_CPL
           =2 
           =2 #ifdef KEIL_CPL
           =2  #define XDATA    xdata
           =2  #define IDATA    idata
           =2  #define BDATA    bdata
           =2  #define CODE     code
           =2  #define FAR      far
           =2 #else
           =2  #define XDATA
           =2  #define IDATA
           =2  #define BDATA
           =2  #define CODE
           =2  #define FAR
           =2 #endif
           =2 
           =2 // Serial interface command direction //
           =2 #define     SI_WR                   BIT0
           =2 #define     SI_RD                   BIT1
           =2 
           =2 #define     FLASH_WR_ENB            (PCON |= PWE_)
           =2 #define     FLASH_WR_DISB           (PCON &= ~PWE_)
           =2 
           =2 #endif  // end of TYPES_H //
