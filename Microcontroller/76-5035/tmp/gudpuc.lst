 121          void GUDPUC_Init(uint localPort)
 122          {
 123   1              byte    i;
 124   1      
 125   1              for (i = 0; i < GUDPUC_MAX_CONNS; i++)
 126   1                gudpuc_Conns[i].State = GUDPUC_STATE_FREE;
 127   1              gudpuc_InterAppId = TCPIP_Bind(GUDPUC_NewConn, GUDPUC_Event, GUDPUC_Receive);
 128   1              // unicast packet //
 129   1              printd("UDP unicast port        : ");                                           // let the user kn
             -ow the the port is initailization attempt
 130   1              if (gudpuc_InterAppId == TCPIP_NO_NEW_CONN)                                         // check if the bindi
             -ng failed
C51 COMPILER V8.06   GUDPUC                                                                03/10/2026 15:31:00 PAGE 60  

 131   1              printd(" **BINDING ERROR!**\n\r");                                                // FAILED
 132   1            else
 133   1              {
 134   2      //        printd("ok. port : ");                                                           // ip binding c
             -ompleted!
 135   2              i = TCPIP_UdpListen(localPort, gudpuc_InterAppId);                                // attempt to se
             -t the listening port for the binding
 136   2              if(i == 1)                                                                        // if 1 the suce
             -ssful, else failed
 137   2                printd("%du\n\r",localPort);                                                    // set listen so
             -cket completed!
 138   2              else
 139   2                printd("* BINDING ERROR! *\n\r");                                               // set listen so
             -cket FAILED! socket ERROR
 140   2              }
 141   1      } // End of GUDPUC_Init() //
