 150          byte GUDPUC_NewConn(ulong XDATA* pip, uint remotePort, byte socket)
 151          {
 152   1              byte    i;
 153   1      
 154   1              pip = pip;
 155   1              remotePort = remotePort;        
 156   1              for (i = 0; i < GUDPUC_MAX_CONNS; i++)
 157   1                {
 158   2                if (gudpuc_Conns[i].State != GUDPUC_STATE_FREE)
 159   2                  TCPIP_UdpClose(gudpuc_Conns[i].UdpSocket); //tony 2009-4-20
 160   2                gudpuc_Conns[i].State = GUDPUC_STATE_CONNECTED;
 161   2                gudpuc_Conns[i].UdpSocket = socket;
 162   2                return i;
 163   2                }
 164   1              return GUDPUC_NO_NEW_CONN;
 165   1      } // End of GUDPUC_NewConn() //
