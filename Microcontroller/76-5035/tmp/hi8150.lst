 171          void writeHI8150(byte dat[5])
 172          {
 173   1          byte i, j;
 174   1          byte temp;
 175   1      
 176   1          HI8150CS   = 1;
 177   1          HI8150CLK  = 1;
 178   1          HI8150LD = 1;
 179   1      
 180   1          // ----- start -----
 181   1          HI8150CS   = 0;
 182   1          HI8150LD = 0;
