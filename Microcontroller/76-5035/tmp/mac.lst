 489          //-----------------------------------------------------------------------------
 490          // name    : mac_ComputeCrc32
 491          // purpose :
 492          // params  :
 493          // returns :
 494          // note    :
 495          // ----------------------------------------------------------------------------
 496          ulong mac_ComputeCrc32(uint length, byte* pbuf)
 497          {
 498   1              ulong   crc32 = 0xffffffff;
 499   1              byte    curByte, carry, j;
 500   1              
 501   1              for (; length; length--)
 502   1              {
 503   2                      curByte = *pbuf++;
 504   2                      for (j=0; j<8; j++)
 505   2                      {
 506   3                              carry = curByte & 1;
 507   3                              if ( crc32 & 0x80000000 )
 508   3                                      carry ^= 1;
 509   3                              crc32 <<= 1;
 510   3                              curByte >>= 1;
 511   3                              if (carry)
 512   3                                      crc32 ^= 0x04c11db7;
 513   3                      }
 514   2              }
 515   1              return crc32;
 516   1      
 517   1      } // End of mac_ComputeCrc32() //
