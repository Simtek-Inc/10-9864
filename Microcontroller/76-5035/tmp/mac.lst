 127   2                      PBDP->MacInfo.MediumLinkType|=(MEDIUM_FULL_DUPLEX_MODE | MEDIUM_MII_100M_MODE |
 128   2                              MEDIUM_ENABLE_RX_FLOWCTRL);
 129   2                      break;
 130   2              case FIXED_100_HALF:
