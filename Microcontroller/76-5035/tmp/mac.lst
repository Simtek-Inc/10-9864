 108   1              mac_StopOperate();
 109   1      
 110   1              if (network_type != FORCE_EMBEDDED_PHY_10_HALF)
 111   1              {
 112   2                      // phy initialize. //
 113   2                      PHY_Init(network_type);
 114   2              }
 115   1              PBDP->MacInfo.MediumLinkType = MEDIUM_ENABLE_TX_FLOWCTRL;
 116   1              PBDP->MacInfo.FullDuplex = 1;
 117   1              switch (network_type)
 118   1              {
 119   2              default:
 120   2              case AUTO_NEGOTIATION:
 121   2                      PBDP->MacInfo.NetworkType = MAC_AUTO_NEGOTIATION;
 122   2                      PBDP->MacInfo.MediumLinkType|=(MEDIUM_FULL_DUPLEX_MODE | MEDIUM_MII_100M_MODE |
