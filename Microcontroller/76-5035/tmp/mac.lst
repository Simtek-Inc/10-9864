 519          // ----------------------------------------------------------------------------
 520          // name    : MAC_MultiFilter
 521          // purpose :
 522          // params  :
 523          // returns :
 524          // note    :
 525          // ----------------------------------------------------------------------------
 526          void MAC_MultiFilter(byte* pbuf, byte len)
 527          {
 528   1              byte    count = len/MAC_ADDRESS_LEN;
 529   1              byte    index, bitNum;
 530   1              byte    filter[8] = {0};
 531   1      
 532   1              for (index = 0; index < count; index++)
 533   1              {
 534   2                      if (!(pbuf[0] & 1))
 535   2                              break;
 536   2      
 537   2                      bitNum = (byte)((mac_ComputeCrc32(MAC_ADDRESS_LEN, pbuf)>>26)&0x3f);
 538   2                      pbuf += MAC_ADDRESS_LEN;
 539   2                      filter[7 - (bitNum/8)] |= (1 << (bitNum % 8));
 540   2              }
 541   1      
 542   1              mac_WriteReg(MAC_MULTICASE_REG, filter, 8);
 543   1      
 544   1      } // End of MAC_MultiFilter() //
