 394          // ----------------------------------------------------------------------------
 395          // name    : mac_LinkSpeedChk
 396          // Purpose       :
 397          // Params        : none
 398          // Returns       : 100 : Ethernet is link to 100M
 399          //                      10 : Ethernet is link to 10M
 400          //                      0  : not link
 401          // note    :
 402          // ----------------------------------------------------------------------------
 403          byte mac_LinkSpeedChk(void)
 404          {
 405   1              if (mac_InterruptStatus & STATUS_PRIMARY_IS_LINK_UP)
 406   1              {
 407   2                      mac_InterruptStatus = 0;
 408   2                      if (PBDP->MacInfo.NetworkType != MAC_FORCE_ENBEDDED_PHY_10_HALF)
 409   2                      {
 410   3                              mac_GetMediaType();
 411   3                      }
 412   2                      else
 413   2                      {
 414   3                              PBDP->MacInfo.FullDuplex = 0;
 415   3                              PBDP->MacInfo.LinkSpeed = 10;
 416   3      
 417   3                              PBDP->MacInfo.MediumLinkType = MEDIUM_ENABLE_RECEIVE;
 418   3                              mac_WriteReg(MAC_MEDIUM_STATUS_MODE_REG, &PBDP->MacInfo.MediumLinkType, 1);
 419   3                      }
 420   2      
 421   2                      // start operation //
 422   2                      mac_StartOperate();
 423   2                      DELAY_Ms(0x30);
 424   2              }
 425   1              else
 426   1              {
 427   2                      mac_InterruptStatus = 0;                
 428   2                      if (PBDP->MacInfo.LinkSpeed)
 429   2                      {
 430   3                              PBDP->MacInfo.LinkSpeed = 0;
 431   3      
 432   3                              // disable receive //
 433   3                              PBDP->MacInfo.MediumLinkType &= ~MEDIUM_ENABLE_RECEIVE;
 434   3                              mac_WriteReg(MAC_MEDIUM_STATUS_MODE_REG, &PBDP->MacInfo.MediumLinkType, 1);
 435   3      
 436   3                              STOE_WaitHwReleaseRcvBuf();
 437   3      
 438   3                              // stop operation and reset Ethernet MAC packet buffer //
 439   3                              mac_StopOperate();
 440   3      
 441   3                              if (PBDP->MacInfo.NetworkType != MAC_FORCE_ENBEDDED_PHY_10_HALF)
 442   3                              {
 443   4                                      PHY_WatchDog();
 444   4                              }
 445   3                      }
 446   2              }
 447   1      
 448   1              return PBDP->MacInfo.LinkSpeed;
 449   1      
 450   1      } // End of mac_LinkSpeedChk //
