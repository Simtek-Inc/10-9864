 104   1              temp[0] = (PHY_SELECT_EMBEDDED | PHY_INTERNAL_PHY_OPERA_STATE | BIT1);
 105   1              mac_WriteReg(MAC_PHY_CTL_REG, temp, 1);
 106   1      
