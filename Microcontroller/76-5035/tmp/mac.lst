 339          // ----------------------------------------------------------------------------
 340          // name    : mac_GetMediaType
 341          // purpose :
 342          // params  :
 343          // returns :
 344          // note    :
 345          // ----------------------------------------------------------------------------
 346          byte mac_GetMediaType(void)
 347          {
 348   1              uint    phylinkstatus;
 349   1      
 350   1              phylinkstatus = PHY_CheckMediaType();
 351   1      
 352   1              PBDP->MacInfo.FullDuplex = TRUE;
 353   1      
 354   1              PBDP->MacInfo.MediumLinkType = (MEDIUM_ENABLE_TX_FLOWCTRL | MEDIUM_ENABLE_RECEIVE);
 355   1      
 356   1              // Determine if we're linked to 100 full duplex. //
 357   1              if (phylinkstatus & ANLPAR_100TXFD)
 358   1              {
 359   2                      PBDP->MacInfo.LinkSpeed = 100;
 360   2                      PBDP->MacInfo.MediumLinkType |=(MEDIUM_FULL_DUPLEX_MODE |MEDIUM_MII_100M_MODE);
 361   2      //              printd ("Link to 100 FULL.\n\r");
 362   2              }
 363   1              // Determine if we're linked to 100 half duplex. //
 364   1              else if (phylinkstatus & ANLPAR_100TX)
 365   1              {
 366   2                      PBDP->MacInfo.LinkSpeed = 100;
 367   2                      PBDP->MacInfo.MediumLinkType |= MEDIUM_MII_100M_MODE;
 368   2                      PBDP->MacInfo.FullDuplex = FALSE;
 369   2      //              printd ("Link to 100 HALF.\n\r");
 370   2              } 
 371   1              // Determine if we're linked to 10 full duplex. //
 372   1              else if (phylinkstatus & ANLPAR_10TFD)
 373   1              {
 374   2                      PBDP->MacInfo.LinkSpeed = 10;
 375   2                      PBDP->MacInfo.MediumLinkType |= MEDIUM_FULL_DUPLEX_MODE;
 376   2      //              printd ("Link to 10 FULL.\n\r");
 377   2              }
 378   1              // we're linked to 10 half duplex. //
 379   1              else
 380   1              {
 381   2                      PBDP->MacInfo.LinkSpeed = 10;
 382   2                      PBDP->MacInfo.FullDuplex = FALSE;
 383   2      //              printd ("Link to 10 HALF.\n\r");
 384   2              }
 385   1      
 386   1              if (PBDP->MacInfo.FullDuplex)
 387   1                      PBDP->MacInfo.MediumLinkType |= MEDIUM_ENABLE_RX_FLOWCTRL;
 388   1              mac_WriteReg(MAC_MEDIUM_STATUS_MODE_REG, &PBDP->MacInfo.MediumLinkType, 1);
 389   1      
 390   1              return PBDP->MacInfo.LinkSpeed;
 391   1      
 392   1      } // End of mac_GetMediaType //
