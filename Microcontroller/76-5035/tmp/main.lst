           =2 #define BIT0            0x01
           =2 #define BIT1            0x02
           =2 #define BIT2            0x04
           =2 #define BIT3            0x08
           =2 #define BIT4            0x10
           =2 #define BIT5            0x20
           =2 #define BIT6            0x40
           =2 #define BIT7            0x80
           =2 #define BIT8            0x0100
           =2 #define BIT9            0x0200
           =2 #define BIT10           0x0400
           =2 #define BIT11           0x0800
           =2 #define BIT12           0x1000
