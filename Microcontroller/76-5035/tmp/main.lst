 906          // name    : UpdateIpSettings                                                             //
 907          // purpose :                                                                              //
 908          // params  : void                                                                         //
 909          // returns : void                                                                         //
 910          // notes   :                                                                              //
 911          //---------------------------------------------------------------------------------------- 
 912          void UpdateIpSettings(ulong ip)                                                           // Update IP add
             -ress, subnet mask, gateway IP address and DNS IP address
 913          {                                                                                         //
 914   1            if (ip > 0)                                                                         // check the IP 
             -to see if it is valid
 915   1              {                                                                                 //
 916   2              printd("IP  : %bu.%bu.%bu.%bu\n\r", (byte) ((ip >> 24) & 0x000000FF),             // write the IP 
             -address to the user debug port
 917   2                                                  (byte) ((ip >> 16) & 0x000000FF),             //
 918   2                                                  (byte) ((ip >> 8)  & 0x000000FF),             //
 919   2                                                  (byte) ( ip        & 0x000000FF));            //
 920   2              }                                                                                 //
 921   1            else                                                                                // the IP was va
             -lid
 922   1              if (ip == 0)                                                                      // check the IP 
             -to see if it is valid
 923   1                {                                                                               //
 924   2                ulong mask = GCONFIG_GetNetmask();                                              // retrieve the 
             -default net mask
 925   2                ip = GCONFIG_GetServerStaticIP();                                               // retrieve the 
             -static IP
 926   2                TCPIP_SetIPAddr(ip);                                                            // write the def
             -ault IP addess into the DCB
 927   2                STOE_SetIPAddr(ip);                                                             // write the def
             -ault IP addess into the DCB
 928   2                TCPIP_SetSubnetMask(mask);                                                      // write the def
             -ault net mask into the DCB
 929   2                STOE_SetSubnetMask(mask);                                                       // write the def
             -ault net mask into the DCB
 930   2                }                                                                               //
C51 COMPILER V8.06   MAIN                                                                  03/10/2026 15:30:57 PAGE 122 

 931   1            GS2E_Init();                                                                        //
 932   1      } // End of UpdateIpSettings //                                                           //
