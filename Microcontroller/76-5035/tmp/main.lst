 390          //----------------------------------------------------------------------------------------
 391          // name    : wrEthTxBuffer(byte ch, uint Count)                                           //
 392          // purpose : write data to the ring buffer to transmit over Ethernet                      //
 393          // params  : Data byte to write, Count of bytes currently in buffer                       //
 394          // returns : updated count of bytes in buffer                                             //
 395          // notes   :                                                                              //
 396          //----------------------------------------------------------------------------------------
 397          uint wrChrEthTxBuffer(byte ch, uint Count)                                                // write data to
             - the ethernet transmit buffer
 398          {
 399   1            EthTxBuffer[EthTxBufIndx] = ch;                                                     // add the data 
             -to the ethernet buffer
 400   1            EthTxBufIndx++;                                                                     // update the et
             -hernet buffer index
 401   1            Count++;                                                                            // update the co
             -unt showing the number of bytes in the buffer
 402   1            if (EthTxBufIndx == EthMaxTxSize)                                                   // check to see 
             -if the index is at the maximum
 403   1              EthTxBufIndx = 0;                                                                 // reset the ind
             -ex to the first byte of the buffer
 404   1            return Count;                                                                       // pass the buff
             -er count back to the calling routine
 405   1      }
 406          
 407          //----------------------------------------------------------------------------------------
 408          // name    : wrStrEthTxBuffer(byte* pData, uint cnt)                                      //
 409          // purpose : write data to the ring buffer to transmit over Ethernet                      //
 410          // params  : pointer to the data bytes to write, number of bytes to write                 //
 411          // returns : number of bytes sucessfully written into the buffer                          //
 412          // notes   :                                                                              //
 413          //----------------------------------------------------------------------------------------
 414          uint wrStrEthTxBuffer(byte* pData, uint cnt)                                              // write data to
             - the ethernet transmit buffer
 415          {
 416   1            uint TmpCnt;                                                                        //
 417   1            uint offset;                                                                        //
 418   1      
 419   1            if((EthTxBufIndx + cnt) > EthMaxTxSize)                                             // make sure tha
             -t the number of bytes to write added to the number
 420   1            {                                                                                   //  of bytes in 
             -the buffer already is not greater then the buffer
 421   2              offset = EthMaxTxSize - EthTxBufIndx;                                             // find the numbe
             -r of bytes that will fit in the buffer before overflow
 422   2              memmove(&EthTxBuffer[EthTxBufIndx], pData, offset);                               // fill the rema
             -inder of the buffer with the given data
 423   2              memmove(&EthTxBuffer[ix01], pData+offset, cnt - offset);                          // add the remai
             -nder of the given data to the begining of the buffer
 424   2                }
 425   1            else                                                                                // else all of t
             -he given data will still fit in the buffer
 426   1            {
 427   2              memmove(&EthTxBuffer[EthTxBufIndx], pData, cnt);                                  // place all of 
C51 COMPILER V8.06   MAIN                                                                  03/10/2026 15:30:57 PAGE 113 

             -the given data into the buffer
 428   2                }
 429   1            EthTxBufIndx += cnt;                                                                // make sure tha
             -t the index points at the first empty byte
 430   1            EthTxBufIndx &= EthMaxTxMask;                                                       // mask the inde
             -x to wrap the buffer around into a ring
 431   1            TmpCnt = readEthTxBufCount() + cnt;                                                 // adjust the cu
             -rrent buffer count  
 432   1                writeEthTxCount(TmpCnt);
 433   1            return TmpCnt;                                                                      // return the nu
             -mber of bytes in the buffer
 434   1      }
