1020          // notes   :                                                                              //
1021          //----------------------------------------------------------------------------------------
1022          ulong setupEthernet(byte enabled)
1023          {
1024   1          ulong ip;                                                                             //
1025   1          ulong mask;                                                                           //
1026   1          byte  cmdDhcpFlag      = 0;                                                           //
1027   1          ulong dhcpTimeStart    = 0;                                                           //
1028   1          ulong swtc;                                                                           //
1029   1      
1030   1          if(enabled == TRUE)                                                                   //
1031   1            {
1032   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
