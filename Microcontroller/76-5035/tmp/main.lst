1092   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1093   2            DELAY_Ms(1000);                                                                     // wait 1S to gi
             -ve the internal hardware time to start up
1094   2            while(cmdDhcpFlag == 1)                                                             // check the DHC
             -P flag to see if the DHCP process has completed
1095   2              {
