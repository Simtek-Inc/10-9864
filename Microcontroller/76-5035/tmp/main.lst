1071   3      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1072   3              printd("DHCP     init           : ");                                             //
1073   3              if (DHCP_Init())                                                                  //
1074   3                printd("pass\n\r");                                                             //
1075   3              else
1076   3                printd("**ERROR**\n\r");                                                        //
1077   3              printd("DHCP Assigned IP    : ");                                                 // tell user tha
             -t the DHCP process has started
1078   3      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1079   3      //    start the DHCP engine                                                               //
1080   3      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1081   3              DHCP_Start();                                                                     // start the DHC
             -P process
1082   3              cmdDhcpFlag   = 1;                                                                // set the DHCP 
             -initailization flag to start
1083   3              dhcpTimeStart = SWTIMER_Tick();                                                   // record the DH
             -CP process start time
1084   3              }
1085   2            else                                                                                //
1086   2              {
