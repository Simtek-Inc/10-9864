 448          //----------------------------------------------------------------------------------------
 449          // name    : main_readEthChar(byte* pDat)                                                 //
 450          // purpose : retrieve data from buffer to place in ethernet transmit buffer               //
 451          // params  : pointer to variable to return                                                //
 452          // returns : count of data left in buffer                                                 //
 453          // notes   : this routine replaced GetEthChar defined in main.c.                          //
 454          //----------------------------------------------------------------------------------------
 455          uint main_readEthChar(byte* pDat)                                                         // read a data b
             -yte from the ethernet buffer
 456          {
 457   1            uint temp;                                                                          //
 458   1            
 459   1            temp = readEthTxBufCount();                                                         // get the curre
             -nt ethernet buffer count
 460   1            if (temp > 0)                                                                       // see if there 
             -are any bytes in the buffer
 461   1              {
 462   2              *pDat = EthTxBuffer[EthTxBufTail];                                                // write the dat
             -a to the location pointed to by the pointer
 463   2              EthTxBufTail++;                                                                   // update the et
             -hernet ring buffer index
 464   2              if (EthTxBufTail == EthMaxTxSize)                                                 // check the ind
             -ex to make sure that the index remains within the buffer space 
 465   2                {  EthTxBufTail = 0;  }                                                         // reset the ind
             -ex to the first byte of the buffer
 466   2              EthTxCount--;                                                                     // update the co
             -unt of the bytes in the buffer
 467   2              return EthTxCount;                                                                // pass the alte
             -red count back to the calling routine
 468   2              }
 469   1            return 0;                                                                           // write the def
             -ault value for the count
 470   1      }
