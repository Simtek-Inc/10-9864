1037   2      //          initailize the device configurationnitialization                              //
1038   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1039   2            GCONFIG_Init();                                                                     //
1040   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1041   2      //          iniailize the software timer                                                  //
1042   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1043   2            SWTIMER_Init();                                                                     //
1044   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1045   2      //          enable transmit socket for runtime mode                                       //
1046   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1047   2            gudpdat_ClientOpen(TrxSocket);                                                      //
1048   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1049   2      //          Start the Ethernet Engine and Software Timer for DMA                          //
1050   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1051   2            ETH_Start();                                                                        // start the eth
             -ernet process
1052   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1053   2      //          Start the Ethernet Engine and Software Timer for DMA                          //
1054   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1055   2            SWTIMER_Start();                                                                    // start the sof
             -tware timer
1056   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1057   2      //          initailize the hardware DCB                                                   //
1058   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1059   2            mask    = GCONFIG_GetNetmask();                                                     //
1060   2            ip      = GCONFIG_GetServerStaticIP();                                              //
1061   2            TCPIP_SetIPAddr(ip);                                                                //
1062   2            STOE_SetIPAddr(ip);                                                                 //
1063   2            TCPIP_SetSubnetMask(mask);                                                          //
1064   2            STOE_SetSubnetMask(mask);                                                           //
1065   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
1066   2      //          update device IP and port settings                                            //
1067   2            if ((GCONFIG_GetNetwork() & GCONFIG_NETWORK_DHCP_ENABLE) == GCONFIG_NETWORK_DHCP_ENABLE)
1068   2              {
