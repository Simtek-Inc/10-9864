 618   1              
 619   1              status_byte1 = readFpgaData(0x61,8);
 620   1              status_byte1 = ~status_byte1;
 621   1              bufStatusRsp[ix02] = status_byte1;
 622   1              if(status_byte1 != status_byte_1_prev) instant_flag++;
 623   1              
 624   1          status_byte2 = readFpgaData(0x62,8);        
 625   1              status_byte2 = ~status_byte2;
 626   1              bufStatusRsp[ix03] = status_byte2;
 627   1              if(status_byte2 != status_byte_2_prev) instant_flag++;
 628   1              
 629   1              status_byte3 = readFpgaData(0x63,8);    
 630   1              status_byte3 = ~status_byte3;   
 631   1              bufStatusRsp[ix04] = status_byte3;
C51 COMPILER V8.06   MAIN                                                                  03/10/2026 15:30:57 PAGE 117 

 632   1              if(status_byte3 != status_byte_3_prev) instant_flag++;
 633   1              
 634   1              status_byte4 = readFpgaData(0x64,8);
 635   1              status_byte4 = ~status_byte4;   
 636   1              bufStatusRsp[ix05] = status_byte4;
 637   1              if(status_byte4 != status_byte_4_prev) instant_flag++;
 638   1              
 639   1              status_byte5 = readFpgaData(0x65,8);                    
 640   1              bufStatusRsp[ix06] = status_byte5;      
 641   1              if(status_byte5 != status_byte_5_prev) instant_flag++;
 642   1              if(status_byte5 - status_byte_5_prev); 
 643   1              
 644   1              status_byte6 = readFpgaData(0x66,8);
 645   1              bufStatusRsp[ix07] = status_byte6;
 646   1              if( status_byte6 != status_byte_6_prev) instant_flag++;
 647   1              if(status_byte6 - status_byte_6_prev); 
 648   1      
 649   1              if(instant_flag > 0 || arp_flag > 0) 
 650   1              {
 651   2                        //printd("\n\r");
 652   2                        //printd(" %bx ", instant_flag);
 653   2                        //printd(" %bx ", arp_flag);
 654   2                        //printd(" %bx ", status_byte_5_prev);
 655   2                        //printd(" <--prev  current-->");
 656   2                        //printd(" %bx ", status_byte5);
 657   2                        //printd("\n\r");
 658   2                      wrHost(&command, 1);
 659   2                      wrHost(&status_byte1, 1);
 660   2                      wrHost(&status_byte2, 1);
 661   2                      wrHost(&status_byte3, 1);
 662   2                      wrHost(&status_byte4, 1);
 663   2                      wrHost(&status_byte5, 1);
 664   2                      wrHost(&status_byte6, 1);
 665   2                      instant_flag = 0;
 666   2                      arp_flag = 0;
 667   2              }
 668   1              status_byte_1_prev = status_byte1; 
 669   1              status_byte_2_prev = status_byte2;
 670   1              status_byte_3_prev = status_byte3;
 671   1              status_byte_4_prev = status_byte4;
 672   1              status_byte_5_prev = status_byte5;
 673   1              status_byte_6_prev = status_byte6;                                              
 674   1      }
