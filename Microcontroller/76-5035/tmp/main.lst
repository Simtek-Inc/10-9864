 990          //----------------------------------------------------------------------------------------
 991          // name    : processEthernetTraffic                                                       //
 992          // purpose : check for new Ethernet traffic and process new data                          //
 993          // params  : last software timer count, display link speed flag                           //
 994          // returns : current timer count                                                          //
 995          // notes   :                                                                              //
 996          //----------------------------------------------------------------------------------------
 997          ulong processEthernetTraffic(ulong ptc, dls)                                              //
 998          {
 999   1          ulong tc;                                                                             // current time 
             -count
1000   1          byte  linkSpeed = 0;                                                                  //
1001   1          
1002   1          tc              = (uint)SWTIMER_Tick();                                               // get the curre
             -nt timer count
1003   1          if ((tc - ptc) >= TIME_OUT_COUNTER)                                                   // see if the di
             -fference in the curent & last time differs more then the timeout
1004   1            {
1005   2            ptc           = tc;                                                                 // set the last 
             -time to the current time
1006   2            TCPIP_PeriodicCheck();                                                              // check the for
             - any TCPIP traffic
1007   2            }
1008   1          STOE_ProcessInterrupt();                                                              // process all T
             -OE buffers input/output
1009   1          if (MAC_GetInterruptFlag())                                                           // get the data 
             -for this device
1010   1            { linkSpeed   = MAC_ProcessInterruptExt(); }                                        // find the link
             -age speed, and process device traffic
1011   1          if(dls == ON) printd("Ethernet Link Speed = bps\n\r", linkSpeed);                     // display the l
             -inkage speed
1012   1          return ptc;                                                                           // return the cu
             -rrent timer count
1013   1      }
