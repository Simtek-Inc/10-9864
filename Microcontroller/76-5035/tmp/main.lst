             -r to port status
 972   1          if(fDebugMode == OFF)                                                                 // get the state
             - of the debug bit
 973   1            {
 974   2            if(fTransmitMode == Server)                                                         // get the state
             - of the client port bit
 975   2              printd("Server\n\r");                                                             // alert the use
             -r to port status
 976   2            else                                                                                //
 977   2              printd("Client\n\r");                                                             // alert the use
             -r to port status
 978   2            }
 979   1          else                                                                                  //
 980   1            printd("Server\n\r");                                                               // alert the use
             -r to port status
 981   1          gconfig_ExDisplayConfigData();                                                        //
