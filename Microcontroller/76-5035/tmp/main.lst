             - settings to the static IP and port
1088   3              cmdDhcpFlag   = 0;                                                                // set the DHCP 
C51 COMPILER V8.06   MAIN                                                                  03/10/2026 15:30:57 PAGE 125 

             -initailization flag to bypass
1089   3              }
1090   2      //~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~//
