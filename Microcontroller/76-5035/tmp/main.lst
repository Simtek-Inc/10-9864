           =1 #define __PHY_H__
           =1 
           =1 
           =1 // INCLUDE FILE DECLARATIONS //
           =1 #include "types.h"
           =1 
           =1 // internal phy id address //
           =1 #define PHY_ADDRESS                                     0x10
           =1 #define PHY_INTERNAL                            0
           =1 #define PHY_EXTERNAL                            1
           =1 
           =1 // network type //
           =1 #define AUTO_NEGOTIATION                        0
           =1 #define FIXED_100_FULL                          1
           =1 #define FIXED_100_HALF                          2
           =1 #define FIXED_10_FULL                           3
           =1 #define FIXED_10_HALF                           4
           =1 #define FORCE_EMBEDDED_PHY_10_HALF      5
           =1 
           =1 // NAMING CONSTANT DECLARATIONS //
           =1 // SFR 0xBE definitions //
           =1 #define PHY_READ_REG                            BIT7
           =1 #define PHY_ACCESS_GO                           BIT6
           =1 #define PHY_CMD_ABORT                           0xFF
           =1 
           =1 // MII register definitions //
           =1 #define MII_PHY_CONTROL                         0x00    // control reg
           =1 #define MII_PHY_STATUS                          0x01    // status reg
           =1 #define MII_PHY_OUI                                     0x02    // most of the OUI bits
           =1 #define MII_PHY_MODEL                           0x03    // model/rev bits, and rest of OUI
           =1 #define MII_PHY_ANAR                            0x04    // AN advertisement reg
           =1 #define MII_PHY_ANLPAR                          0x05    // AN Link Partner
           =1 #define MII_PHY_ANER                            0x06    // AN expansion reg
           =1 
           =1 // Bit definitions: MII Control //
           =1 #define CONTROL_RESET                           0x8000  // reset bit in control reg
           =1 #define CONTROL_LOOPBACK                        0x4000  // loopback bit in control reg
