  42          
  43          // ----------------------------------------------------------------------------
  44          // name    : SWTIMER_Timer
  45          // purpose : 
  46          // params  :
  47          // returns :
  48          // note    :
  49          // ----------------------------------------------------------------------------
  50          static void SWTIMER_Timer(void) interrupt 10
  51          {
  52   1                      byte    temp;
  53   1      
  54   1                      EINT5 = 0;
  55   1                      EIF &= ~INT5F;
  56   1                      temp = SDSTSR;
  57   1                      if (temp & SWTIMER_EXPIRED)
  58   1                              swtimer_Counter++;
  59   1                      EINT5 = 1;
  60   1      
  61   1      } // End of SWTIMER_Timer //
  62          
  63          // ----------------------------------------------------------------------------
  64          // name    : SWTIMER_Init
  65          // purpose : Initial software timer module.
  66          // params  :
  67          // returns :
  68          // note    :
  69          // ----------------------------------------------------------------------------
  70          void SWTIMER_Init(void)
  71          {
  72   1      #ifdef RuntimeCodeAt24KH
  73   1                      ExecuteRuntimeFlag |= 0x01;
  74   1      #endif
  75   1      
  76   1      } // End of SWTIMER_Init //
C51 COMPILER V8.06   MSTIMER                                                               03/10/2026 15:30:56 PAGE 21  

  77          
  78          // ----------------------------------------------------------------------------
  79          // name    : SWTIMER_Start
  80          // purpose : Enable and start software timer.
  81          // params  :
  82          // returns :
  83          // note    :
  84          // ----------------------------------------------------------------------------
  85          void SWTIMER_Start(void)
  86          {
  87   1              byte XDATA      temp[2];
  88   1      
  89   1              // set software timer //
  90   1              temp[1] = (byte)SWTIMER_INTERVAL;
  91   1              temp[0] = (byte)(SWTIMER_INTERVAL >> 8) + SWTIMER_START + SWTIMER_INT_ENABLE;
  92   1              DMA_WriteReg(SWTIMER_REG, temp, 2);
  93   1              EXTINT5(1);     // Enable INT5 interrupt for software timer. //
  94   1      } // End of SWTIMER_Start //
  95          
  96          #if (SWTIMER_STOP_FUNC == SWTIMER_SUPPORT_STOP_FUNC)
              // ----------------------------------------------------------------------------
              // name    : SWTIMER_Stop
              // purpose : Disable and Stop software timer.
              // params  :
              // returns :
              // note    :
              // ----------------------------------------------------------------------------
              void SWTIMER_Stop(void)
              {
                      byte XDATA      temp[2];
              
                      // set software timer //
                      temp[1] = (byte)SWTIMER_INTERVAL;
                      temp[0] = (byte)(SWTIMER_INTERVAL >> 8);
                      DMA_WriteReg(SWTIMER_REG, temp, 2);
              } // End of SWTIMER_Stop //
              #endif
 114          
 115          // ----------------------------------------------------------------------------
 116          // name    : SWTIMER_Tick
 117          // purpose : Get software timer count.
 118          // params  :
 119          // returns :
 120          // note    :
 121          // ----------------------------------------------------------------------------
 122          ulong SWTIMER_Tick(void)
 123          {
 124   1              ulong   timer;
 125   1              byte    isr;
 126   1      
 127   1              isr = EA;
 128   1              EA = 0;
 129   1              timer = swtimer_Counter;
 130   1              EA = isr;
 131   1              return timer;
 132   1      } // End of SWTIMER_Tick //
