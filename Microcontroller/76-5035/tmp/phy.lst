  23      =3  #ifndef TYPES_H
           =3 #define TYPES_H
           =3 
           =3 typedef unsigned short int          bool;                                                 // boolean
           =3 typedef unsigned char               byte;                                                 //  8-bit unsign
             -ed
           =3 typedef unsigned short int          uint;                                                 // 16-bit unsign
             -ed
           =3 typedef short int                   sint;                                                 // 16-bit signed
           =3 typedef unsigned long               ulong;                                                // 32-bit unsign
             -ed
           =3 typedef unsigned short int          word;                                                 // 16-bit unsign
             -ed
           =3 
           =3 #ifndef NULL
           =3   #define NULL ((void *) 0L)
           =3 #endif
           =3 
           =3 #define TRUE                  1
           =3 #define FALSE                 0
           =3 #define ON                    1
           =3 #define OFF                   0
           =3 #define Client                1
           =3 #define Server                0
           =3 
           =3 // Bit Definitions for Bitwise Operation //
           =3 #define BIT0            0x01
           =3 #define BIT1            0x02
           =3 #define BIT2            0x04
           =3 #define BIT3            0x08
           =3 #define BIT4            0x10
           =3 #define BIT5            0x20
           =3 #define BIT6            0x40
           =3 #define BIT7            0x80
           =3 #define BIT8            0x0100
           =3 #define BIT9            0x0200
           =3 #define BIT10           0x0400
           =3 #define BIT11           0x0800
           =3 #define BIT12           0x1000
           =3 #define BIT13           0x2000
           =3 #define BIT14           0x4000
           =3 #define BIT15           0x8000
           =3 #define BIT16           0x00010000
           =3 #define BIT17           0x00020000
           =3 #define BIT18           0x00040000
           =3 #define BIT19           0x00080000
           =3 #define BIT20           0x00100000
           =3 #define BIT21           0x00200000
           =3 #define BIT22           0x00400000
           =3 #define BIT23           0x00800000
           =3 #define BIT24           0x01000000
C51 COMPILER V8.06   PHY                                                                   03/10/2026 15:30:56 PAGE 18  

           =3 #define BIT25           0x02000000
           =3 #define BIT26           0x04000000
           =3 #define BIT27           0x08000000
           =3 #define BIT28           0x10000000
           =3 #define BIT29           0x20000000
           =3 #define BIT30           0x40000000
           =3 #define BIT31           0x80000000
           =3 
           =3 #define LOW_BYTE(dat)   (byte) (dat & 0x00FF)
           =3 #define HIGH_BYTE(dat)  (byte)((dat & 0xFF00) >> 8)
           =3 
           =3 #define U32BYTE0(dat)   (byte) (dat  & 0x000000FF)
           =3 #define U32BYTE1(dat)   (byte)((dat  & 0x0000FF00) >> 8)
           =3 #define U32BYTE2(dat)   (byte)((dat  & 0x00FF0000) >> 16)
           =3 #define U32BYTE3(dat)   (byte)((dat  & 0xFF000000) >> 24)
           =3  
           =3 // Keil compiler user define //
           =3 #define     KEIL_CPL
           =3 
           =3 #ifdef KEIL_CPL
           =3  #define XDATA    xdata
           =3  #define IDATA    idata
           =3  #define BDATA    bdata
           =3  #define CODE     code
           =3  #define FAR      far
           =3 #else
           =3  #define XDATA
           =3  #define IDATA
           =3  #define BDATA
           =3  #define CODE
           =3  #define FAR
           =3 #endif
           =3 
           =3 // Serial interface command direction //
           =3 #define     SI_WR                   BIT0
           =3 #define     SI_RD                   BIT1
           =3 
           =3 #define     FLASH_WR_ENB            (PCON |= PWE_)
           =3 #define     FLASH_WR_DISB           (PCON &= ~PWE_)
           =3 
           =3 #endif  // end of TYPES_H //
