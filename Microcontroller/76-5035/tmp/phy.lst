  20      =2  #ifndef __PHY_H__
           =2 #define __PHY_H__
           =2 
           =2 
           =2 // INCLUDE FILE DECLARATIONS //
           =2 #include "types.h"
           =2 
           =2 // internal phy id address //
           =2 #define PHY_ADDRESS                                     0x10
           =2 #define PHY_INTERNAL                            0
           =2 #define PHY_EXTERNAL                            1
           =2 
           =2 // network type //
           =2 #define AUTO_NEGOTIATION                        0
           =2 #define FIXED_100_FULL                          1
           =2 #define FIXED_100_HALF                          2
           =2 #define FIXED_10_FULL                           3
           =2 #define FIXED_10_HALF                           4
           =2 #define FORCE_EMBEDDED_PHY_10_HALF      5
           =2 
           =2 // NAMING CONSTANT DECLARATIONS //
           =2 // SFR 0xBE definitions //
           =2 #define PHY_READ_REG                            BIT7
           =2 #define PHY_ACCESS_GO                           BIT6
           =2 #define PHY_CMD_ABORT                           0xFF
           =2 
           =2 // MII register definitions //
           =2 #define MII_PHY_CONTROL                         0x00    // control reg
           =2 #define MII_PHY_STATUS                          0x01    // status reg
           =2 #define MII_PHY_OUI                                     0x02    // most of the OUI bits
           =2 #define MII_PHY_MODEL                           0x03    // model/rev bits, and rest of OUI
           =2 #define MII_PHY_ANAR                            0x04    // AN advertisement reg
           =2 #define MII_PHY_ANLPAR                          0x05    // AN Link Partner
           =2 #define MII_PHY_ANER                            0x06    // AN expansion reg
           =2 
           =2 // Bit definitions: MII Control //
           =2 #define CONTROL_RESET                           0x8000  // reset bit in control reg
           =2 #define CONTROL_LOOPBACK                        0x4000  // loopback bit in control reg
           =2 #define CONTROL_10MB                            0x0000  // 10 Mbit
           =2 #define CONTROL_100MB                           0x2000  // 100Mbit
           =2 #define CONTROL_ENABLE_AUTO                     0x1000  // autonegotiate enable
           =2 #define CONTROL_POWER_DOWN                      0x0800
           =2 #define CONTROL_ISOLATE                         0x0400  // islolate bit
           =2 #define CONTROL_START_AUTO                      0x0200  // restart autonegotiate
           =2 #define CONTROL_FULL_DUPLEX                     0x0100
           =2 
           =2 // Bit definitions: Auto-Negotiation Advertisement //
           =2 #define ANAR_PAUSE                                      0x0400  // support pause packets
           =2 #define ANAR_100T4                                      0x0200  // support 100BT4
           =2 #define ANAR_100TXFD                            0x0100  // support 100BTX full duplex
           =2 #define ANAR_100TX                                      0x0080  // support 100BTX half duplex
           =2 #define ANAR_10TFD                                      0x0040  // support 10BT full duplex
           =2 #define ANAR_10T                                        0x0020  // support 10BT half duplex
C51 COMPILER V8.06   PHY                                                                   03/10/2026 15:30:56 PAGE 23  

           =2 #define ANAR_SELECTOR_FIELD                     0x001F  // selector field.
           =2 #define ANAR_SELECTOR_8023                      0x0001
           =2 
           =2 // Bit definitions: Auto-Negotiation Link Partner Ability //
           =2 #define ANLPAR_PAUSE                            0x0400  // support pause packets
           =2 #define ANLPAR_100T4                            0x0200  // support 100BT4
           =2 #define ANLPAR_100TXFD                          0x0100  // support 100BTX full duplex
           =2 #define ANLPAR_100TX                            0x0080  // support 100BTX half duplex
           =2 #define ANLPAR_10TFD                            0x0040  // support 10BT full duplex
           =2 #define ANLPAR_10T                                      0x0020  // support 10BT half duplex
           =2 
           =2 // TYPE DECLARATIONS //
           =2 //---------------------------------------------------------------
           =2 typedef struct _PHY_INFORMATION
           =2 {
           =2         byte    PhyAddr;
           =2         byte    PhyType;
           =2 
           =2 } PHY_INFO;
           =2 
           =2 // EXPORTED SUBPROGRAM SPECIFICATIONS //
           =2 //---------------------------------------------------------------
           =2 void PHY_Init(byte);
           =2 uint PHY_CheckMediaType(void);
           =2 void PHY_PowerUp(void);
           =2 void PHY_WatchDog(void);
           =2 void phy_WriteReg(byte regaddr, uint value);
           =2 
           =2 #endif // End of __PHY_H__ //
