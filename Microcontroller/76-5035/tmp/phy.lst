  30          //-----------------------------------------------------------------------------
  31          // name    : phy_ReadReg
  32          // purpose : Read PHY register.
  33          // params  :
  34          // returns :
  35          // note    :
  36          // ----------------------------------------------------------------------------
  37          void phy_ReadReg(byte regaddr, uint XDATA* pvalue)
  38          {
  39   1              byte    temp, isr;
  40   1      
  41   1              isr = EA;
  42   1              EA = 0;
  43   1              _nop_();
  44   1              // abort command //
C51 COMPILER V8.06   PHY                                                                   03/10/2026 15:30:56 PAGE 30  

  45   1              EPCR = 0xff;
  46   1      
  47   1              EPCR = regaddr;
  48   1              EPCR = (PBDP->PhyInfo.PhyAddr + PHY_ACCESS_GO + PHY_READ_REG);
  49   1      
  50   1              temp = EPCR;
  51   1              temp = EPCR;
  52   1              while (temp & PHY_ACCESS_GO)
  53   1              {
  54   2                      DELAY_Us(1);
  55   2                      temp = EPCR;
  56   2                      temp = EPCR;
  57   2      
  58   2              } // End of while //
  59   1      
  60   1              *pvalue = EPDR;
  61   1              temp = EPDR;
  62   1              EA = isr;
  63   1              *pvalue += ((uint)temp << 8);
  64   1      
  65   1      } // End of phy_ReadReg //
  66          
  67          //-----------------------------------------------------------------------------
  68          // name    : phy_WriteReg
  69          // purpose : Set PHY register.
  70          // params  :
  71          // returns :
  72          // note    :
  73          // ----------------------------------------------------------------------------
  74          void phy_WriteReg(byte regaddr, uint value)
  75          {
  76   1              byte    temp, isr;
  77   1      
  78   1              isr = EA;
  79   1              EA = 0;
  80   1              _nop_();
  81   1              // abort command //
  82   1              EPCR = 0xff;
  83   1      
  84   1              EPDR = (byte)value;
  85   1              EPDR = (byte)(value >> 8);
  86   1              EPCR = regaddr;
  87   1              EPCR = (PBDP->PhyInfo.PhyAddr + PHY_ACCESS_GO);
  88   1      
  89   1              temp = EPCR;
  90   1              temp = EPCR;
  91   1              while (temp & PHY_ACCESS_GO)
  92   1              {
  93   2                      DELAY_Us(1);
  94   2                      temp = EPCR;
  95   2                      temp = EPCR;
  96   2      
  97   2              } // End of File //
  98   1              EA = isr;
  99   1      
 100   1      } // End of phy_WriteReg //
 101          
 102          //-----------------------------------------------------------------------------
 103          // name    : PHY_Init
 104          // Purpose : Initial some registers and variables of PHY.
 105          // Params  : network_type -0 : auto- negotiation
 106          //                                                -1 : fixed 100 full speed.
C51 COMPILER V8.06   PHY                                                                   03/10/2026 15:30:56 PAGE 31  

 107          //                                                -2 : fixed 100 half speed.
 108          //                                                -3 : fixed 10 full speed.
 109          //                                                -4 : fixed 10 half speed.
 110          // returns :
 111          // note    :
 112          // ----------------------------------------------------------------------------
 113          void PHY_Init(byte network_type)
 114          {
 115   1              uint XDATA      phyctrl, phyanar, tempshort;
 116   1      
 117   1              phy_NetworkType = network_type;
 118   1      
 119   1              // use internal phy //
 120   1              PBDP->PhyInfo.PhyAddr = PHY_ADDRESS;
 121   1              PBDP->PhyInfo.PhyType = PHY_INTERNAL;
 122   1      
 123   1              // software reset //
 124   1              phy_WriteReg(MII_PHY_CONTROL, CONTROL_RESET);
 125   1      
 126   1              // read phy reg-2, reg-0 to make sure embedded phy is ready //
 127   1              while (1)
 128   1              {
 129   2                      phy_ReadReg(MII_PHY_OUI, &tempshort);
 130   2                      if (tempshort == 0x003B)
 131   2                              break;
 132   2              }
 133   1      
 134   1              while (1)
 135   1              {
 136   2                      phy_ReadReg(MII_PHY_CONTROL, &phyctrl);
 137   2                      if ((phyctrl == 0x3100) || (phyctrl == 0x3000) || (phyctrl == 0x1100) ||
 138   2                              (phyctrl == 0x1000))
 139   2                                      break;
 140   2              }
 141   1      
 142   1              switch (network_type)
 143   1              {
 144   2              default:
 145   2              case AUTO_NEGOTIATION:
 146   2                      phyctrl |= (CONTROL_100MB | CONTROL_FULL_DUPLEX);
 147   2                      phyanar = ANAR_SELECTOR_8023 + (ANAR_PAUSE | ANAR_100TXFD | ANAR_100TX |
 148   2                              ANAR_10TFD | ANAR_10T);
 149   2                      break;
 150   2              case FIXED_100_FULL:
 151   2                      phyctrl |= (CONTROL_100MB | CONTROL_FULL_DUPLEX);
 152   2                      phyanar = ANAR_SELECTOR_8023 + (ANAR_PAUSE | ANAR_100TXFD);
 153   2                      break;
 154   2              case FIXED_100_HALF:
 155   2                      phyctrl |= CONTROL_100MB;
 156   2                      phyanar = ANAR_SELECTOR_8023 + (ANAR_PAUSE | ANAR_100TX);
 157   2                      break;
 158   2              case FIXED_10_FULL:
 159   2                      phyctrl |= CONTROL_FULL_DUPLEX;
 160   2                      phyanar = ANAR_SELECTOR_8023 + (ANAR_PAUSE | ANAR_10TFD);
 161   2                      break;
 162   2              case FIXED_10_HALF:
 163   2                      phyanar = ANAR_SELECTOR_8023 + (ANAR_PAUSE | ANAR_10T);
 164   2                      break;
 165   2              }
 166   1      
 167   1              // set phy register 0 & 4 to start negotitation //
 168   1              phy_WriteReg(MII_PHY_ANAR, phyanar);
C51 COMPILER V8.06   PHY                                                                   03/10/2026 15:30:56 PAGE 32  

 169   1              phyctrl |= (CONTROL_ENABLE_AUTO | CONTROL_START_AUTO);
 170   1              phy_WriteReg(MII_PHY_CONTROL, phyctrl);
 171   1              phy_Control = phyctrl;
 172   1      
 173   1      } // End of PHY_Init() //
 174          
 175          // ----------------------------------------------------------------------------
 176          // name    : PHY_CheckMediaType
 177          // purpose :
 178          // params  :
 179          // returns :
 180          // note    :
 181          // ----------------------------------------------------------------------------
 182          uint PHY_CheckMediaType(void)
 183          {
 184   1              uint XDATA      phylinkstatus = 0;
 185   1              uint XDATA      tempshort;
 186   1      
 187   1              while (!phylinkstatus)
 188   1              {
 189   2                      phy_ReadReg(MII_PHY_STATUS, &phylinkstatus);
 190   2                      phylinkstatus &= BIT5;
 191   2              }
 192   1              DELAY_Ms(10);
 193   1      
 194   1              // read phy register 0 for internal phy //
 195   1              phy_ReadReg(MII_PHY_CONTROL, &tempshort);
 196   1      
 197   1              if ((tempshort & CONTROL_100MB) && (tempshort & CONTROL_FULL_DUPLEX))
 198   1                      phylinkstatus = ANLPAR_100TXFD;
 199   1              else if (tempshort & CONTROL_100MB)
 200   1                      phylinkstatus = ANLPAR_100TX;
 201   1              else if (tempshort & CONTROL_FULL_DUPLEX)
 202   1                      phylinkstatus = ANLPAR_10TFD;
 203   1              else
 204   1                      phylinkstatus = ANLPAR_10T;
 205   1              return phylinkstatus;
 206   1      
 207   1      } // End of PHY_CheckMediaType() //
 208          
 209          // ----------------------------------------------------------------------------
 210          // name    : PHY_Reset
 211          // purpose :
 212          // params  :
 213          // returns :
 214          // note    :
 215          // ----------------------------------------------------------------------------
 216          void phy_Restart(void)
 217          {
 218   1              phy_WriteReg(MII_PHY_CONTROL, CONTROL_POWER_DOWN);
 219   1      
 220   1              MAC_Init(phy_NetworkType);
 221   1      
 222   1      } // End of PHY_Reset() //
 223          
 224          // ----------------------------------------------------------------------------
 225          // name    : PHY_PowerUp
 226          // purpose : set phy to power up
 227          // params  :
 228          // returns :
 229          // note    :
 230          // ----------------------------------------------------------------------------
C51 COMPILER V8.06   PHY                                                                   03/10/2026 15:30:56 PAGE 33  

 231          void PHY_PowerUp(void)
 232          {
 233   1              PBDP->PhyInfo.PhyAddr = PHY_ADDRESS;
 234   1      
 235   1              phy_WriteReg(MII_PHY_CONTROL, 0);
 236   1      
 237   1      } // End of PHY_PowerUp() //
 238          
 239          // ----------------------------------------------------------------------------
 240          // name    : PHY_WatchDog
 241          // purpose : If ethernet is un-link, restart the phy to make sure it work right
 242          // params  :
 243          // returns :
 244          // note    :
 245          // ----------------------------------------------------------------------------
 246          void PHY_WatchDog(void)
 247          {
 248   1              if (!PBDP->MacInfo.LinkSpeed)
 249   1                      phy_Restart();
 250   1      
 251   1      } // End of PHY_WatchDog() //
 252          
 253          // End of phy.c //
