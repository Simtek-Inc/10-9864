 242          // name      : printipa
 243          // purpose   : convert long into IPv4 formatted string
 244          // params    : 
 245          // returns   : number of character converted
 246          // note      :
 247          //----------------------------------------------------------------------------------------
 248          int printipa(long i, int width, int pad)
 249          {//  i       == value
 250   1       //  width   == width of string
 251   1       //  pad     == pad flags
 252   1            char  print_buf[PRINT_BUF_LEN];
 253   1            char *s;
 254   1            long  t, pc = 0;
 255   1            ulong u = i;
 256   1            char  x = 0;
 257   1      
 258   1            memset(&print_buf[0], '\0', PRINT_BUF_LEN);
