 260   1            *s = '\0';
 261   1      
 262   1            do
 263   1              {
 264   2              u = (i >> x) & 0xFF;
 265   2              do
 266   2                {
 267   3                t = u % 10;
 268   3                *--s = t + '0';
 269   3                u /= 10;
 270   3                }
 271   2              while (u);
 272   2              x += 8;
 273   2              if((x <= 24))
 274   2                *--s = '.';
 275   2              }
C51 COMPILER V8.06   PRINTD                                                                03/10/2026 15:31:00 PAGE 14  

 276   1            while(x < 25);
 277   1      
 278   1            return pc + prints(s, width, pad);
 279   1      }
