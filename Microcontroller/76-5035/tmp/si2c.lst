  38          
  39          // ----------------------------------------------------------------------------
  40          // Function Name : void I2C_ReadReg(byte RegAddr, byte *pRegData, byte Len)
  41          // Purpose       :
  42          // Params        :
  43          // Returns       :
  44          // Note          :
  45          // ----------------------------------------------------------------------------
  46          //
  47          void I2C_ReadReg(byte RegAddr, byte *pRegData, byte Len)
  48          {
  49   1              byte ISRtmp;
  50   1              
  51   1              ISRtmp = EA;
  52   1              EA = 0;
  53   1              I2CCIR = RegAddr;
  54   1              while (Len --)  pRegData[Len] = I2CDR;
  55   1              EA = ISRtmp;    
  56   1      } // End of I2C_ReadReg() //
  57          
  58          // ----------------------------------------------------------------------------
  59          // Function Name : void I2C_WriteReg(byte RegAddr, byte *pRegData, byte Len)
  60          // Purpose       :
  61          // Params        :
  62          // Returns       :
  63          // Note          :
  64          // ----------------------------------------------------------------------------
  65          //
  66          void I2C_WriteReg(byte RegAddr, byte *pRegData, byte Len)
  67          {
  68   1              byte ISRtmp;
  69   1              
  70   1              ISRtmp = EA;
  71   1              EA = 0;
  72   1              while (Len --)  I2CDR = pRegData[Len];
  73   1              I2CCIR = RegAddr;       
  74   1              EA = ISRtmp;    
  75   1      } // End of I2C_WriteReg() //
