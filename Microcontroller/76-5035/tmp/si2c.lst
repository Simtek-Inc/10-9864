 155          // ----------------------------------------------------------------------------
 156          // Function Name : teI2C_STATUS I2C_Write(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
 157          // Purpose       :
 158          // Params        :
 159          // Returns       :
C51 COMPILER V8.06   SI2C                                                                  03/10/2026 15:31:01 PAGE 16  

 160          // Note          :
 161          // ----------------------------------------------------------------------------
 162          //
 163          teI2C_STATUS I2C_Write(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
 164          {
 165   1              byte MasterStatus, Cmd, Temp;
 166   1              
 167   1              //Write start mark
 168   1              DevAddr &= 0xFE;                                                        // For write operation  
 169   1              Cmd = I2C_START_COND|I2C_CMD_WRITE|I2C_MASTER_GO;                       //
 170   1              I2C_WriteReg(I2CTR, (byte*)&DevAddr, 1);                                //
 171   1              I2C_WriteReg(I2CCR, (byte*)&(Cmd), 1);                                  //
 172   1              do { I2C_ReadReg(I2CMSR, &MasterStatus, 1);                             //
 173   2              } while (MasterStatus & I2C_TIP);                                       //
 174   1              if (MasterStatus & I2C_NO_ACK) return I2C_NACK_ERR;                     //
 175   1              
 176   1              //Write Register address
 177   1              Cmd = I2C_CMD_WRITE|I2C_MASTER_GO;                                      //
 178   1              I2C_WriteReg(I2CTR, (byte*)&RegAddr, 1);                                //
 179   1              I2C_WriteReg(I2CCR, (byte*)&(Cmd), 1);                                  //
 180   1              do { I2C_ReadReg(I2CMSR, &MasterStatus, 1);                             //
 181   2              } while (MasterStatus & I2C_TIP);                                       //
 182   1              if (MasterStatus & I2C_NO_ACK) return I2C_NACK_ERR;                     //
 183   1              
 184   1              //Write data
 185   1              while (Len --)                                                          //
 186   1                {
 187   2                if (Len)                                                              //
 188   2              Cmd = I2C_CMD_WRITE|I2C_MASTER_GO;                                      //
 189   2                      else
 190   2                              Cmd = I2C_CMD_WRITE|I2C_MASTER_GO|I2C_STOP_COND;            // Send stop mark for last byte read.
 191   2      
 192   2                      Temp = *pBuf;                                                     //
 193   2                      I2C_WriteReg(I2CTR, (byte*)&(Temp), 1);                           //
 194   2                      I2C_WriteReg(I2CCR, (byte*)&(Cmd), 1);                            //
 195   2                      do { I2C_ReadReg(I2CMSR, &MasterStatus, 1);                       //
 196   3                      } while (MasterStatus & I2C_TIP);                                 //
 197   2                      if (MasterStatus & I2C_NO_ACK) return I2C_NACK_ERR;               //
 198   2                      pBuf ++;
 199   2              }
 200   1              
 201   1              return I2C_OK;  
 202   1      } // End of I2C_Write() //
