 133   2            } while (MasterStatus & I2C_TIP);                                                   //
 134   1            if (MasterStatus & I2C_NO_ACK) return I2C_NACK_ERR;                                 //
 135   1              
 136   1              //Read data
 137   1            while (Len --)                                                                      //
 138   1              {
 139   2              if (Len)                                                                      //
 140   2                Cmd = I2C_CMD_READ|I2C_MASTER_GO;                                       //
 141   2              else                                                                          //
 142   2                Cmd = I2C_CMD_READ|I2C_MASTER_GO|I2C_STOP_COND;//Send stop mark for last byte read.
 143   2                              
 144   2              I2C_WriteReg(I2CCR, (byte*)&(Cmd), 1);
 145   2              do { I2C_ReadReg(I2CMSR, &MasterStatus, 1);
 146   3                 } while (MasterStatus & I2C_TIP);
 147   2              I2C_ReadReg(I2CRR, &Temp, 1);
 148   2              *pBuf = Temp;
 149   2              pBuf ++;
 150   2              }
 151   1              
 152   1              return I2C_OK;  
