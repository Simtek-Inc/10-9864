 105          //
 106          teI2C_STATUS I2C_Read(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
 107          {
 108   1            byte MasterStatus, Cmd, Temp;
 109   1              
 110   1              //Write start mark
 111   1            DevAddr &= 0xFE;                                                                    // For write ope
             -ration        
 112   1            Cmd = I2C_START_COND|I2C_CMD_WRITE|I2C_MASTER_GO;                                   //
 113   1            I2C_WriteReg(I2CTR, (byte*)&DevAddr, 1);                                            //
 114   1            I2C_WriteReg(I2CCR, (byte*)&(Cmd), 1);                                              //
 115   1            do { I2C_ReadReg(I2CMSR, &MasterStatus, 1);                                         //
 116   2            } while (MasterStatus & I2C_TIP);                                                   //
 117   1            if (MasterStatus & I2C_NO_ACK) return I2C_NACK_ERR;                                 //
 118   1              
 119   1            //Write Register address
 120   1            Cmd = I2C_CMD_WRITE|I2C_MASTER_GO;                                                  //
 121   1            I2C_WriteReg(I2CTR, (byte*)&RegAddr, 1);                                            //
