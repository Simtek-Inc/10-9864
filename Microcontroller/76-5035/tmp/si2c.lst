  78          // Function Name : void I2C_Setup(byte Mode, uint PreClk, uint SlavDevAddr)
  79          // Purpose       :
  80          // Params        :
  81          // Returns       :
  82          // Note          :
  83          // ----------------------------------------------------------------------------
  84          //
  85          void I2C_Setup(byte Mode, uint PreClk, uint SlavDevAddr)
  86          {
  87   1              //Set Pre-Scale Register
  88   1              I2C_WriteReg(I2CCPR, (byte*)&PreClk, 2);
  89   1              
  90   1              //Set Control Register
  91   1              I2C_WriteReg(I2CCTL, (byte*)&Mode, 1);
  92   1              
  93   1              //Set Slave Device Address Register
  94   1              I2C_WriteReg(I2CSDAR, (byte*)&SlavDevAddr, 2);
  95   1                      
  96   1      } // End of I2C_Setup() //
