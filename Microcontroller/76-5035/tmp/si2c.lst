  99          // Function Name : teI2C_STATUS I2C_Read(byte DevAddr, byte RegAddr, byte *pBuf, byte Len)
C51 COMPILER V8.06   SI2C                                                                  03/10/2026 15:31:01 PAGE 15  

 100          // Purpose       :
 101          // Params        :
