 337   1      
 338   1              DELAY_Us(1000);
 339   1      
 340   1              isr = EA;
 341   1              EA = 0;
 342   1              while (PBDP->RFP < PAGES_OF_RCV)
 343   1              {
 344   2                      PBDP->RHPR = PBDP->RTPR;
 345   2                      PBDP->RFP = PAGES_OF_RCV;
 346   2                      EA = isr;
 347   2      
 348   2                      DELAY_Us(1000);
 349   2      
 350   2                      isr = EA;
 351   2                      EA = 0;
 352   2              }
