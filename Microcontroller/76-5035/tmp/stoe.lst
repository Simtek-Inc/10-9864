  53          // ----------------------------------------------------------------------------
  54          // Function Name: stoe_ReadReg
  55          // Purpose:
  56          // Params:
  57          // Returns:
  58          // Note:
  59          // ----------------------------------------------------------------------------
  60          void stoe_ReadReg(byte regaddr, byte XDATA* pbuf, byte length)
  61          {
  62   1              byte    isr;
  63   1      
  64   1              isr = EA;
  65   1              EA = 0;
  66   1              _nop_();
  67   1              TCIR = regaddr;
  68   1              while (length--)
  69   1                pbuf[length] = TDR;
  70   1              EA = isr;
  71   1      
  72   1      } // End of stoe_ReadReg //
  73          
  74          // ----------------------------------------------------------------------------
  75          // Function Name: stoe_WriteReg
  76          // Purpose:
  77          // Params:
  78          // Returns:
  79          // Note:
  80          // ----------------------------------------------------------------------------
  81          void stoe_WriteReg(byte regaddr, byte XDATA* pbuf, byte length)
  82          {
  83   1              byte    isr;
  84   1      
  85   1              isr = EA;
  86   1              EA = 0;
C51 COMPILER V8.06   STOE                                                                  03/10/2026 15:30:55 PAGE 39  

  87   1              while (length--)
  88   1                      TDR = pbuf[length];
  89   1              TCIR = regaddr;
  90   1              EA = isr;
  91   1      
  92   1      } // End of stoe_WriteReg
  93          
  94          // ----------------------------------------------------------------------------
  95          // Function Name: STOE_Init
  96          // Purpose: to initial all registers and variables of STOE. 
  97          // Params: network_type -0: auto- negotiation
  98          //                                              -1: fixed 100 full speed.
  99          //                                              -2: fixed 100 half speed.
 100          //                                              -3: fixed 10 full speed.
 101          //                                              -4: fixed 10 half speed.
 102          // Returns: none
 103          // Note:
 104          // ----------------------------------------------------------------------------
 105          void STOE_Init(byte network_type)
 106          {
 107   1              byte XDATA      temp[2];
 108   1              byte XDATA      value[6] = {0,0,0,0,0,0};
 109   1      
 110   1              // set xmit & rcv memory.
 111   1              stoe_BdpInit();
 112   1      
 113   1              PNetStation = &PBDP->NetStation;
 114   1      
 115   1              // source IP
 116   1              stoe_ReadReg(STOE_IP_ADDR_REG, (byte XDATA*)&PNetStation->DefaultIP, 4);
 117   1              PNetStation->StationIP = PNetStation->DefaultIP;
 118   1      
 119   1              // subnet mask
 120   1              stoe_ReadReg(STOE_SUBNET_MASK_REG, (byte XDATA*)&PNetStation->DefaultMask, 4);
 121   1              PNetStation->SubnetMask = PNetStation->DefaultMask;
 122   1      
 123   1              // gateway
 124   1              PNetStation->DefaultGateway = ((PNetStation->StationIP & PNetStation->SubnetMask) | 1);
 125   1              if (PNetStation->StationIP == PNetStation->DefaultGateway)
 126   1                {
 127   2                PNetStation->DefaultGateway |= (~PNetStation->SubnetMask);
 128   2                PNetStation->DefaultGateway &= 0xfffffffe;
 129   2                }
 130   1      
 131   1              // set L2 control register
 132   1              temp[0] = (RX_TRANSPARENT | TX_TRANSPARENT);
 133   1      
 134   1              stoe_WriteReg(STOE_L2_CTL_REG, temp, 1);
 135   1      
 136   1              // set ARP table timeout register
 137   1              temp[0] = STOE_ARP_TIMEOUT;
 138   1              stoe_WriteReg(STOE_ARP_TIMEOUT_REG, temp, 1);
 139   1      
 140   1              // set L4 control register
 141   1              temp[0] = (DROP_CHKSUMERR_PKT | ENABLE_XMIT_CHKSUM | ENABLE_XMIT_CROSS);
 142   1      
 143   1              stoe_WriteReg(STOE_L4_CTL_REG, temp, 1);
 144   1      
 145   1              // set BDP point
 146   1              temp[0] = (STOE_BDP_START_ADDR >> 16);
 147   1              temp[1] = (STOE_BDP_START_ADDR >> 8);
 148   1              stoe_WriteReg(STOE_L4_BDP_PNT_REG, temp, 2);
C51 COMPILER V8.06   STOE                                                                  03/10/2026 15:30:55 PAGE 40  

 149   1      
 150   1              // receive callback function initialize to null point.
 151   1              STOE_RcvCallback = 0;
 152   1      
 153   1              DMA_Init();
 154   1              DELAY_Init();
 155   1              MAC_Init(network_type);
 156   1      
 157   1              STOE_SetGateway(PNetStation->DefaultGateway);
 158   1      
 159   1      } // End of STOE_Init
 160          
 161          //-----------------------------------------------------------------------------
 162          // Function Name: stoe_BdpInit
 163          // Purpose: initial Buffer Descriptor Page.
 164          // Params:
 165          // Returns:
 166          // Note:
 167          // ----------------------------------------------------------------------------
 168          void stoe_BdpInit(void)
 169          {
 170   1              uint    page = (STOE_BDP_START_ADDR >> 8);
 171   1      
 172   1              PBDP = STOE_BDP_START_ADDR;
 173   1      
 174   1              // set BDP number
 175   1              PBDP->BDP_ID = 0;
 176   1      
 177   1              // set rcv buffer.
 178   1              PBDP->RSPP = page + 1;
 179   1              PBDP->REPP = page + PAGES_OF_RCV;
 180   1              PBDP->RHPR = PBDP->RSPP;
 181   1              PBDP->RTPR = PBDP->RSPP;
 182   1              PBDP->RFP = PAGES_OF_RCV;
 183   1      
 184   1              // set xmit buffer.
 185   1              PBDP->TSPP = page + 1 + PAGES_OF_RCV;
 186   1              PBDP->TEPP = page + PAGES_OF_RCV + PAGES_OF_XMIT;
 187   1              PBDP->THPR = PBDP->TSPP;
 188   1              PBDP->TTPR = PBDP->TSPP;
 189   1              PBDP->TFP = PAGES_OF_XMIT;
 190   1      
 191   1              // set rcv and xmit start/end buffer address.
 192   1              PBDP->RcvStartAddr = STOE_BDP_START_ADDR + 256;
 193   1              PBDP->XmtStartAddr = PBDP->RcvStartAddr + STOE_RCV_BUF_SIZE;
 194   1              PBDP->RcvEndAddr = PBDP->XmtStartAddr - 1;
