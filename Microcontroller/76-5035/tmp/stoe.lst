 487          //-----------------------------------------------------------------------------
 488          // Function Name: STOE_AssignSendBuf
 489          // Purpose: Assign a buffer that adress is between TSPP and TEPP, so STOE engine
 490          //                              cans transmit the packet to MAC SRAM.
 491          // Params: length : Buffer size that the packet occupied.
 492          // Returns: Assigned transmit buffer address
 493          // Note:
 494          // ----------------------------------------------------------------------------
 495          byte XDATA* STOE_AssignSendBuf(uint length)
 496          {
 497   1              byte XDATA*     pframe;
 498   1              byte            occupypages;
 499   1      
 500   1              occupypages = ((length + PAGE_SIZE - 1)/PAGE_SIZE);
 501   1      
 502   1              if (PBDP->TFP <= occupypages)
 503   1                      return (byte XDATA*)0;
 504   1      
 505   1              pframe = ((PBDP->TTPR) << 8);
 506   1              PBDP->STOE_TxInform.Pages = occupypages;
 507   1      
 508   1              return pframe;
 509   1      
 510   1      } // End of STOE_AssignSendBuf
