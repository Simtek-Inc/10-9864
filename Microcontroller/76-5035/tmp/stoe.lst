 433          // Function Name: stoe_XmitHandle
 434          // Purpose: Set send packet bit to tell hardware transmit one packet to ethernet.
 435          // Params: 
 436          // Returns:     
 437          // Note:
 438          // ----------------------------------------------------------------------------
 439          void stoe_XmitHandle(void)
 440          {
 441   1              byte XDATA temp;
 442   1      
 443   1              stoe_ReadReg(STOE_L4_CMD_REG, &temp, 1);
 444   1              while (temp & XMIT_PACKET)
 445   1                      stoe_ReadReg(STOE_L4_CMD_REG, &temp, 1);
 446   1      
 447   1              temp = XMIT_PACKET;
 448   1              stoe_WriteReg(STOE_L4_CMD_REG, &temp, 1);
 449   1      
 450   1      } // stoe_XmitHandle
