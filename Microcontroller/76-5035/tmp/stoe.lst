 397          // Function Name: stoe_RcvHandle
 398          // Purpose: 
 399          // Params: 
 400          // Returns:
 401          // Note:
 402          // ----------------------------------------------------------------------------
 403          void stoe_RcvHandle(void)
 404          {
 405   1              static STOE_FRAME_HEADER XDATA* pframe;
 406   1              uint    length;
 407   1              byte    pages, isr;
 408   1      
 409   1              pframe = ((PBDP->RHPR) << 8);
 410   1              length = (pframe->Length & 0xfff);
 411   1      
 412   1              PBDP->STOE_RxInform.Protocol = pframe->Protocol;
 413   1              PBDP->STOE_RxInform.TotalLen = length;
 414   1              PBDP->STOE_RxInform.PBuf = &pframe->Packet; 
 415   1      
 416   1              if (length && STOE_RcvCallback)
 417   1                      STOE_RcvCallback(&pframe->Packet, length, pframe->Protocol);
 418   1      
 419   1              if (PBDP->RHPR > pframe->NPR)
 420   1                      pages = (PBDP->TSPP - PBDP->RHPR) + (pframe->NPR - PBDP->RSPP);
 421   1              else
 422   1                      pages = pframe->NPR - PBDP->RHPR;
 423   1      
 424   1              isr = EA;
 425   1              EA = 0;
 426   1              PBDP->RHPR = pframe->NPR;
 427   1              PBDP->RFP += pages;
 428   1              EA = isr;
 429   1      
 430   1      } // End of stoe_RcvHandle
