 329   1              {
 330   2                      PBDP->RHPR = PBDP->RTPR;
 331   2                      PBDP->RFP = PAGES_OF_RCV;
 332   2              }
 333   1              EA = isr;
 334   1      
C51 COMPILER V8.06   STOE                                                                  03/10/2026 15:30:55 PAGE 43  

 335   1              temp = RESUME_PKT_RCV;
