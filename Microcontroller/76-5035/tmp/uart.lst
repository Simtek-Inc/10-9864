 313          // Name    : static char uart0_GetKey(void)
 314          // Purpose : UART0 input function. This function replies one byte data from the
 315          //           software character buffer.
 316          // Params  : none
 317          // Returns : c - one byte character.
 318          // Note    : none
 319          // ---------------------------------------------------------------------------------------
 320          uint uart0_GetKey (void)
 321          {
 322   1            byte c;
 323   1      
 324   1            if (uart0_RxCount == 0) return 0x100;
 325   1      
 326   1            EA = 0;
 327   1            uart0_RxCount--;
 328   1            EA = 1;
 329   1            c = uart0_RxBuf[uart0_RxTail];
 330   1            uart0_RxTail++;
 331   1            uart0_RxTail &= MAX_RX_UART0_MASK;
 332   1            return c;
 333   1      }
