 281          // Name    : static uint uart0_PutChar(char c)
 282          // Purpose : UART0 output function. This function puts one byte data into the
 283          //           software character buffer.
 284          // Params  : c - one byte character.
 285          // Returns : c - one byte character.
 286          // Note    : none
 287          // ---------------------------------------------------------------------------------------
 288          uint uart0_PutChar(char c)
 289          {
 290   1            uint count = 0;
 291   1              do
 292   1                {
 293   2                EA = 0;
 294   2                count = uart0_TxCount; 
 295   2                EA = 1;
 296   2                } 
 297   1              while (count == MAX_TX_UART0_BUF_SIZE);
 298   1              uart0_TxBuf[uart0_TxHead] = c;
 299   1              EA = 0;
 300   1              uart0_TxCount++;
 301   1              EA = 1;
 302   1              uart0_TxHead++;
 303   1              uart0_TxHead &= MAX_TX_UART0_MASK;
 304   1            if (!uart0_TxFlag)
 305   1              {
 306   2              uart0_TxFlag = 1;
 307   2              SBUF0 = uart0_TxBuf[uart0_TxTail];
 308   2              }
 309   1            return c;
 310   1      }
