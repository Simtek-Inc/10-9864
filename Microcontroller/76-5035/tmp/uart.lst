C51 COMPILER V8.06   UART                                                                  03/10/2026 15:30:57 PAGE 27  

 374   2              memmove(&uart0_TxBuf[uart0_TxHead], pData, offset);
 375   2              memmove(&uart0_TxBuf[0], pData+offset, cnt - offset);
 376   2              }
 377   1            else
 378   1              memmove(&uart0_TxBuf[uart0_TxHead], pData, cnt);
 379   1            
 380   1            EA = 0;
 381   1            uart0_TxCount += cnt;
 382   1            EA = 1;
 383   1            uart0_TxHead += cnt;
 384   1            uart0_TxHead &= MAX_TX_UART0_MASK;
 385   1            if (!uart0_TxFlag)
 386   1              {
 387   2              uart0_TxFlag = 1;
