 246          // Name    : static void uart0_Init
 247          // Purpose : Setting operation mode of UART0 and initiating the global values.
 248          // Params  : baud rate, parity on
 249          // Returns : none
 250          // Note    : none
 251          // ---------------------------------------------------------------------------------------
 252          static void uart0_Init(byte baudrate, parity)
 253          {
 254   1            byte  sysClk  = 0;
 255   1      
 256   1            uart0_TxHead  = 0;                                                                  // set the head 
             -index to the beginning of the ring buffer
 257   1            uart0_TxTail  = 0;                                                                  // set the tail 
             -index to the beginning of the ring buffer
 258   1            uart0_TxCount = 0;                                                                  // set the buffe
             -r count to zero
 259   1            uart0_TxFlag  = 0;                                                                  // set the trans
             -mit engine started flag
 260   1            uart0_RxHead  = 0;                                                                  // set the head 
             -index to the beginning of the ring buffer
 261   1            uart0_RxTail  = 0;                                                                  // set the tail 
C51 COMPILER V8.06   UART                                                                  03/10/2026 15:30:57 PAGE 25  

             -index to the beginning of the ring buffer
 262   1            uart0_RxCount = 0;                                                                  // set the buffe
             -r count to zero
 263   1            memset(&uart0_TxBuf[0],0,MAX_TX_UART0_BUF_SIZE);                                    // clear the tra
             -nsmit buffer
 264   1            memset(&uart0_RxBuf[0],0,MAX_RX_UART0_BUF_SIZE);                                    // clear the rec
             -eive buffer
 265   1      // initialize timer1 for standard 8051 uart clock
 266   1      //      uart0_Mode    = parity;                                                             // tell the IS
             -R that there is parity, 1 = true, 0 = false
 267   1            PCON          = PCON | SMOD2_;                                                      // 
 268   1            SM00          = 0;                                                                  // 
 269   1            SM01          = 1;                                                                  // Use serial po
             -rt 0 in mode 1 with 8-bits data.
 270   1            REN0          = 1;                                                                  // Enable UART0 
             -receiver.
 271   1            TMOD          = 0x20;                                                                   // Use timer 1 in mode 
             -2, 8-bit counter with auto-reload.
 272   1            uart0_setBaudRate(baudrate);                                                        // set the baudr
             -ate
 273   1            TH2           = RLDH;                                                               // load the regi
             -sters with the reload values
 274   1            TL2           = RLDL;                                                               //
 275   1            ES0           = 1;                                                                  // enable serial
             - port Interrupt request
 276   1            T2CON         = 0x30;                                                               // set uart0 to 
             -use timer 2 for rclk and tclk
 277   1            TR2           = 1;                                                                  // run timer 2
 278   1      } // End of uart0_Init //
