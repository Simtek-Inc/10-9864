 441          // Note    : none
 442          // ---------------------------------------------------------------------------------------
 443          byte uart0_RxPtrSet(byte c)
 444          {
 445   1            uint length;
 446   1            byte *pData1, *pData2;
 447   1            
 448   1            length       = MAX_TX_UART0_BUF_SIZE - uart0_RxTail;
 449   1            pData1       = memchr(&uart0_RxBuf[uart0_RxTail], c, length);
 450   1            pData2       = &uart0_RxBuf[MAX_RX_UART0_BUF_SIZE];
 451   1            length       = *(pData1) - *(pData2);
 452   1            uart0_RxTail = length;
 453   1            return uart0_RxBuf[uart0_RxTail];
 454   1      }
