 169          //----------------------------------------------------------------------------------------
 170          // name    : uart0_setBaudRate                                                            //
 171          // purpose : read the baud switch and update the COM port settings                        //
 172          // params  : desired baud rate                                                            //
 173          // returns : baudrate setting and system clock setting                                    //
 174          // notes   :                                                                              //
 175          //----------------------------------------------------------------------------------------
 176          byte  uart0_setBaudRate(byte baudrate)                                                    //
 177          {
 178   1            byte     t;                                                                         //
 179   1            byte     sysClk;                                                                    //
 180   1            uint     xcap;                                                                      //
C51 COMPILER V8.06   UART                                                                  03/10/2026 15:30:57 PAGE 23  

 181   1            
 182   1            sysClk = CSREPR & 0xC0;                                                             // get the clock
             - frequency
 183   1            t = sysClk | baudrate;                                                              // add the syste
             -m clock setting to the baudrate
 184   1            switch (t)                                                                          // use the baudr
             -ate and clock frequency 
 185   1              {
 186   2              case F_25_B___1200 : printd("1200@25MHz");    xcap = 0xFD75;  break;              // Baud rate =  
             - 1200  @  25MHz.
