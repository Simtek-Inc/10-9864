 423          // Params  : the number of bytes that were copied
 424          // Returns : none
 425          // Note    : none
 426          // ---------------------------------------------------------------------------------------
 427          void uart0_RxBufUpdate(byte cnt)
 428          {
 429   1            uart0_RxTail = uart0_RxTail + cnt;
 430   1            uart0_RxTail &= MAX_RX_UART0_MASK;
 431   1            EA = 0;
 432   1            uart0_RxCount = uart0_RxCount - cnt;      
 433   1            EA = 1;
 434   1      }
