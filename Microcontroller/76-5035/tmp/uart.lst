 408   2              memmove(pData, &uart0_RxBuf[uart0_RxTail], offset);
 409   2              memmove(pData+offset, &uart0_RxBuf[0], cnt - offset);
 410   2              }
 411   1            else
 412   1              memmove(pData, &uart0_RxBuf[uart0_RxTail], cnt);
 413   1      }
