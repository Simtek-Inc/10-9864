 362   1      //printd("stx msg cnt = %bu\n\r",cnt);
 363   1      
 364   1            do
 365   1              {
 366   2              EA = 0;
 367   2              count = uart0_TxCount; 
 368   2              EA = 1;
 369   2              } 
 370   1            while ((count + cnt) == MAX_TX_UART0_BUF_SIZE);
 371   1            if((uart0_TxHead + cnt) > MAX_TX_UART0_BUF_SIZE)
 372   1              {
