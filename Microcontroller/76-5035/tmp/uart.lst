1013          // Name    : bool UART_ParityChk(char checkByte)
1014          // Purpose : find the number of bits in a byte and set report the parity state to the calling routine
1015          // Params  : checkByte - the byte of data to find the checksum
1016          // Returns : TRUE - odd parity ; FALSE - even parity.
1017          // Note    : none
1018          // ---------------------------------------------------------------------------------------
1019          bool UART_ParityChk(char checkByte)
1020          {
1021   1            byte  bitSum;
1022   1            uint  i;
1023   1      
1024   1            bitSum = 0;                                                                         // set one bit c
             -ount to 0
1025   1            for (i = 0; i <= 7; i++)                                                            // loop through 
             -byte to find all bits that equal 1
1026   1              {
1027   2              if (checkByte & (BIT0 << i))                                                      // check if bit 
             -is equal to 1
1028   2                {
1029   3                bitSum ++;                                                                      // it is a 1 add
             - to the bit count
1030   3                }
1031   2              }
1032   1            if ((bitSum % 2) == 0)                                                              // find if there
             - is an even number of '1's
1033   1              return FALSE;                                                                     // if sum of '1'
             - bits is even, return 0      
1034   1            return TRUE;                                                                        // if sum of '1'
             - bits is odd, return 1
1035   1      }
