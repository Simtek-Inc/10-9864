  96          // Name    : static void uart0_ISR(void)
  97          // Purpose : UART0 interrupt service routine. For sending out, it puts data
  98          //           from software buffer into hardware serial buffer register (SBUF0).
  99          //           For receiving, it gets data from hardware serial buffer register
 100          //           (SBUF0) and stores into software buffer.
 101          // Params  : none
 102          // Returns : none
 103          // Note    : none
 104          // ---------------------------------------------------------------------------------------
 105          static void uart0_ISR(void) interrupt 4
 106          {
 107   1      //      byte  parity = 0;
 108   1            byte  tmp    = 0;                                                                   // 
 109   1      
 110   1            if (RI0)
 111   1              {
 112   2              EA = 0;                                                                           // disable all i
             -nterrupts to make sure process is not interrupted
 113   2              if (uart0_RxCount != MAX_RX_UART0_BUF_SIZE)                                       // 
 114   2                {
 115   3                tmp           = SBUF0;                                                          // get the recei
             -ved data byte
 116   3      //          if (uart0_Mode & TRUE)                                                          // if bit is o
             -ne check for even parity
 117   3      //            {
 118   3      ////            parity = UART_ParityChk(tmp);                                                 // calculate
             - the parity of the recieved byte
 119   3      ////            if (RB08 == parity)                                                           // compare t
             -o received parity bit
 120   3      ////              {
 121   3      //              uart0_RxBuf[uart0_RxHead] = tmp;                                            // place the d
             -ata byte in the ring buffer
 122   3      //              uart0_RxCount++;                                                            // update the 
             -byte count to show data received
 123   3      //              uart0_RxHead++;                                                             // update buff
             -er index to next byte
 124   3      //              uart0_RxHead &= MAX_RX_UART0_MASK;                                          // mask the in
             -dex to buffer circular
 125   3      ////              }
 126   3      ////            else
 127   3      ////              {
 128   3      ////              printd("!!parity fail!!\n\r");                                              // alert the
             - user to the parity error
 129   3      ////              }
 130   3      //            }
 131   3      //          else                                                                            // no parity c
             -heck required
 132   3      //            {
 133   3                  uart0_RxBuf[uart0_RxHead] = tmp;                                              // place the dat
             -a byte in the ring buffer
 134   3                  uart0_RxCount++;                                                              // update the by
C51 COMPILER V8.06   UART                                                                  03/10/2026 15:30:57 PAGE 22  

             -te count to show data received
 135   3                  uart0_RxHead++;                                                               // update buffer
             - index to next byte
 136   3                  uart0_RxHead &= MAX_RX_UART0_MASK;                                            // mask the inde
             -x to buffer circular
 137   3      //            }  
 138   3                }
 139   2              RI0 = 0;
 140   2              EA = 1;
 141   2              } // End of if(RI0) //
 142   1            if (TI0)                                                                            // check if a by
             -te transmission is finished
 143   1              {
 144   2              EA = 0;                                                                           // disable all i
             -nterrupts to make sure process is not interrupted
 145   2              uart0_TxTail++;                                                                   // move the poin
             -ter to the next byte to transmit
 146   2              uart0_TxTail &= MAX_TX_UART0_MASK;                                                // mask the inde
             -x point to make the buffer loop
 147   2              uart0_TxCount--;                                                                  // remove the by
             -te from the buffer count
 148   2              if (uart0_TxCount > 0)                                                            // check if ther
             -e are more bytes to transmit
 149   2                {
 150   3                SBUF0 = uart0_TxBuf[uart0_TxTail];                                              // transmit the 
             -next byte
 151   3      //          if (uart0_Mode & TRUE)                                                          // if bit is o
             -ne check for even parity
 152   3      //            {
 153   3      //            parity = UART_ParityChk((byte)uart0_TxBuf[uart0_TxTail]);                     // generate th
             -e parity bity for even parity
 154   3      //            if (parity)                                                                   // if true byt
             -e parity is odd
 155   3      //              TB08 = 1;                                                                   // data parity
             - is odd set parity bit to '1' to correct for even parity
 156   3      //            else
 157   3      //              TB08 = 0;                                                                   // data parity
             - is even set parity bit to '0' no correction needed
 158   3      //            }
 159   3                }
 160   2              else
