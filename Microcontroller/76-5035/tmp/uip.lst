   4      =1  //
   5      =1  // The functions in the architecture specific module implement the IP
   6      =1  // check sum and 32-bit additions.
   7      =1  //
   8      =1  // The IP checksum calculation is the most computationally expensive
   9      =1  // operation in the TCP/IP stack and it therefore pays off to
  10      =1  // implement this in efficient assembler. The purpose of the uip-arch
  11      =1  // module is to let the checksum functions to be implemented in
  12      =1  // architecture specific assembler.
  13      =1  //
