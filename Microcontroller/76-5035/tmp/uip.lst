C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 45  

           =2 // First, the functions that should be called from the
           =2 // system. Initialization, the periodic timer and incoming packets are
           =2 // handled by the following three functions.
           =2 //
           =2 
           =2 //
           =2 // \defgroup uipconffunc uIP configuration functions
           =2 // @{
           =2 //
           =2 // The uIP configuration functions are used for setting run-time
           =2 // parameters in uIP such as IP addresses. 
           =2 //
           =2 
           =2 //
           =2 // Set the IP address of this host.
           =2 //
           =2 // The IP address is represented as a 4-byte array where the first
           =2 // octet of the IP address is put in the first member of the 4-byte
           =2 // array.
           =2 //
           =2 // \param addr A pointer to a 4-byte representation of the IP address.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_sethostaddr(addr) do { uip_hostaddr[0] = addr[0]; \
           =2                               uip_hostaddr[1] = addr[1]; } while(0)
           =2 
           =2 //
           =2 // Get the IP address of this host.
           =2 //
           =2 // The IP address is represented as a 4-byte array where the first
           =2 // octet of the IP address is put in the first member of the 4-byte
           =2 // array.
           =2 //
           =2 // \param addr A pointer to a 4-byte array that will be filled in with
           =2 // the currently configured IP address.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_gethostaddr(addr) do { addr[0] = uip_hostaddr[0]; \
           =2                               addr[1] = uip_hostaddr[1]; } while(0)
           =2 
           =2 //
           =2 // \defgroup uipinit uIP initialization functions
           =2 // @{
           =2 //
           =2 // The uIP initialization functions are used for booting uIP.
           =2 //
           =2 
           =2 //
           =2 // uIP initialization function.
           =2 //
           =2 // This function should be called at boot up to initilize the uIP
           =2 // TCP/IP stack.
           =2 //
           =2 void uip_init(void);
           =2 
           =2 // @} //
           =2 
           =2 // \defgroup uipdevfunc uIP device driver functions
           =2 // @{
           =2 //
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 46  

           =2 // These functions are used by a network device driver for interacting
           =2 // with uIP.
           =2 //
           =2 // Process an incoming packet.
           =2 //
           =2 // This function should be called when the device driver has received
           =2 // a packet from the network. The packet from the device driver must
           =2 // be present in the uip_buf buffer, and the length of the packet
           =2 // should be placed in the uip_len variable.
           =2 //
           =2 // When the function returns, there may be an outbound packet placed
           =2 // in the uip_buf packet buffer. If so, the uip_len variable is set to
           =2 // the length of the packet. If no packet is to be sent out, the
           =2 // uip_len variable is set to 0.
           =2 //
           =2 // The usual way of calling the function is presented by the source
           =2 // code below.
           =2 // \code
           =2 //  uip_len = devicedriver_poll();
           =2 //  if(uip_len > 0) {
           =2 //    uip_input();
           =2 //    if(uip_len > 0) {
           =2 //      devicedriver_send();
           =2 //    }
           =2 //  }
           =2 // \endcode
           =2 //
           =2 // \note If you are writing a uIP device driver that needs ARP
           =2 // (Address Resolution Protocol), e.g., when running uIP over
           =2 // Ethernet, you will need to call the uIP ARP code before calling
           =2 // this function:
           =2 // \code
           =2 //  #define BUF ((struct uip_eth_hdr *)&uip_buf[0])
           =2 //  uip_len = ethernet_devicedrver_poll();
           =2 //  if(uip_len > 0) {
           =2 //    if(BUF->type == HTONS(UIP_ETHTYPE_IP)) {
           =2 //      uip_arp_ipin();
           =2 //      uip_input();
           =2 //      if(uip_len > 0) {
           =2 //        uip_arp_out();
           =2 //      ethernet_devicedriver_send();
           =2 //      }
           =2 //    } else if(BUF->type == HTONS(UIP_ETHTYPE_ARP)) {
           =2 //      uip_arp_arpin();
           =2 //      if(uip_len > 0) {
           =2 //      ethernet_devicedriver_send();
           =2 //      }
           =2 //    }
           =2 // \endcode
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 //#define uip_input()        uip_process(UIP_DATA)
           =2 
           =2 //
           =2 // Periodic processing for a connection identified by its number.
           =2 // 
           =2 // This function does the necessary periodic processing (timers,
           =2 // polling) for a uIP TCP conneciton, and should be called when the
           =2 // periodic uIP timer goes off. It should be called for every
           =2 // connection, regardless of whether they are open of closed.
           =2 //
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 47  

           =2 // When the function returns, it may have an outbound packet waiting
           =2 // for service in the uIP packet buffer, and if so the uip_len
           =2 // variable is set to a value larger than zero. The device driver
           =2 // should be called to send out the packet.
           =2 //
           =2 // The ususal way of calling the function is through a for() loop like
           =2 // this:
           =2 // \code
           =2 //  for(i = 0; i < UIP_CONNS; ++i) {
           =2 //    uip_periodic(i);
           =2 //    if(uip_len > 0) {
           =2 //      devicedriver_send();
           =2 //    }
           =2 //  }
           =2 // \endcode
           =2 //
           =2 // \note If you are writing a uIP device driver that needs ARP
           =2 // (Address Resolution Protocol), e.g., when running uIP over
           =2 // Ethernet, you will need to call the uip_arp_out() function before
           =2 // calling the device driver:
           =2 // \code
           =2 //  for(i = 0; i < UIP_CONNS; ++i) {
           =2 //    uip_periodic(i);
           =2 //    if(uip_len > 0) {
           =2 //      uip_arp_out();
           =2 //      ethernet_devicedriver_send();
           =2 //    }
           =2 //  }
           =2 // \endcode 
           =2 //
           =2 // \param conn The number of the connection which is to be periodically polled.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_periodic(conn) do { uip_conn = &uip_conns[conn]; \
           =2                                 uip_process(UIP_TIMER); } while (0)
           =2 
           =2 //
           =2 // Periodic processing for a connection identified by a pointer to its structure.
           =2 //
           =2 // Same as uip_periodic() but takes a pointer to the actual uip_conn
           =2 // struct instead of an integer as its argument. This function can be
           =2 // used to force periodic processing of a specific connection.
           =2 //
           =2 // \param conn A pointer to the uip_conn struct for the connection to
           =2 // be processed.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_periodic_conn(conn) do { uip_conn = conn; \
           =2                                      uip_process(UIP_TIMER); } while (0)
           =2 
           =2 #if UIP_UDP
           =2 //
           =2 // Periodic processing for a UDP connection identified by its number.
           =2 //
           =2 // This function is essentially the same as uip_prerioic(), but for
           =2 // UDP connections. It is called in a similar fashion as the
           =2 // uip_periodic() function:
           =2 // \code
           =2 //  for(i = 0; i < UIP_UDP_CONNS; i++) {
           =2 //    uip_udp_periodic(i);
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 48  

           =2 //    if(uip_len > 0) {
           =2 //      devicedriver_send();
           =2 //    }
           =2 //  }   
           =2 // \endcode
           =2 //
           =2 // \note As for the uip_periodic() function, special care has to be
           =2 // taken when using uIP together with ARP and Ethernet:
           =2 // \code
           =2 //  for(i = 0; i < UIP_UDP_CONNS; i++) {
           =2 //    uip_udp_periodic(i);
           =2 //    if(uip_len > 0) {
           =2 //      uip_arp_out();
           =2 //      ethernet_devicedriver_send();
           =2 //    }
           =2 //  }   
           =2 // \endcode
           =2 //
           =2 // \param conn The number of the UDP connection to be processed.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_udp_periodic(conn) do { uip_udp_conn = &uip_udp_conns[conn]; \
           =2                                 uip_process(UIP_UDP_TIMER); } while (0)
           =2 
           =2 //
           =2 // Periodic processing for a UDP connection identified by a pointer to
           =2 // its structure.
           =2 //
           =2 // Same as uip_udp_periodic() but takes a pointer to the actual
           =2 // uip_conn struct instead of an integer as its argument. This
           =2 // function can be used to force periodic processing of a specific
           =2 // connection.
           =2 //
           =2 // \param conn A pointer to the uip_udp_conn struct for the connection
           =2 // to be processed.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_udp_periodic_conn(conn) do { uip_udp_conn = conn; \
           =2                                          uip_process(UIP_UDP_TIMER); } while (0)
           =2 
           =2 void uip_udp_listen(uint port);
           =2 void uip_udp_unlisten(uint port);
           =2 
           =2 #endif // UIP_UDP //
           =2 
           =2 // The uIP packet buffer.
           =2 //
           =2 // The uip_buf array is used to hold incoming and outgoing
           =2 // packets. The device driver should place incoming data into this
           =2 // buffer. When sending data, the device driver should read the link
           =2 // level headers and the TCP/IP headers from this buffer. The size of
           =2 // the link level headers is configured by the UIP_LLH_LEN define.
           =2 //
           =2 // \note The application data need not be placed in this buffer, so
           =2 // the device driver must read it from the place pointed to by the
           =2 // uip_appdata pointer as illustrated by the following example:
           =2 // \code
           =2 // void
           =2 // devicedriver_send(void)
           =2 // {
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 49  

           =2 //    hwsend(&uip_buf[0], UIP_LLH_LEN);
           =2 //    hwsend(&uip_buf[UIP_LLH_LEN], 40);
           =2 //    hwsend(uip_appdata, uip_len - 40 - UIP_LLH_LEN);
           =2 // }
           =2 // \endcode
           =2 //
           =2 //extern byte xdata uip_buf[UIP_BUFSIZE+2];
           =2 
           =2 // @} //
           =2 void uip_listen(uint port);
           =2 
           =2 //-----------------------------------------------------------------------------------//
           =2 // Functions that are used by the uIP application program. Opening and
           =2 // closing connections, sending and receiving data, etc. is all
           =2 // handled by the functions below.
           =2 //
           =2 //
           =2 // \defgroup uipappfunc uIP application functions
           =2 // @{
           =2 //
           =2 // Functions used by an application running of top of uIP.
           =2 //
           =2 
           =2 // Start listening to the specified port.
           =2 //
           =2 // \note Since this function expects the port number in network byte
           =2 // order, a conversion using HTONS() or htons() is necessary.
           =2 //
           =2 // \code
           =2 // uip_listen(HTONS(80)); 
           =2 // \endcode
           =2 //
           =2 // \param port A 16-bit port number in network byte order.
           =2 //
           =2 void uip_listen(uint port);
           =2 
           =2 // Stop listening to the specified port.
           =2 //
           =2 // \note Since this function expects the port number in network byte
           =2 // order, a conversion using HTONS() or htons() is necessary.
           =2 //
           =2 // \code
           =2 // uip_unlisten(HTONS(80)); 
           =2 // \endcode
           =2 //
           =2 // \param port A 16-bit port number in network byte order.
           =2 //
           =2 
           =2 struct uip_conn *uip_connect(uint *ripaddr, uint port);
           =2 
           =2 // Connect to a remote host using TCP.
           =2 //
           =2 // This function is used to start a new connection to the specified
           =2 // port on the specied host. It allocates a new connection identifier,
           =2 // sets the connection to the SYN_SENT state and sets the
           =2 // retransmission timer to 0. This will cause a TCP SYN segment to be
           =2 // sent out the next time this connection is periodically processed,
           =2 // which usually is done within 0.5 seconds after the call to
           =2 // uip_connect().
           =2 //
           =2 // \note This function is avaliable only if support for active open
           =2 // has been configured by defining UIP_ACTIVE_OPEN to 1 in uipopt.h.
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 50  

           =2 //
           =2 // \note Since this function requires the port number to be in network
           =2 // byte order, a convertion using HTONS() or htons() is necessary.
           =2 //
           =2 // \code
           =2 // uint ipaddr[2];
           =2 
           =2 // uip_ipaddr(ipaddr, 192,168,1,2);
           =2 // uip_connect(ipaddr, HTONS(80)); 
           =2 // \endcode
           =2 // 
           =2 // \param ripaddr A pointer to a 4-byte array representing the IP
           =2 // address of the remote hot.
           =2 //
           =2 // \param port A 16-bit port number in network byte order.
           =2 //
           =2 // \return A pointer to the uIP connection identifier for the new connection,
           =2 // or NULL if no connection could be allocated.   
           =2 // 
           =2 //
           =2 struct uip_conn *uip_connect(uint *ripaddr, uint port);
           =2 
           =2 //
           =2 // \internal
           =2 //
           =2 // Check if a connection has outstanding (i.e., unacknowledged) data.
           =2 //
           =2 // \param conn A pointer to the uip_conn structure for the connection.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_outstanding(conn) ((conn)->len)
           =2 
           =2 //
           =2 // Send data on the current connection.
           =2 //
           =2 // This function is used to send out a single segment of TCP
           =2 // data. Only applications that have been invoked by uIP for event
           =2 // processing can send data. 
           =2 //
           =2 // The amount of data that actually is sent out after a call to this
           =2 // funcion is determined by the maximum amount of data TCP allows. uIP
           =2 // will automatically crop the data so that only the appropriate
           =2 // amount of data is sent. The function uip_mss() can be used to query
           =2 // uIP for the amount of data that actually will be sent.
           =2 // 
           =2 // \note This function does not guarantee that the sent data will
           =2 // arrive at the destination. If the data is lost in the network, the
           =2 // application will be invoked with the uip_rexmit() event being
           =2 // set. The application will then have to resend the data using this
           =2 // function.
           =2 // 
           =2 // \param data A pointer to the data which is to be sent.
           =2 //
           =2 // \param len The maximum amount of data bytes to be sent.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_send(data, len) do { uip_sappdata = (data); uip_slen = (len);} while(0)   
           =2 
           =2 //
           =2 // The length of any incoming data that is currently avaliable (if avaliable)
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 51  

           =2 // in the uip_appdata buffer.
           =2 //
           =2 // The test function uip_data() must first be used to check if there
           =2 // is any data available at all.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_datalen()       uip_len
           =2 
           =2 //
           =2 // The length of any out-of-band data (urgent data) that has arrived
           =2 // on the connection.
           =2 //
           =2 // \note The configuration parameter UIP_URGDATA must be set for this
           =2 // function to be enabled.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_urgdatalen()    uip_urglen
           =2 
           =2 //
           =2 // Close the current connection.
           =2 //
           =2 // This function will close the current connection in a nice way.
           =2 //
