           =2     uip_stats_t vhlerr;   //< Number of packets dropped due to wrong IP version or header length. //
           =2     uip_stats_t hblenerr; //< Number of packets dropped due to wrong IP length, high byte. //
           =2     uip_stats_t lblenerr; //< Number of packets dropped due to wrong IP length, low byte. //
           =2     uip_stats_t fragerr;  //< Number of packets dropped since they were IP fragments. //
           =2     uip_stats_t chkerr;   //< Number of packets dropped due to IP checksum errors. //
           =2     uip_stats_t protoerr; //< Number of packets dropped since they were neither ICMP, UDP nor TCP. //
           =2   } ip;                   //< IP statistics. //
           =2   struct {
