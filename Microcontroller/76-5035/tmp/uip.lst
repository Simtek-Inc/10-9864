           =1 /**
           =1  * \defgroup uipoptapp Appication specific configurations
           =1  * @{
           =1  *
           =1  * An uIP application is implemented using a single application
           =1  * function that is called by uIP whenever a TCP/IP event occurs. The
           =1  * name of this function must be registered with uIP at compile time
           =1  * using the UIP_APPCALL definition.
           =1  *
           =1  * uIP applications can store the application state within the
           =1  * uip_conn structure by specifying the size of the application
           =1  * structure with the UIP_APPSTATE_SIZE macro.
           =1  *
           =1  * The file containing the definitions must be included in the
           =1  * uipopt.h file.
           =1  *
           =1  * The following example illustrates how this can look.
           =1  \code
           =1 
           =1 void httpd_appcall(void);
           =1 #define UIP_APPCALL     httpd_appcall
           =1 
           =1 struct httpd_state {
           =1   uint state; 
           =1   uint count;
           =1   char *dataptr;
           =1   char *script;
           =1 };
           =1 #define UIP_APPSTATE_SIZE (sizeof(struct httpd_state))
           =1  \endcode
           =1  */
           =1 
           =1 /**
           =1  * \var #define UIP_APPCALL
           =1  *
           =1  * The name of the application function that uIP should call in
           =1  * response to TCP/IP events.
           =1  *
           =1  */
           =1 
           =1 /**
           =1  * \var #define UIP_APPSTATE_SIZE
           =1  *
           =1  * The size of the application state that is to be stored in the
           =1  * uip_conn structure.
           =1  */
           =1 /** @} */
           =1 
           =1 /* Include the header file for the application program that should be
           =1    used. If you don't use the example web server, you should change
           =1    this. */
           =1 
