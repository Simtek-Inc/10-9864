  69      =1  //
  70      =1  // Carry out a 32-bit addition.
  71      =1  //
  72      =1  // Because not all architectures for which uIP is intended has native
  73      =1  // 32-bit arithmetic, uIP uses an external C function for doing the
  74      =1  // required 32-bit additions in the TCP protocol processing. This
C51 COMPILER V8.06   UIP                                                                   03/10/2026 15:30:58 PAGE 61  

  75      =1  // function should add the two arguments and place the result in the
  76      =1  // global variable uip_acc32.
  77      =1  //
  78      =1  // \note The 32-bit integer pointed to by the op32 parameter and the
  79      =1  // result in the uip_acc32 variable are in network byte order (big
  80      =1  // endian).
  81      =1  //
  82      =1  // \param op32 A pointer to a 4-byte array representing a 32-bit
  83      =1  // integer in network byte order (big endian).
  84      =1  //
  85      =1  // \param op16 A 16-bit integer in host byte order.
  86      =1  //
  87      =1  void uip_add32(byte *op32, uint op16);
  88      =1  
  89      =1  //
  90      =1  // Calculate the Internet checksum over a buffer.
  91      =1  //
  92      =1  // The Internet checksum is the one's complement of the one's
  93      =1  // complement sum of all 16-bit words in the buffer.
  94      =1  //
  95      =1  // See RFC1071.
  96      =1  //
  97      =1  // \note This function is not called in the current version of uIP,
  98      =1  // but future versions might make use of it.
  99      =1  //
 100      =1  // \param buf A pointer to the buffer over which the checksum is to be
 101      =1  // computed.
 102      =1  //
 103      =1  // \param len The length of the buffer over which the checksum is to
 104      =1  // be computed.
 105      =1  //
 106      =1  // \return The Internet checksum of the buffer.
 107      =1  //
 108      =1  uint uip_chksum(uint *buf, uint len);
 109      =1  
 110      =1  //
 111      =1  // Calculate the IP header checksum of the packet header in uip_buf.
 112      =1  //
 113      =1  // The IP header checksum is the Internet checksum of the 20 bytes of
 114      =1  // the IP header.
 115      =1  //
 116      =1  // \return The IP header checksum of the IP header in the uip_buf
 117      =1  // buffer.
 118      =1  //
 119      =1  uint uip_ipchksum(void);
 120      =1  
 121      =1  //
 122      =1  // Calculate the TCP checksum of the packet in uip_buf and uip_appdata.
 123      =1  //
 124      =1  // The TCP checksum is the Internet checksum of data contents of the
 125      =1  // TCP segment, and a pseudo-header as defined in RFC793.
 126      =1  //
 127      =1  // \note The uip_appdata pointer that points to the packet data may
 128      =1  // point anywhere in memory, so it is not possible to simply calculate
 129      =1  // the Internet checksum of the contents of the uip_buf buffer.
 130      =1  //
 131      =1  // \return The TCP checksum of the TCP segment in uip_buf and pointed
 132      =1  // to by uip_appdata.
 133      =1  //
 134      =1  uint uip_tcpchksum(void);
 135      =1  
