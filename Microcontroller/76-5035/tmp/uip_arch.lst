  60      =1  //-----------------------------------------------------------------------------------//
  61      =1  // First, the functions that should be called from the
  62      =1  // system. Initialization, the periodic timer and incoming packets are
  63      =1  // handled by the following three functions.
  64      =1  //
  65      =1  
  66      =1  //
  67      =1  // \defgroup uipconffunc uIP configuration functions
  68      =1  // @{
  69      =1  //
  70      =1  // The uIP configuration functions are used for setting run-time
  71      =1  // parameters in uIP such as IP addresses. 
  72      =1  //
  73      =1  
  74      =1  //
  75      =1  // Set the IP address of this host.
