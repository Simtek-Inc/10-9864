 528      =2    uint count;
 529      =2    char *dataptr;
 530      =2    char *script;
 531      =2  };
 532      =2  #define UIP_APPSTATE_SIZE (sizeof(struct httpd_state))
 533      =2   \endcode
 534      =2   */
 535      =2  
 536      =2  /**
 537      =2   * \var #define UIP_APPCALL
 538      =2   *
 539      =2   * The name of the application function that uIP should call in
 540      =2   * response to TCP/IP events.
 541      =2   *
 542      =2   */
 543      =2  
 544      =2  /**
 545      =2   * \var #define UIP_APPSTATE_SIZE
 546      =2   *
 547      =2   * The size of the application state that is to be stored in the
 548      =2   * uip_conn structure.
 549      =2   */
 550      =2  /** @} */
 551      =2  
 552      =2  /* Include the header file for the application program that should be
 553      =2     used. If you don't use the example web server, you should change
 554      =2     this. */
 555      =2  
 556      =2  
 557      =2  #endif /* __UIPOPT_H__ */
