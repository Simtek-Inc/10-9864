 213      =1  // \endcode 
 214      =1  //
 215      =1  // \param conn The number of the connection which is to be periodically polled.
 216      =1  //
 217      =1  // \hideinitializer
 218      =1  //
 219      =1  #define uip_periodic(conn) do { uip_conn = &uip_conns[conn]; \
 220      =1                                  uip_process(UIP_TIMER); } while (0)
 221      =1  
 222      =1  //
 223      =1  // Periodic processing for a connection identified by a pointer to its structure.
 224      =1  //
 225      =1  // Same as uip_periodic() but takes a pointer to the actual uip_conn
 226      =1  // struct instead of an integer as its argument. This function can be
 227      =1  // used to force periodic processing of a specific connection.
 228      =1  //
 229      =1  // \param conn A pointer to the uip_conn struct for the connection to
 230      =1  // be processed.
