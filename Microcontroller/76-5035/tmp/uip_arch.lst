           =2 
           =2 //
           =2 // Pack an IP address into a 4-byte array which is used by uIP to
           =2 // represent IP addresses.
           =2 //
           =2 // Example:
           =2 // \code
           =2 // uint ipaddr[2];
           =2 //
           =2 // uip_ipaddr(&ipaddr, 192,168,1,2); 
           =2 // \endcode
           =2 //
           =2 // \param addr A pointer to a 4-byte array that will be filled in with
           =2 // the IP addres.
           =2 // \param addr0 The first octet of the IP address.
           =2 // \param addr1 The second octet of the IP address.
           =2 // \param addr2 The third octet of the IP address.
           =2 // \param addr3 The forth octet of the IP address. 
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #define uip_ipaddr(addr, addr0,addr1,addr2,addr3) do { \
           =2                      (addr)[0] = HTONS(((addr0) << 8) | (addr1)); \
           =2                      (addr)[1] = HTONS(((addr2) << 8) | (addr3)); \
           =2                   } while(0)
           =2 
           =2 //
           =2 // Convert 16-bit quantity from host byte order to network byte order.
           =2 //
           =2 // This macro is primarily used for converting constants from host
           =2 // byte order to network byte order. For converting variables to
           =2 // network byte order, use the htons() function instead.
           =2 //
           =2 // \hideinitializer
           =2 //
           =2 #ifndef HTONS
           =2 #if BYTE_ORDER == BIG_ENDIAN
           =2 #define HTONS(n) (n)
           =2 #else // BYTE_ORDER == BIG_ENDIAN //
           =2 #define HTONS(n) ((((uint)((n) & 0xff)) << 8) | (((n) & 0xff00) >> 8))
           =2 #endif // BYTE_ORDER == BIG_ENDIAN //
           =2 #endif // HTONS //
           =2 
           =2 //
           =2 // Convert 16-bit quantity from host byte order to network byte order.
           =2 //
           =2 // This function is primarily used for converting variables from host
C51 COMPILER V8.06   UIP_ARCH                                                              03/10/2026 15:30:58 PAGE 46  

           =2 // byte order to network byte order. For converting constants to
           =2 // network byte order, use the HTONS() macro instead.
           =2 //
           =2 //#ifndef htons
           =2 //uint htons(uint val);
           =2 //#endif // htons //
