  82      =1  //
  83      =1  // \hideinitializer
  84      =1  //
  85      =1  #define uip_sethostaddr(addr) do { uip_hostaddr[0] = addr[0]; \
  86      =1                                uip_hostaddr[1] = addr[1]; } while(0)
  87      =1  
  88      =1  //
C51 COMPILER V8.06   UIP_ARCH                                                              03/10/2026 15:30:58 PAGE 18  

  89      =1  // Get the IP address of this host.
  90      =1  //
  91      =1  // The IP address is represented as a 4-byte array where the first
  92      =1  // octet of the IP address is put in the first member of the 4-byte
  93      =1  // array.
  94      =1  //
  95      =1  // \param addr A pointer to a 4-byte array that will be filled in with
  96      =1  // the currently configured IP address.
  97      =1  //
  98      =1  // \hideinitializer
  99      =1  //
 100      =1  #define uip_gethostaddr(addr) do { addr[0] = uip_hostaddr[0]; \
 101      =1                                addr[1] = uip_hostaddr[1]; } while(0)
 102      =1  
 103      =1  //
 104      =1  // \defgroup uipinit uIP initialization functions
 105      =1  // @{
