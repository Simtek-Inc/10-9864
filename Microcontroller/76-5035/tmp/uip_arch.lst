           =2 #define UIP_ACKDATA   1     // Signifies that the outstanding data was
           =2 //                             acked and the application should send
           =2 //                             out new data instead of retransmitting
           =2 //                             the last data.
           =2 #define UIP_NEWDATA   2     // Flags the fact that the peer has sent us new data. //
           =2 #define UIP_REXMIT    4     // Tells the application to retransmit the data that was last sent. //
