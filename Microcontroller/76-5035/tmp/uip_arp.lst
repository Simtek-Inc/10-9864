 845      =2      uip_stats_t recv;     //< Number of received ICMP packets. //
 846      =2      uip_stats_t sent;     //< Number of sent ICMP packets. //
 847      =2      uip_stats_t typeerr;  //< Number of ICMP packets with a wrong type. //
 848      =2    } icmp;                 //< ICMP statistics. //
