 134          /**
 135           * Initialize the ARP module.
 136           *
 137           */
 138          /*-----------------------------------------------------------------------------------*/
 139          void uip_arp_init(void)
 140          {
 141   1              for(i = 0; i < UIP_ARPTAB_SIZE; ++i) {
 142   2                      memset(arp_table[i].ipaddr, 0, 4);
 143   2              }
 144   1      }
 145          
 146          /*-----------------------------------------------------------------------------------*/
 147          /**
 148           * Periodic ARP processing function.
 149           *
 150           * This function performs periodic timer processing in the ARP module
 151           * and should be called at regular intervals. The recommended interval
 152           * is 10 seconds between the calls.
 153           *
 154           */
 155          /*-----------------------------------------------------------------------------------*/
 156          void uip_arp_timer(void)
 157          {
 158   1              struct arp_entry *tabptr;
 159   1      
 160   1              ++arptime;
 161   1              for(i = 0; i < UIP_ARPTAB_SIZE; ++i) {
 162   2                      tabptr = &arp_table[i];
 163   2                      if((tabptr->ipaddr[0] | tabptr->ipaddr[1]) != 0 &&
 164   2                              arptime - tabptr->time >= UIP_ARP_MAXAGE)
 165   2                      {
 166   3                              memset(tabptr->ipaddr, 0, 4);
 167   3                      }
 168   2              }
 169   1      }
 170          
 171          /*-----------------------------------------------------------------------------------*/
 172          
 173          static void uip_arp_update(uint *ipaddr, struct uip_eth_addr *ethaddr)
 174          {
 175   1              register struct arp_entry *tabptr;
 176   1      
 177   1              /* Walk through the ARP mapping table and try to find an entry to
 178   1                 update. If none is found, the IP -> MAC address mapping is
 179   1                 inserted in the ARP table. */
 180   1              for(i = 0; i < UIP_ARPTAB_SIZE; ++i) {
 181   2                      tabptr = &arp_table[i];
 182   2                      /* Only check those entries that are actually in use. */
 183   2                      if(tabptr->ipaddr[0] != 0 && tabptr->ipaddr[1] != 0) {
 184   3                              /* Check if the source IP address of the incoming packet matches
 185   3                                 the IP address in this ARP table entry. */
 186   3                              if(ipaddr[0] == tabptr->ipaddr[0] && ipaddr[1] == tabptr->ipaddr[1]) {
 187   4                                      /* An old entry found, update this and return. */
 188   4                                      memcpy(tabptr->ethaddr.addr, ethaddr->addr, 6);
 189   4                                      tabptr->time = arptime;
 190   4                                      return;
 191   4                              }
 192   3                      }
 193   2              }
 194   1      
 195   1              /* If we get here, no existing ARP table entry was found, so we create one. */
C51 COMPILER V8.06   UIP_ARP                                                               03/10/2026 15:30:58 PAGE 49  

 196   1      
 197   1              /* First, we try to find an unused entry in the ARP table. */
 198   1              for(i = 0; i < UIP_ARPTAB_SIZE; ++i) {
 199   2                      tabptr = &arp_table[i];
 200   2                      if(tabptr->ipaddr[0] == 0 && tabptr->ipaddr[1] == 0) {
 201   3                              break;
 202   3                      }
 203   2              }
 204   1      
 205   1              /* If no unused entry is found, we try to find the oldest entry and throw it away. */
 206   1              if(i == UIP_ARPTAB_SIZE) {
 207   2                      tmpage = 0;
 208   2                      c = 0;
 209   2                      for(i = 0; i < UIP_ARPTAB_SIZE; ++i) {
 210   3                              tabptr = &arp_table[i];
 211   3                              if(arptime - tabptr->time > tmpage) {
 212   4                                      tmpage = arptime - tabptr->time;
 213   4                                      c = i;
 214   4                              }
 215   3                      }
 216   2                      i = c;
 217   2                      tabptr = &arp_table[i];
 218   2              }
 219   1      
 220   1              /* Now, i is the ARP table entry which we will fill with the new information. */
 221   1              memcpy(tabptr->ipaddr, ipaddr, 4);
 222   1              memcpy(tabptr->ethaddr.addr, ethaddr->addr, 6);
 223   1              tabptr->time = arptime;
 224   1      }
