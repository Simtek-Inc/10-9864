 756      =2  //
 757      =2  // Representation of a uIP TCP connection.
 758      =2  //
 759      =2  // The uip_conn structure is used for identifying a connection. All
 760      =2  // but one field in the structure are to be considered read-only by an
 761      =2  // application. The only exception is the appstate field whos purpose
