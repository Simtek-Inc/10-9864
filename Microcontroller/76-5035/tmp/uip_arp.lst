 925      =2  // The actual uIP function which does all the work.
 926      =2  //
 927      =2  void uip_process(byte flag);
 928      =2  
 929      =2  // The following flags are passed as an argument to the uip_process()
C51 COMPILER V8.06   UIP_ARP                                                               03/10/2026 15:30:58 PAGE 33  

 930      =2  // function. They are used to distinguish between the two cases where
