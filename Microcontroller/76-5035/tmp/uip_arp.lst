 882      =2  // The following flags may be set in the global variable uip_flags
 883      =2  // before calling the application callback. The UIP_ACKDATA and
 884      =2  // UIP_NEWDATA flags may both be set at the same time, whereas the
 885      =2  // others are mutualy exclusive. Note that these flags should *NOT* be
 886      =2  // accessed directly, but through the uIP functions/macros.
 887      =2  
 888      =2  #define UIP_ACKDATA   1     // Signifies that the outstanding data was
 889      =2  //                             acked and the application should send
 890      =2  //                             out new data instead of retransmitting
 891      =2  //                             the last data.
 892      =2  #define UIP_NEWDATA   2     // Flags the fact that the peer has sent us new data. //
 893      =2  #define UIP_REXMIT    4     // Tells the application to retransmit the data that was last sent. //
