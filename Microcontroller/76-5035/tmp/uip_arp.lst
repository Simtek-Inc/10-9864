 837      =2      uip_stats_t hblenerr; //< Number of packets dropped due to wrong IP length, high byte. //
 838      =2      uip_stats_t lblenerr; //< Number of packets dropped due to wrong IP length, low byte. //
 839      =2      uip_stats_t fragerr;  //< Number of packets dropped since they were IP fragments. //
 840      =2      uip_stats_t chkerr;   //< Number of packets dropped due to IP checksum errors. //
 841      =2      uip_stats_t protoerr; //< Number of packets dropped since they were neither ICMP, UDP nor TCP. //
 842      =2    } ip;                   //< IP statistics. //
 843      =2    struct {
