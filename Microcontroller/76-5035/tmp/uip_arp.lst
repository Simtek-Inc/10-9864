 665      =2  
 666      =2  //
 667      =2  // Pack an IP address into a 4-byte array which is used by uIP to
 668      =2  // represent IP addresses.
 669      =2  //
 670      =2  // Example:
 671      =2  // \code
 672      =2  // uint ipaddr[2];
 673      =2  //
 674      =2  // uip_ipaddr(&ipaddr, 192,168,1,2); 
 675      =2  // \endcode
 676      =2  //
 677      =2  // \param addr A pointer to a 4-byte array that will be filled in with
 678      =2  // the IP addres.
 679      =2  // \param addr0 The first octet of the IP address.
 680      =2  // \param addr1 The second octet of the IP address.
 681      =2  // \param addr2 The third octet of the IP address.
C51 COMPILER V8.06   UIP_ARP                                                               03/10/2026 15:30:58 PAGE 29  

 682      =2  // \param addr3 The forth octet of the IP address. 
 683      =2  //
 684      =2  // \hideinitializer
 685      =2  //
 686      =2  #define uip_ipaddr(addr, addr0,addr1,addr2,addr3) do { \
 687      =2                       (addr)[0] = HTONS(((addr0) << 8) | (addr1)); \
 688      =2                       (addr)[1] = HTONS(((addr2) << 8) | (addr3)); \
 689      =2                    } while(0)
 690      =2  
 691      =2  //
 692      =2  // Convert 16-bit quantity from host byte order to network byte order.
 693      =2  //
 694      =2  // This macro is primarily used for converting constants from host
 695      =2  // byte order to network byte order. For converting variables to
 696      =2  // network byte order, use the htons() function instead.
 697      =2  //
 698      =2  // \hideinitializer
 699      =2  //
 700      =2  #ifndef HTONS
 701      =2  #if BYTE_ORDER == BIG_ENDIAN
 702      =2  #define HTONS(n) (n)
 703      =2  #else // BYTE_ORDER == BIG_ENDIAN //
           =2 #define HTONS(n) ((((uint)((n) & 0xff)) << 8) | (((n) & 0xff00) >> 8))
           =2 #endif // BYTE_ORDER == BIG_ENDIAN //
 706      =2  #endif // HTONS //
 707      =2  
 708      =2  //
 709      =2  // Convert 16-bit quantity from host byte order to network byte order.
