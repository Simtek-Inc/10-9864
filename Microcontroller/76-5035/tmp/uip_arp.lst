 764      =2  // configured in the "uipopt.h" header file.
 765      =2  //
 766      =2  struct uip_conn {
 767      =2          uint ripaddr[2];    //< The IP address of the remote host. //
 768      =2  
 769      =2          uint lport;         //< The local TCP port, in network byte order. //
 770      =2          uint rport;         //< The local remote TCP port, in network byte order. //  
 771      =2  
 772      =2          byte rcv_nxt[4];    //< The sequence number that we expect to receive next. //
 773      =2          byte snd_nxt[4];    //< The sequence number that was last sent by us. //
 774      =2          uint len;           //< Length of the data that was previously sent. //
 775      =2          uint mss;           //< Current maximum segment size for the connection. //
 776      =2          uint initialmss;    //< Initial maximum segment size for the connection. //  
 777      =2          byte sa;            //< Retransmission time-out calculation state variable. //
 778      =2          byte sv;            //< Retransmission time-out calculation state variable. //
 779      =2          byte rto;           //< Retransmission time-out. //
 780      =2          byte tcpstateflags; //< TCP state and flags. //
 781      =2          byte timer;         //< The retransmission timer. //
 782      =2          byte nrtx;          //< The number of retransmissions for the last segment sent. //
 783      =2  
 784      =2          byte window[2];
 785      =2          byte keepaliveflag;
 786      =2      byte sndkeepalive; // number of keepalive packet was sent //
 787      =2          uint keepalivetick;
 788      =2          byte tcpip_id;
 789      =2  
 790      =2          // The application state. //
 791      =2  //      byte appstate[UIP_APPSTATE_SIZE];  
 792      =2  };
