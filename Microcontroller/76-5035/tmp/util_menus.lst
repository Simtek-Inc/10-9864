  41      =1  #define I2C_7BIT                                0               // I2C 7-bit device address mode
  42      =1  #define I2C_RELOAD                              BIT4    // Reload I2C configuration EEPROM
  43      =1  #define I2C_SLV_IE                              BIT6    // I2C slave mode interrupt enable
  44      =1  #define I2C_MASTER_MODE                 BIT7    // I2C operated as master mode
