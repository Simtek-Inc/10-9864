  61      =1  #define I2C_BL_DONE                             BIT4    // Bootloader done
  62      =1  #define I2C_ARB_LOST                    BIT5    // Arbitration lost
  63      =1  #define I2C_BUS_BUSY                    BIT6    // I2C bus busy
