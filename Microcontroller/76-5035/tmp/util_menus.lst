 696          //----------------------------------------------------------------------------------------
 697          // name      : static int   UTIL_StrLen(char//Str1)
 698          // purpose   : Return length of string passed. space char counts as end of string.
 699          // params    : char *Str
 700          // returns   : return length of string passed.
 701          // note      :
 702          //----------------------------------------------------------------------------------------
 703          static int  UTIL_StrLen(char *Str)
 704          {
 705   1            int   StrLen = 0;
 706   1      
 707   1            while (*Str && (*Str != ' '))                                                       // find first NU
             -LL or space
 708   1              {
 709   2              Str ++;
