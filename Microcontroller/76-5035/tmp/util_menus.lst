  25      =1  // I2C Register //
  26      =1  #define I2CCPR                                  0x00    // I2C Clock Pre-scale Register
  27      =1  #define I2CTR                                   0x02    // I2C Transmit Register
  28      =1  #define I2CRR                                   0x03    // I2C Receive Register
  29      =1  #define I2CCTL                                  0x04    // I2C Control Register
  30      =1  #define I2CCR                                   0x05    // I2C Command Register
  31      =1  #define I2CMSR                                  0x06    // I2C Master Status Register
  32      =1  #define I2CSDAR                                 0x08    // I2C Slave Device Address Register
  33      =1  #define I2CSSR                                  0x0A    // I2C Slave Status Register
  34      =1  // I2CCTLR //
  35      =1  #define I2C_MST_IE                              BIT0    // I2C master mode interrupt enable
  36      =1  #define I2C_ENB                                 BIT1    // I2C module enable
  37      =1  #define I2C_DISB                                0               // I2C module disable
  38      =1  #define I2C_STANDARD                    BIT2    // I2C standard speed in slave mode
C51 COMPILER V8.06   UTIL_MENUS                                                            03/10/2026 15:31:01 PAGE 22  

  39      =1  #define I2C_FAST                                0               // I2C fast speed in slave mode
