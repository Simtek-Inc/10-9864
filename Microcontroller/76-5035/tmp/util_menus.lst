 463   1            cmd = UTIL_NextArg(cmdLine);
 464   1            if (*cmd == 0)
 465   1              {
 466   2              printd("Usage : read <device address> <memory address> <memory length>\n\r");
 467   2              return;
 468   2              }
 469   1            if (UTIL_StrToULong(cmd, &device) == FALSE)
 470   1              {
 471   2              printd("Device address error.\n\r");
