    inc(gRate_Indicator.uc);
    inc(gRate_Dimming.uc);
	inc(gRate_Display.uc);
//    inc(gRateC6.uc);
    end;//if gRate.uc >= (tbUpdateRate.Position) then

  if (fImageRedraw and cbxGraphicsEnable.Checked) then
    begin
    paintGUI;
    end;

