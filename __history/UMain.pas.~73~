function TMainForm.calculateChecksum(ptrCK: pbyte;cnt:byte):byte;
var  i,sum     : integer;
     tmp       : byte;
begin
  sum    := 0;
  for i  := 1 to cnt do
    begin
    tmp  := ptrCK^;
    sum  := sum + integer(tmp);
    inc(ptrCK);
    end;
  result := byte(sum);
end;


